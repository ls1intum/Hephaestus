{
  "name": "webhook-ingest",
  "version": "0.0.0-development",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc && tsc-alias",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "check": "biome check src test",
    "check:fix": "biome check --write --unsafe src test",
    "format": "biome format --write .",
    "format:check": "biome check --formatter-enabled=true --linter-enabled=false src test",
    "lint": "biome lint src test",
    "lint:fix": "biome lint --write src test",
    "typecheck": "tsc -p tsconfig.test.json --noEmit",
    "validate": "pnpm run typecheck && pnpm run lint && pnpm run test"
  },
  "dependencies": {
    "@hono/node-server": "2.0.2",
    "@nats-io/jetstream": "3.4.0",
    "@nats-io/nats-core": "3.4.0",
    "@nats-io/transport-node": "3.4.0",
    "dotenv": "17.4.2",
    "dotenv-expand": "13.0.0",
    "hono": "4.12.19",
    "pino": "10.3.1",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@types/node": "24.12.4",
    "@vitest/coverage-v8": "4.1.6",
    "tsc-alias": "1.8.17",
    "tsx": "4.22.1",
    "typescript": "6.0.3",
    "vitest": "4.1.6"
  },
  "engines": {
    "node": ">=24.0"
  }
}
