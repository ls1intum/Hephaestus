<?xml version="1.1" encoding="UTF-8" standalone="no"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <!--
        #1198 Wave 4 — PKCE (RFC 7636, S256) on the OAuth state nonce store.

        The verifier (43-128 unreserved chars per RFC 7636 §4.1) is persisted on
        the nonce row so the redirect can carry only the SHA-256 challenge while
        the original verifier survives the round-trip for the token-exchange POST.

        Single-use is inherited from the existing conditional UPDATE on
        consumed_at — reading the verifier in the same transaction as the
        markConsumed claim makes "read verifier ⇔ flip consumed_at" atomic.

        Nullable on purpose: PKCE is opt-in per strategy. App-install flows
        (GitHub App, GitLab webhooks) don't run OAuth, and the existing PAT-paste
        path does not either. Once all OAuth-using strategies adopt PKCE, the
        column gates flip to NOT NULL behind a per-kind check.
    -->

    <changeSet author="hephaestus-1198" id="1779701000000-1">
        <preConditions onFail="MARK_RAN">
            <not>
                <columnExists tableName="oauth_state_nonce" columnName="code_verifier"/>
            </not>
        </preConditions>
        <addColumn tableName="oauth_state_nonce">
            <column name="code_verifier" type="VARCHAR(128)">
                <constraints nullable="true"/>
            </column>
        </addColumn>
    </changeSet>

</databaseChangeLog>
