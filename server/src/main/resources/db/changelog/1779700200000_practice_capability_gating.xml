<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <!--
        #1198 Unified Integration Framework — practice capability gating.

        Adds three columns to `practice` so the workspace UI can show only practices
        whose required capabilities/aspects/family are satisfied by the workspace's
        active Connections:

          required_capabilities (jsonb[])  Subset of integration.spi.Capability names.
                                           UI gates: practice visible iff
                                           required_capabilities ⊆ workspace.activeCapabilities.
          required_aspects      (jsonb[])  Free-form context aspect names. The orchestrator
                                           unions these across enabled practices to decide
                                           what to fetch once (diff, commits, pr_metadata, ...).
          required_family       (varchar)  Narrows the practice to a single IntegrationFamily.Family
                                           (SCM, MESSAGING, ...). Null = family-agnostic.

        Backfill: every existing practice today is SCM-only (Swift/iOS code review against
        PRs/MRs), so set required_family = 'SCM'. capabilities + aspects start empty —
        per-practice declarations land as the framework matures.
    -->

    <changeSet author="hephaestus-1198" id="1779700200000-1">
        <preConditions onFail="MARK_RAN" onFailMessage="practice.required_capabilities already present">
            <not><columnExists tableName="practice" columnName="required_capabilities"/></not>
        </preConditions>
        <comment>Add required_capabilities jsonb — UI gating set of integration.spi.Capability names.</comment>
        <addColumn tableName="practice">
            <column name="required_capabilities"
                    type="jsonb"
                    defaultValueComputed="'[]'::jsonb">
                <constraints nullable="false"/>
            </column>
        </addColumn>
        <rollback>
            <dropColumn tableName="practice" columnName="required_capabilities"/>
        </rollback>
    </changeSet>

    <changeSet author="hephaestus-1198" id="1779700200000-2">
        <preConditions onFail="MARK_RAN" onFailMessage="practice.required_aspects already present">
            <not><columnExists tableName="practice" columnName="required_aspects"/></not>
        </preConditions>
        <comment>Add required_aspects jsonb — context aspects unioned across enabled practices.</comment>
        <addColumn tableName="practice">
            <column name="required_aspects"
                    type="jsonb"
                    defaultValueComputed="'[]'::jsonb">
                <constraints nullable="false"/>
            </column>
        </addColumn>
        <rollback>
            <dropColumn tableName="practice" columnName="required_aspects"/>
        </rollback>
    </changeSet>

    <changeSet author="hephaestus-1198" id="1779700200000-3">
        <preConditions onFail="MARK_RAN" onFailMessage="practice.required_family already present">
            <not><columnExists tableName="practice" columnName="required_family"/></not>
        </preConditions>
        <comment>Add required_family varchar(32) — narrow to IntegrationFamily.Family or null.</comment>
        <addColumn tableName="practice">
            <column name="required_family" type="varchar(32)"/>
        </addColumn>
        <rollback>
            <dropColumn tableName="practice" columnName="required_family"/>
        </rollback>
    </changeSet>

    <changeSet author="hephaestus-1198" id="1779700200000-4">
        <preConditions onFail="MARK_RAN" onFailMessage="required_family backfill already applied">
            <and>
                <columnExists tableName="practice" columnName="required_family"/>
                <sqlCheck expectedResult="0">
                    SELECT COUNT(*) FROM practice WHERE required_family IS NOT NULL
                </sqlCheck>
            </and>
        </preConditions>
        <comment>
            Backfill required_family = 'SCM' for every existing practice — today's catalog
            is exclusively code-review practices that apply to pull/merge requests.
        </comment>
        <sql>
            UPDATE practice SET required_family = 'SCM' WHERE required_family IS NULL;
        </sql>
        <rollback>
            <!-- Backfill is data-only; column drop in -3 rolls back the schema. -->
        </rollback>
    </changeSet>

</databaseChangeLog>
