<?xml version="1.1" encoding="UTF-8" standalone="no"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <!--
        #1198 OAuth single-use nonce store.

        Closes the within-TTL replay window left open by the HMAC-only state token.
        Every issue() writes a row; every consume() flips consumed_at via an atomic
        conditional UPDATE so the second caller for the same nonce sees 0 rows
        affected and is rejected.

        Pruning: OAuthStateNonceCleanupJob deletes rows past the retention window
        (default 7d). With a 10-min HMAC TTL, longer retention is purely defensive.
    -->

    <changeSet author="hephaestus-1198" id="1779700700000-1">
        <preConditions onFail="MARK_RAN" onFailMessage="oauth_state_nonce table already present">
            <not><tableExists tableName="oauth_state_nonce"/></not>
        </preConditions>
        <comment>Single-use nonce store for OAuth state.</comment>
        <createTable tableName="oauth_state_nonce">
            <column name="nonce" type="varchar(32)">
                <constraints primaryKey="true" primaryKeyName="pk_oauth_state_nonce" nullable="false"/>
            </column>
            <column name="workspace_id" type="bigint">
                <constraints nullable="false"/>
            </column>
            <column name="kind" type="varchar(48)">
                <constraints nullable="false"/>
            </column>
            <column name="issued_at" type="timestamp with time zone">
                <constraints nullable="false"/>
            </column>
            <column name="consumed_at" type="timestamp with time zone"/>
        </createTable>
        <createIndex tableName="oauth_state_nonce" indexName="ix_oauth_state_nonce_issued_at">
            <column name="issued_at"/>
        </createIndex>
        <rollback>
            <dropTable tableName="oauth_state_nonce"/>
        </rollback>
    </changeSet>

</databaseChangeLog>
