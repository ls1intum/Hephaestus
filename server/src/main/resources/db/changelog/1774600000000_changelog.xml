<?xml version="1.1" encoding="UTF-8" standalone="no"?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
                   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                   http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <!-- Drop legacy bad practice tables (code removed in this PR, data no longer read or written) -->

    <changeSet id="1774600000000-1" author="FelixTJDietrich">
        <preConditions onFail="MARK_RAN">
            <tableExists tableName="bad_practice_feedback"/>
        </preConditions>
        <comment>Drop bad_practice_feedback table (legacy detection system removed)</comment>
        <dropTable tableName="bad_practice_feedback" cascadeConstraints="true"/>
    </changeSet>

    <changeSet id="1774600000000-2" author="FelixTJDietrich">
        <preConditions onFail="MARK_RAN">
            <tableExists tableName="pull_request_bad_practice"/>
        </preConditions>
        <comment>Drop pull_request_bad_practice table (legacy detection system removed)</comment>
        <dropTable tableName="pull_request_bad_practice" cascadeConstraints="true"/>
    </changeSet>

    <changeSet id="1774600000000-3" author="FelixTJDietrich">
        <preConditions onFail="MARK_RAN">
            <tableExists tableName="bad_practice_detection"/>
        </preConditions>
        <comment>Drop bad_practice_detection table (legacy detection system removed)</comment>
        <dropTable tableName="bad_practice_detection" cascadeConstraints="true"/>
    </changeSet>

</databaseChangeLog>
