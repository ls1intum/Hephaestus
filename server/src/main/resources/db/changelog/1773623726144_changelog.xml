<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-3.8.xsd">

    <!-- Add job_token_hash for efficient token lookup (encrypted job_token cannot be queried) -->
    <changeSet author="llm-proxy" id="1773623726144-1">
        <addColumn tableName="agent_job">
            <column name="job_token_hash" type="VARCHAR(64)">
                <constraints nullable="true"/>
            </column>
        </addColumn>
        <createIndex tableName="agent_job" indexName="uk_agent_job_token_hash" unique="true">
            <column name="job_token_hash"/>
        </createIndex>
    </changeSet>

    <!-- Add frozen LLM API key on agent_job (encrypted at rest, independent of config FK) -->
    <changeSet author="llm-proxy" id="1773623726144-2">
        <addColumn tableName="agent_job">
            <column name="llm_api_key" type="TEXT"/>
        </addColumn>
    </changeSet>

</databaseChangeLog>
