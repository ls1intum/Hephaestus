        <createIndex tableName="feedback_post" indexName="ix_feedback_post_lookup">
            <column name="connection_id"/>
            <column name="subject_external_id"/>
            <column name="post_kind"/>
        </createIndex>
        <rollback>
            <dropTable tableName="feedback_post"/>
        </rollback>
