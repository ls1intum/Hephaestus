                             constraintName="uq_integration_webhook_subscription"/>
        <rollback>
            <dropTable tableName="integration_webhook_subscription"/>
        </rollback>
    </changeSet>

    <!-- ───────────────────────────────────────────────────────────────────────
         3. feedback_post cross-vendor edit-in-place tracking.
         ─────────────────────────────────────────────────────────────────────── -->

    <changeSet author="hephaestus-1198" id="1779790459343-6">
        <preConditions onFail="MARK_RAN" onFailMessage="feedback_post already present">
            <not><tableExists tableName="feedback_post"/></not>
        </preConditions>
        <comment>Cross-vendor edit-in-place tracking — Slack chat.update, Outline comments.update, GitHub PR comments.</comment>
        <createTable tableName="feedback_post">
            <column name="id" type="bigserial">
