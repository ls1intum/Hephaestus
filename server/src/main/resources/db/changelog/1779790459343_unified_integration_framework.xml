            <column name="deleted_at" type="timestamp with time zone"/>
        </createTable>
        <addForeignKeyConstraint
            baseTableName="outline_document"
            baseColumnNames="connection_id"
            referencedTableName="connection"
            referencedColumnNames="id"
            constraintName="fk_outline_document_connection"
            onDelete="CASCADE"/>
        <addUniqueConstraint tableName="outline_document"
                             columnNames="connection_id, document_id"
                             constraintName="uq_outline_document"/>
        <createIndex tableName="outline_document" indexName="ix_outline_document_connection">
            <column name="connection_id"/>
        </createIndex>
        <createIndex tableName="outline_document" indexName="ix_outline_document_collection">
            <column name="connection_id"/>
            <column name="collection_id"/>
        </createIndex>
        <rollback>
            <dropTable tableName="outline_document"/>
        </rollback>
    </changeSet>

    <!-- ───────────────────────────────────────────────────────────────────────
         8. ShedLock distributed-lock table.
         ─────────────────────────────────────────────────────────────────────── -->

    <changeSet author="hephaestus-1198" id="1779790459343-20">
        <preConditions onFail="MARK_RAN" onFailMessage="shedlock table already present">
            <not><tableExists tableName="shedlock"/></not>
        </preConditions>
        <comment>
            ShedLock lock-coordination table (one row per named lock). Schema is dictated
            by JdbcTemplateLockProvider — column names + types MUST match exactly.
        </comment>
        <createTable tableName="shedlock">
            <column name="name" type="varchar(64)">
                <constraints primaryKey="true" primaryKeyName="pk_shedlock" nullable="false"/>
            </column>
            <column name="lock_until" type="timestamp without time zone">
                <constraints nullable="false"/>
            </column>
            <column name="locked_at" type="timestamp without time zone">
                <constraints nullable="false"/>
            </column>
            <column name="locked_by" type="varchar(255)">
                <constraints nullable="false"/>
            </column>
        </createTable>
        <rollback>
            <dropTable tableName="shedlock"/>
        </rollback>
    </changeSet>

    <!-- ───────────────────────────────────────────────────────────────────────
         9. OAuth state nonce store (with PKCE code_verifier from the start).
         ─────────────────────────────────────────────────────────────────────── -->

    <changeSet author="hephaestus-1198" id="1779790459343-21">
        <preConditions onFail="MARK_RAN" onFailMessage="oauth_state_nonce table already present">
            <not><tableExists tableName="oauth_state_nonce"/></not>
        </preConditions>
        <comment>
            Single-use nonce store for OAuth state — closes the within-TTL replay window
            left open by HMAC-only state. PKCE verifier (RFC 7636 §4.1, 43–128 chars,
            opt-in per strategy) is persisted on the same row so the redirect carries
            only the SHA-256 challenge while the verifier survives the token-exchange
            POST round-trip.
        </comment>
        <createTable tableName="oauth_state_nonce">
            <column name="nonce" type="varchar(32)">
                <constraints primaryKey="true" primaryKeyName="pk_oauth_state_nonce" nullable="false"/>
            </column>
            <column name="workspace_id" type="bigint">
                <constraints nullable="false"/>
            </column>
            <column name="kind" type="varchar(48)">
                <constraints nullable="false"/>
            </column>
            <column name="issued_at" type="timestamp with time zone">
                <constraints nullable="false"/>
            </column>
            <column name="consumed_at" type="timestamp with time zone"/>
            <column name="code_verifier" type="VARCHAR(128)"/>
        </createTable>
        <createIndex tableName="oauth_state_nonce" indexName="ix_oauth_state_nonce_issued_at">
            <column name="issued_at"/>
        </createIndex>
        <rollback>
            <dropTable tableName="oauth_state_nonce"/>
        </rollback>
    </changeSet>

