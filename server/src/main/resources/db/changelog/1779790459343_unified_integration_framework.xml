    <!-- ───────────────────────────────────────────────────────────────────────
         4. agent_job classification columns + index.
         ─────────────────────────────────────────────────────────────────────── -->

    <changeSet author="hephaestus-1198" id="1779790459343-9">
        <preConditions onFail="MARK_RAN" onFailMessage="agent_job.integration_kind already present">
            <not><columnExists tableName="agent_job" columnName="integration_kind"/></not>
        </preConditions>
        <comment>Add integration_kind: enables per-kind dispatch (GITHUB/GITLAB/SLACK/OUTLINE).</comment>
        <addColumn tableName="agent_job">
            <column name="integration_kind" type="varchar(48)"/>
        </addColumn>
        <rollback>
            <dropColumn tableName="agent_job" columnName="integration_kind"/>
