    </changeSet>

    <changeSet author="hephaestus-1198" id="1779790459343-10">
        <preConditions onFail="MARK_RAN" onFailMessage="agent_job.subject_class already present">
            <not><columnExists tableName="agent_job" columnName="subject_class"/></not>
        </preConditions>
        <comment>Add subject_class: drives polymorphic dispatch (PULL_REQUEST, ISSUE, ...).</comment>
        <addColumn tableName="agent_job">
            <column name="subject_class" type="varchar(48)"/>
        </addColumn>
        <rollback>
            <dropColumn tableName="agent_job" columnName="subject_class"/>
        </rollback>
    </changeSet>

    <changeSet author="hephaestus-1198" id="1779790459343-11">
        <preConditions onFail="MARK_RAN" onFailMessage="idx_agent_job_subject already present">
            <not><indexExists indexName="idx_agent_job_subject"/></not>
        </preConditions>
        <comment>
            Index for agent-job filter queries: per-(kind, subject) timelines and
            kind-scoped recent-jobs listings. created_at DESC supports cursor pagination.
        </comment>
        <createIndex tableName="agent_job" indexName="idx_agent_job_subject">
            <column name="integration_kind"/>
            <column name="subject_class"/>
            <column name="created_at" descending="true"/>
        </createIndex>
        <rollback>
            <dropIndex tableName="agent_job" indexName="idx_agent_job_subject"/>
        </rollback>
    </changeSet>

    <!-- ───────────────────────────────────────────────────────────────────────
         5. practice capability gating (UI surface filter).
         ─────────────────────────────────────────────────────────────────────── -->

    <changeSet author="hephaestus-1198" id="1779790459343-12">
        <preConditions onFail="MARK_RAN" onFailMessage="practice.required_capabilities already present">
            <not><columnExists tableName="practice" columnName="required_capabilities"/></not>
        </preConditions>
        <comment>UI gating set of integration.spi.Capability names.</comment>
        <addColumn tableName="practice">
            <column name="required_capabilities" type="jsonb" defaultValueComputed="'[]'::jsonb">
                <constraints nullable="false"/>
            </column>
        </addColumn>
        <rollback>
            <dropColumn tableName="practice" columnName="required_capabilities"/>
        </rollback>
    </changeSet>

    <changeSet author="hephaestus-1198" id="1779790459343-13">
        <preConditions onFail="MARK_RAN" onFailMessage="practice.required_aspects already present">
            <not><columnExists tableName="practice" columnName="required_aspects"/></not>
        </preConditions>
        <comment>Context aspects unioned across enabled practices.</comment>
        <addColumn tableName="practice">
            <column name="required_aspects" type="jsonb" defaultValueComputed="'[]'::jsonb">
                <constraints nullable="false"/>
            </column>
        </addColumn>
        <rollback>
            <dropColumn tableName="practice" columnName="required_aspects"/>
        </rollback>
    </changeSet>

    <changeSet author="hephaestus-1198" id="1779790459343-14">
        <preConditions onFail="MARK_RAN" onFailMessage="practice.required_family already present">
            <not><columnExists tableName="practice" columnName="required_family"/></not>
        </preConditions>
        <comment>Narrow practice to a single IntegrationFamily.Family (SCM, MESSAGING, ...). Null = family-agnostic.</comment>
        <addColumn tableName="practice">
            <column name="required_family" type="varchar(32)"/>
        </addColumn>
        <rollback>
            <dropColumn tableName="practice" columnName="required_family"/>
        </rollback>
    </changeSet>

    <changeSet author="hephaestus-1198" id="1779790459343-15">
        <preConditions onFail="MARK_RAN" onFailMessage="required_family backfill already applied">
            <and>
                <columnExists tableName="practice" columnName="required_family"/>
                <sqlCheck expectedResult="0">
                    SELECT COUNT(*) FROM practice WHERE required_family IS NOT NULL
                </sqlCheck>
            </and>
        </preConditions>
        <comment>
            One-time backfill required_family = 'SCM' for every existing practice — today's
            catalog is exclusively code-review practices that apply to pull/merge requests.
        </comment>
        <sql>
            UPDATE practice SET required_family = 'SCM' WHERE required_family IS NULL;
        </sql>
        <rollback>
            <!-- Backfill is data-only; the schema rollback is on the addColumn changeset. -->
        </rollback>
    </changeSet>

    <!-- ───────────────────────────────────────────────────────────────────────
         6. Slack persistence (channels + messages).
         ─────────────────────────────────────────────────────────────────────── -->

    <changeSet author="hephaestus-1198" id="1779790459343-16">
        <preConditions onFail="MARK_RAN" onFailMessage="slack_channel table already present">
            <not><tableExists tableName="slack_channel"/></not>
        </preConditions>
        <comment>Slack channel metadata — one row per (connection, channel_id).</comment>
        <createTable tableName="slack_channel">
            <column name="id" type="bigserial">
                <constraints primaryKey="true" primaryKeyName="pk_slack_channel" nullable="false"/>
            </column>
            <column name="connection_id" type="bigint">
                <constraints nullable="false"/>
            </column>
            <column name="channel_id" type="varchar(64)">
                <constraints nullable="false"/>
            </column>
            <column name="name" type="varchar(256)"/>
            <column name="topic" type="text"/>
            <column name="purpose" type="text"/>
            <column name="is_archived" type="boolean" defaultValueBoolean="false">
                <constraints nullable="false"/>
            </column>
            <column name="archived_at" type="timestamp with time zone"/>
            <column name="member_count" type="integer"/>
            <column name="ingested_at" type="timestamp with time zone" defaultValueComputed="NOW()">
                <constraints nullable="false"/>
            </column>
        </createTable>
        <addForeignKeyConstraint
            baseTableName="slack_channel"
            baseColumnNames="connection_id"
            referencedTableName="connection"
            referencedColumnNames="id"
            constraintName="fk_slack_channel_connection"
            onDelete="CASCADE"/>
        <addUniqueConstraint tableName="slack_channel"
                             columnNames="connection_id, channel_id"
                             constraintName="uq_slack_channel"/>
        <createIndex tableName="slack_channel" indexName="ix_slack_channel_connection">
            <column name="connection_id"/>
        </createIndex>
        <rollback>
            <dropTable tableName="slack_channel"/>
        </rollback>
    </changeSet>

    <changeSet author="hephaestus-1198" id="1779790459343-17">
        <preConditions onFail="MARK_RAN" onFailMessage="slack_message table already present">
            <not><tableExists tableName="slack_message"/></not>
        </preConditions>
        <comment>Slack message — workspace-scoped via Connection. Soft-deleted on message_deleted.</comment>
        <createTable tableName="slack_message">
            <column name="id" type="bigserial">
                <constraints primaryKey="true" primaryKeyName="pk_slack_message" nullable="false"/>
            </column>
            <column name="connection_id" type="bigint">
                <constraints nullable="false"/>
            </column>
            <column name="team_id" type="varchar(64)">
                <constraints nullable="false"/>
            </column>
            <column name="channel_id" type="varchar(64)">
                <constraints nullable="false"/>
            </column>
            <column name="ts" type="varchar(64)">
                <constraints nullable="false"/>
            </column>
            <column name="thread_ts" type="varchar(64)"/>
            <column name="user_id" type="varchar(64)"/>
            <column name="text" type="text"/>
            <column name="blocks" type="jsonb"/>
            <column name="ingested_at" type="timestamp with time zone" defaultValueComputed="NOW()">
                <constraints nullable="false"/>
            </column>
            <column name="deleted_at" type="timestamp with time zone"/>
        </createTable>
        <addForeignKeyConstraint
            baseTableName="slack_message"
            baseColumnNames="connection_id"
            referencedTableName="connection"
            referencedColumnNames="id"
            constraintName="fk_slack_message_connection"
            onDelete="CASCADE"/>
        <addUniqueConstraint tableName="slack_message"
                             columnNames="connection_id, team_id, channel_id, ts"
                             constraintName="uq_slack_message"/>
        <!--
            Composite (connection_id, channel_id, ts DESC) supports the dominant access
            pattern: newest-first thread fetch within a channel. ts DESC must be the trailing
            column so the scan terminates after K rows for K-window mentor context loads.
        -->
        <sql>
            CREATE INDEX ix_slack_message_thread
                ON slack_message (connection_id, channel_id, ts DESC);
        </sql>
        <rollback>
            <sql>DROP INDEX IF EXISTS ix_slack_message_thread;</sql>
            <dropTable tableName="slack_message"/>
        </rollback>
    </changeSet>

