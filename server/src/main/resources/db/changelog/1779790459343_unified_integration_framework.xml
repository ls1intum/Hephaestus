            </column>
            <column name="connection_id" type="bigint">
                <constraints nullable="false" referencedTableName="connection" referencedColumnNames="id"
                             foreignKeyName="fk_feedback_post_connection"/>
            </column>
            <column name="subject_external_id" type="varchar(256)">
                <constraints nullable="false"/>
            </column>
            <column name="subject_class" type="varchar(48)">
                <constraints nullable="false"/>
            </column>
            <column name="post_kind" type="varchar(48)">
                <constraints nullable="false"/>
            </column>
            <column name="external_post_id" type="varchar(256)">
                <constraints nullable="false"/>
            </column>
            <column name="vendor_metadata" type="jsonb" defaultValueComputed="'{}'::jsonb">
                <constraints nullable="false"/>
            </column>
            <column name="created_at" type="timestamp with time zone" defaultValueComputed="NOW()">
                <constraints nullable="false"/>
            </column>
        </createTable>
        <addUniqueConstraint tableName="feedback_post"
                             columnNames="connection_id, subject_external_id, post_kind, external_post_id"
