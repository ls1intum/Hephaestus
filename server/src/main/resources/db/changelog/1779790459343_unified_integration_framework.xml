        <comment>Per-subscription signing-secret sidecar (Outline, Notion, MS Graph, Asana, Linear).</comment>
        <createTable tableName="integration_webhook_subscription">
            <column name="id" type="bigserial">
                <constraints primaryKey="true" primaryKeyName="pk_integration_webhook_subscription" nullable="false"/>
            </column>
            <column name="connection_id" type="bigint">
                <constraints nullable="false" referencedTableName="connection" referencedColumnNames="id"
                             foreignKeyName="fk_iws_connection"/>
            </column>
            <column name="subscription_id" type="varchar(128)">
                <constraints nullable="false"/>
            </column>
            <column name="signing_secret_encrypted" type="bytea">
                <constraints nullable="false"/>
            </column>
            <column name="credentials_alg" type="varchar(64)" defaultValue="aesgcm-v1">
                <constraints nullable="false"/>
            </column>
            <column name="events_subscribed" type="jsonb" defaultValueComputed="'[]'::jsonb">
                <constraints nullable="false"/>
