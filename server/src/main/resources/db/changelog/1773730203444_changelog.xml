<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-3.8.xsd">

    <!-- ==================== Practice catalog + finding tables ==================== -->
    <!--
    Creates two tables for the practice-aware review system:
    - practice: workspace-scoped practice definitions (e.g., "PR description quality")
    - practice_finding: immutable detection results with idempotent insertion
    -->

    <!-- Step 1: Create practice table -->
    <changeSet author="practice-data-model" id="1773730203444-1">
        <createTable tableName="practice">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints nullable="false" primaryKey="true" primaryKeyName="practice_pkey"/>
            </column>
            <column name="workspace_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="slug" type="VARCHAR(64)">
                <constraints nullable="false"/>
            </column>
            <column name="name" type="VARCHAR(128)">
                <constraints nullable="false"/>
            </column>
            <column name="category" type="VARCHAR(64)"/>
            <column name="description" type="TEXT">
                <constraints nullable="false"/>
            </column>
            <column name="trigger_events" type="JSONB" defaultValueComputed="'[]'::jsonb">
                <constraints nullable="false"/>
            </column>
            <column name="detection_prompt" type="TEXT"/>
            <column name="is_active" type="BOOLEAN" defaultValueBoolean="true">
                <constraints nullable="false"/>
            </column>
            <column name="created_at" type="TIMESTAMP(6) WITH TIME ZONE">
                <constraints nullable="false"/>
            </column>
            <column name="updated_at" type="TIMESTAMP(6) WITH TIME ZONE"/>
        </createTable>
    </changeSet>

    <!-- Step 2: Unique constraint — one practice per (workspace, slug) -->
    <changeSet author="practice-data-model" id="1773730203444-2">
        <addUniqueConstraint columnNames="workspace_id, slug"
            constraintName="uk_practice_workspace_slug" tableName="practice"/>
    </changeSet>

    <!-- Step 3: FK practice.workspace_id → workspace.id -->
    <changeSet author="practice-data-model" id="1773730203444-3">
        <addForeignKeyConstraint baseColumnNames="workspace_id" baseTableName="practice"
            constraintName="fk_practice_workspace" referencedColumnNames="id"
            referencedTableName="workspace" validate="true"/>
    </changeSet>

    <!-- Step 4: Index on (workspace_id, is_active) for filtered queries -->
    <changeSet author="practice-data-model" id="1773730203444-4">
        <createIndex indexName="idx_practice_workspace_active" tableName="practice">
            <column name="workspace_id"/>
            <column name="is_active"/>
        </createIndex>
    </changeSet>

    <!-- Step 5: Create practice_finding table -->
    <changeSet author="practice-data-model" id="1773730203444-5">
        <createTable tableName="practice_finding">
            <column name="id" type="UUID">
                <constraints nullable="false" primaryKey="true" primaryKeyName="practice_finding_pkey"/>
            </column>
            <column name="idempotency_key" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="agent_job_id" type="UUID">
                <constraints nullable="false"/>
            </column>
            <column name="practice_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="target_type" type="VARCHAR(32)">
                <constraints nullable="false"/>
            </column>
            <column name="target_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="contributor_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="title" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="verdict" type="VARCHAR(16)">
                <constraints nullable="false"/>
            </column>
            <column name="severity" type="VARCHAR(16)">
                <constraints nullable="false"/>
            </column>
            <column name="confidence" type="REAL">
                <constraints nullable="false"/>
            </column>
            <column name="evidence" type="JSONB"/>
            <column name="reasoning" type="TEXT"/>
            <column name="guidance" type="TEXT"/>
            <column name="guidance_method" type="VARCHAR(16)"/>
            <column name="detected_at" type="TIMESTAMP(6) WITH TIME ZONE">
                <constraints nullable="false"/>
            </column>
        </createTable>
    </changeSet>

    <!-- Step 6: Unique constraint on idempotency_key -->
    <changeSet author="practice-data-model" id="1773730203444-6">
        <addUniqueConstraint columnNames="idempotency_key"
            constraintName="uk_practice_finding_idempotency" tableName="practice_finding"/>
    </changeSet>

    <!-- Step 7: CHECK constraints for verdict, severity, confidence, guidance method -->
    <changeSet author="practice-data-model" id="1773730203444-7">
        <sql>
            ALTER TABLE practice_finding
            ADD CONSTRAINT chk_practice_finding_verdict
            CHECK (verdict IN ('POSITIVE', 'NEGATIVE', 'NOT_APPLICABLE', 'NEEDS_REVIEW'));

            ALTER TABLE practice_finding
            ADD CONSTRAINT chk_practice_finding_severity
            CHECK (severity IN ('CRITICAL', 'MAJOR', 'MINOR', 'INFO'));

            ALTER TABLE practice_finding
            ADD CONSTRAINT chk_practice_finding_confidence
            CHECK (confidence >= 0 AND confidence &lt;= 1);

            ALTER TABLE practice_finding
            ADD CONSTRAINT chk_practice_finding_guidance_method
            CHECK (guidance_method IS NULL OR guidance_method IN (
                'MODELING', 'COACHING', 'SCAFFOLDING', 'ARTICULATION', 'REFLECTION', 'EXPLORATION'
            ));
        </sql>
        <rollback>
            ALTER TABLE practice_finding DROP CONSTRAINT IF EXISTS chk_practice_finding_verdict;
            ALTER TABLE practice_finding DROP CONSTRAINT IF EXISTS chk_practice_finding_severity;
            ALTER TABLE practice_finding DROP CONSTRAINT IF EXISTS chk_practice_finding_confidence;
            ALTER TABLE practice_finding DROP CONSTRAINT IF EXISTS chk_practice_finding_guidance_method;
        </rollback>
    </changeSet>

    <!-- Step 8: FK practice_finding.agent_job_id → agent_job.id -->
    <changeSet author="practice-data-model" id="1773730203444-8">
        <addForeignKeyConstraint baseColumnNames="agent_job_id" baseTableName="practice_finding"
            constraintName="fk_practice_finding_agent_job" referencedColumnNames="id"
            referencedTableName="agent_job" validate="true"/>
    </changeSet>

    <!-- Step 9: FK practice_finding.practice_id → practice.id (CASCADE delete) -->
    <changeSet author="practice-data-model" id="1773730203444-9">
        <addForeignKeyConstraint baseColumnNames="practice_id" baseTableName="practice_finding"
            constraintName="fk_practice_finding_practice" referencedColumnNames="id"
            referencedTableName="practice" onDelete="CASCADE" validate="true"/>
    </changeSet>

    <!-- Step 10: FK practice_finding.contributor_id → user.id -->
    <changeSet author="practice-data-model" id="1773730203444-10">
        <addForeignKeyConstraint baseColumnNames="contributor_id" baseTableName="practice_finding"
            constraintName="fk_practice_finding_contributor" referencedColumnNames="id"
            referencedTableName="user" validate="true"/>
    </changeSet>

    <!-- Step 11: Indexes on practice_finding for query performance -->
    <changeSet author="practice-data-model" id="1773730203444-11">
        <createIndex indexName="idx_practice_finding_practice_detected" tableName="practice_finding">
            <column name="practice_id"/>
            <column name="detected_at" descending="true"/>
        </createIndex>
        <createIndex indexName="idx_practice_finding_contributor_detected" tableName="practice_finding">
            <column name="contributor_id"/>
            <column name="detected_at" descending="true"/>
        </createIndex>
        <createIndex indexName="idx_practice_finding_agent_job" tableName="practice_finding">
            <column name="agent_job_id"/>
        </createIndex>
        <createIndex indexName="idx_practice_finding_target" tableName="practice_finding">
            <column name="target_type"/>
            <column name="target_id"/>
        </createIndex>
    </changeSet>

    <!-- Step 12: Seed 5 initial practices for all existing workspaces -->
    <changeSet author="practice-data-model" id="1773730203444-12">
        <sql>
            INSERT INTO practice (workspace_id, slug, name, category, description, trigger_events, is_active, created_at, updated_at)
            SELECT w.id, v.slug, v.name, v.category, v.description, v.trigger_events::jsonb, true, NOW(), NOW()
            FROM workspace w
            CROSS JOIN (VALUES
                ('pr-description-quality', 'PR Description Quality', 'pr-hygiene',
                 'Evaluates whether PR descriptions clearly explain what changed and why.',
                 '["PullRequestCreated","PullRequestReady"]'),
                ('commit-message-quality', 'Commit Message Quality', 'commit-hygiene',
                 'Evaluates whether commit messages follow conventions and clearly describe the change.',
                 '["PullRequestCreated"]'),
                ('pr-scope', 'PR Scope', 'pr-hygiene',
                 'Evaluates whether a pull request has an appropriate scope — not too large, focused on a single concern.',
                 '["PullRequestCreated"]'),
                ('review-thoroughness', 'Review Thoroughness', 'review-quality',
                 'Evaluates whether a code review is thorough, providing actionable and constructive feedback.',
                 '["ReviewSubmitted"]'),
                ('error-handling', 'Error Handling', 'code-quality',
                 'Evaluates whether error handling follows best practices — no swallowed exceptions, proper logging, meaningful messages.',
                 '["PullRequestCreated"]')
            ) AS v(slug, name, category, description, trigger_events)
            WHERE NOT EXISTS (
                SELECT 1 FROM practice p WHERE p.workspace_id = w.id AND p.slug = v.slug
            );
        </sql>
        <rollback>
            DELETE FROM practice WHERE slug IN (
                'pr-description-quality', 'commit-message-quality', 'pr-scope',
                'review-thoroughness', 'error-handling'
            );
        </rollback>
    </changeSet>

</databaseChangeLog>
