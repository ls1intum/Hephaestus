    <!--
        auth_event is partitioned by occurred_at (monthly RANGE) and SELF-MANAGED in-app:
          a) Create the parent table + ck constraints. We cannot use Liquibase's createTable
             because it doesn't emit PARTITION BY, so we hand-roll the SQL.
          b) Create a DEFAULT partition (always-safe catch-all) PLUS the previous / current /
             next month's explicit partitions, so the very first INSERT after migration on a
             stock Postgres (no pg_partman) lands in a real partition and can NEVER fail with
             "no partition of relation auth_event found for row".
          c) Going forward, AuthEventPartitionManager (a @Scheduled, @SchedulerLock'd component,
             server-role only) creates-ahead the next 1-2 months and DROPs partitions older
             than 12 months. It runs once on ApplicationReadyEvent and monthly thereafter.
        This replaces the prior pg_partman dependency entirely — no non-stock extension required.
    -->
    <changeSet author="FelixTJDietrich" id="1780291041748-7-auth-event-parent">
        <preConditions onFail="MARK_RAN" onFailMessage="auth_event parent already present">
            <not><tableExists tableName="auth_event"/></not>
        </preConditions>
        <sql splitStatements="false"><![CDATA[
            CREATE TABLE auth_event (
                id                 BIGSERIAL,
                occurred_at        TIMESTAMP WITH TIME ZONE NOT NULL DEFAULT now(),
                -- sfk_* = scalar FK (no JPA @ManyToOne); excluded from the JPA-vs-DB drift gate (see header).
                account_id         BIGINT CONSTRAINT sfk_auth_event_account_id        REFERENCES account(id)       ON DELETE SET NULL,
                acting_account_id  BIGINT CONSTRAINT sfk_auth_event_acting_account_id REFERENCES account(id)       ON DELETE SET NULL,
                event_type         VARCHAR(48) NOT NULL,
                result             VARCHAR(16) NOT NULL,
                failure_reason     VARCHAR(64),
                git_provider_id    BIGINT CONSTRAINT sfk_auth_event_git_provider_id   REFERENCES git_provider(id),
                workspace_id       BIGINT CONSTRAINT sfk_auth_event_workspace_id      REFERENCES workspace(id)     ON DELETE SET NULL,
                identity_link_id   BIGINT CONSTRAINT sfk_auth_event_identity_link_id  REFERENCES identity_link(id) ON DELETE SET NULL,
                ip_inet            INET NOT NULL,
                user_agent         VARCHAR(512),
                details            JSONB,
                CONSTRAINT pk_auth_event PRIMARY KEY (id, occurred_at),
                CONSTRAINT ck_auth_event_result CHECK (result IN ('SUCCESS', 'FAILURE')),
                CONSTRAINT ck_auth_event_event_type CHECK (event_type IN (
                    'LOGIN', 'LOGIN_FAILED', 'LOGOUT', 'TOKEN_REFRESH', 'JWT_REVOKED',
                    'IDENTITY_LINKED', 'IDENTITY_UNLINKED',
                    'IMPERSONATION_BEGIN', 'IMPERSONATION_END',
                    'ACCOUNT_DELETED',
                    'EXPORT_REQUESTED', 'FEATURE_FLAG_CHANGED', 'APP_ROLE_CHANGED'
                ))
            ) PARTITION BY RANGE (occurred_at);

            CREATE INDEX ix_auth_event_account_occurred
                ON auth_event (account_id, occurred_at DESC) WHERE account_id IS NOT NULL;
            CREATE INDEX ix_auth_event_occurred ON auth_event (occurred_at);
            CREATE INDEX ix_auth_event_failure_ip
                ON auth_event (ip_inet) WHERE result = 'FAILURE';
        ]]></sql>
        <rollback>
            <!-- Raw CREATE TABLE has no auto-rollback. CASCADE drops the child partitions
                 (bootstrapped in -8) + all indexes with the parent. -->
            <sql splitStatements="false"><![CDATA[
                DROP TABLE IF EXISTS auth_event CASCADE;
            ]]></sql>
        </rollback>
    </changeSet>

    <!--
        Bootstrap partitions on stock Postgres (no pg_partman). Creates the DEFAULT catch-all
        plus the previous/current/next month's explicit monthly partitions so inserts are safe
        the instant Liquibase finishes — before any scheduler runs. AuthEventPartitionManager
        takes over create-ahead + retention at runtime. Fully idempotent: IF NOT EXISTS guards
        every CREATE, and the month names are computed from now() at migration time. Naming
        convention auth_event_pYYYYMM and auth_event_default MUST match AuthEventPartitionManager.
    -->
    <changeSet author="FelixTJDietrich" id="1780291041748-8-auth-event-bootstrap-partitions">
        <preConditions onFail="MARK_RAN" onFailMessage="auth_event parent missing — partitioning skipped">
            <tableExists tableName="auth_event"/>
        </preConditions>
        <sql splitStatements="false"><![CDATA[
            DO $auth_event_bootstrap$
            DECLARE
                month_start date;
                part_name   text;
                offsets     int[] := ARRAY[-1, 0, 1];  -- previous, current, next month
                off         int;
            BEGIN
                -- Always-safe catch-all so an insert can never fail, even before the scheduler runs.
                IF NOT EXISTS (
                    SELECT 1 FROM pg_class WHERE relname = 'auth_event_default'
                ) THEN
                    EXECUTE 'CREATE TABLE auth_event_default PARTITION OF auth_event DEFAULT';
                END IF;

                -- Pre-create prev / current / next month so normal rows land in a real monthly
                -- partition rather than the default.
                FOREACH off IN ARRAY offsets LOOP
                    month_start := (date_trunc('month', now()) + (off || ' month')::interval)::date;
                    part_name   := 'auth_event_p' || to_char(month_start, 'YYYYMM');
                    IF NOT EXISTS (
                        SELECT 1 FROM pg_class WHERE relname = part_name
                    ) THEN
                        EXECUTE format(
                            'CREATE TABLE %I PARTITION OF auth_event FOR VALUES FROM (%L) TO (%L)',
                            part_name,
                            month_start,
                            (month_start + interval '1 month')::date
                        );
                    END IF;
                END LOOP;
            END
            $auth_event_bootstrap$;
        ]]></sql>
        <rollback>
            <sql splitStatements="false"><![CDATA[
                DROP TABLE IF EXISTS auth_event_default;
            ]]></sql>
        </rollback>
    </changeSet>

    <!--
        Drop the legacy user.keycloak_subject column + its unique index (ADR 0016 Stage A,
        added in 1779790459343). Superseded by ADR 0017: identity now lives on
        account + identity_link; the SCM user row no longer carries an IdP subject, and the
        auth lookup is login → preferred_username, never this column. No backward compat.
        Idempotent (IF EXISTS) so it's safe whether or not 1779790459343 reached the DB.
    -->
    <changeSet author="FelixTJDietrich" id="1780291041748-9-drop-keycloak-subject">
        <preConditions onFail="MARK_RAN" onFailMessage="user.keycloak_subject already removed">
            <columnExists tableName="user" columnName="keycloak_subject"/>
        </preConditions>
        <sql splitStatements="false"><![CDATA[
            DROP INDEX IF EXISTS uq_user_keycloak_subject;
            ALTER TABLE "user" DROP COLUMN IF EXISTS keycloak_subject;
        ]]></sql>
        <rollback>
            <!-- Re-add the dropped column + its partial unique index (matching 1779790459343). -->
            <sql splitStatements="false"><![CDATA[
                ALTER TABLE "user" ADD COLUMN IF NOT EXISTS keycloak_subject VARCHAR(128);
                CREATE UNIQUE INDEX IF NOT EXISTS uq_user_keycloak_subject
                    ON "user" (keycloak_subject)
                    WHERE keycloak_subject IS NOT NULL;
            ]]></sql>
        </rollback>
    </changeSet>


    <!--
        Backing table for Bucket4j Postgres ProxyManager (SELECT … FOR UPDATE) used by the
        auth rate limiter (core.auth.ratelimit, ADR 0017 hardening). Distributed token-bucket
        state shared across replicas — no Redis. Schema is fixed by Bucket4j:
          - id        : the bucket key (VARCHAR — PrimaryKeyMapper.STRING).
          - state     : serialized bucket state (BYTEA).
          - expires_at: epoch-millis expiry (BIGINT), nullable.
        Not a JPA entity (managed by the Bucket4j library, like the shedlock table).
    -->
    <changeSet author="FelixTJDietrich" id="1780291041748-10-auth-rate-limit-bucket">
        <preConditions onFail="MARK_RAN" onFailMessage="auth_rate_limit_bucket already present">
            <not><tableExists tableName="auth_rate_limit_bucket"/></not>
        </preConditions>
        <createTable tableName="auth_rate_limit_bucket">
            <column name="id" type="VARCHAR(255)">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="state" type="BYTEA"/>
            <column name="expires_at" type="BIGINT"/>
        </createTable>
        <rollback>
            <dropTable tableName="auth_rate_limit_bucket"/>
        </rollback>
    </changeSet>

    <!--
        account_export — GDPR Art. 20 ("right to data portability") self-service export.
        One row per "download my data" request (entity: core.auth.export.AccountExport).
        Account-scoped. Lifecycle PENDING → PROCESSING → READY → EXPIRED (or → FAILED); the JSON
        bundle is stored inline in `payload` (BYTEA). The payload never contains tokens,
        credential blobs, or signing keys — see ExportBundle (the disclosure contract).
    -->
    <changeSet author="FelixTJDietrich" id="1780291041748-11-account-export">
        <preConditions onFail="MARK_RAN" onFailMessage="account_export already present">
            <not><tableExists tableName="account_export"/></not>
        </preConditions>
        <createTable tableName="account_export">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="account_id" type="BIGINT">
                <constraints nullable="false"
                             foreignKeyName="sfk_account_export_account"
                             referencedTableName="account"
                             referencedColumnNames="id"
                             deleteCascade="true"/>
            </column>
            <column name="status" type="VARCHAR(16)" defaultValue="PENDING">
                <constraints nullable="false"/>
            </column>
            <column name="requested_at" type="TIMESTAMP WITH TIME ZONE" defaultValueComputed="now()">
                <constraints nullable="false"/>
            </column>
            <column name="completed_at" type="TIMESTAMP WITH TIME ZONE"/>
            <column name="expires_at" type="TIMESTAMP WITH TIME ZONE"/>
            <column name="failure_reason" type="VARCHAR(128)"/>
            <column name="payload" type="BYTEA"/>
        </createTable>
        <sql><![CDATA[
            ALTER TABLE account_export ADD CONSTRAINT ck_account_export_status
                CHECK (status IN ('PENDING', 'PROCESSING', 'READY', 'FAILED', 'EXPIRED'));
            -- Hot path: "my exports" listing + the ownership-scoped (id, account_id) lookup.
            CREATE INDEX ix_account_export_account ON account_export (account_id);
            -- Backs the retention sweep: READY rows past expiry.
            CREATE INDEX ix_account_export_ready_expiry
                ON account_export (expires_at)
                WHERE status = 'READY';
        ]]></sql>
        <rollback>
            <!-- dropTable cascades the check constraint + both indexes. -->
            <dropTable tableName="account_export"/>
        </rollback>
    </changeSet>

    <!--
        GDPR Art. 17 erasure completeness: when AccountHardDeleteSweeper purges a subject it now
        anonymizes that subject's retained auth_event rows (raw IP, user_agent, and the free-text
        `details` blob, which for impersonation carries the operator-supplied reason + another account
        id). Redacting the IP to NULL is cleaner than a fake sentinel ('0.0.0.0' would pollute
        ix_auth_event_failure_ip and read as a real value), so relax ip_inet to nullable. Context-free
        on purpose: the runtime ddl-auto:create schema (AuthEvent.ipInet) and the Liquibase schema must
        agree in every environment.
    -->
    <changeSet author="FelixTJDietrich" id="1780291041748-12-auth-event-ip-nullable">
        <preConditions onFail="MARK_RAN" onFailMessage="auth_event.ip_inet already nullable">
            <sqlCheck expectedResult="NO">
                SELECT is_nullable FROM information_schema.columns
                 WHERE table_name = 'auth_event' AND column_name = 'ip_inet'
            </sqlCheck>
        </preConditions>
        <sql splitStatements="false"><![CDATA[
            ALTER TABLE auth_event ALTER COLUMN ip_inet DROP NOT NULL;
        ]]></sql>
        <rollback>
            <!-- Re-assert NOT NULL. Backfill any anonymized NULLs to the unspecified-address sentinel
                 first so the constraint can be re-added. -->
            <sql splitStatements="false"><![CDATA[
                UPDATE auth_event SET ip_inet = '0.0.0.0' WHERE ip_inet IS NULL;
                ALTER TABLE auth_event ALTER COLUMN ip_inet SET NOT NULL;
            ]]></sql>
        </rollback>
    </changeSet>

    <!--
        Audit immutability at the storage layer (prod only). The app owns auth_event and runs Liquibase
        as its own datasource role, so REVOKE binds (an owner CAN revoke its own ordinary
        INSERT/UPDATE/DELETE — Postgres treats them as self-granted), making the table append-only even
        to the owner — though the owner could GRANT them back, so REVOKE is a guardrail, not a proof.
        The BEFORE UPDATE OR DELETE trigger is the binding control: it fires for the owner too and blocks
        every mutation EXCEPT the GDPR Art. 17 redaction (NULL-out ip_inet/user_agent/details — see
        AccountPurger#anonymizeAuditRows). context="prod" because the ddl-auto test tier and the
        empty-context Liquibase proof test do fixture UPDATE/DELETE. Superuser still bypasses both; the
        app does not connect as superuser. Row-level triggers on a partitioned parent (PG 13+) cascade to
        all current and future partitions automatically.
    -->
    <changeSet author="FelixTJDietrich" id="1780291041748-13-auth-event-immutability" context="prod">
        <preConditions onFail="MARK_RAN" onFailMessage="auth_event immutability trigger already present">
            <sqlCheck expectedResult="0">
                SELECT count(*) FROM pg_trigger WHERE tgname = 'trg_auth_event_block_mutation'
            </sqlCheck>
        </preConditions>
        <sql splitStatements="false"><![CDATA[
            REVOKE UPDATE, DELETE, TRUNCATE ON auth_event FROM CURRENT_USER;

            CREATE OR REPLACE FUNCTION auth_event_block_mutation() RETURNS trigger AS $auth_immut$
            BEGIN
                IF TG_OP = 'DELETE' THEN
                    RAISE EXCEPTION 'auth_event is append-only: DELETE is not permitted (use partition retention)';
                END IF;
                -- Permit ONLY the GDPR Art. 17 redaction: the three PII columns set to NULL and NOTHING
                -- else changed. Comparing the whole row MINUS the redactable columns (to_jsonb - keys) is
                -- column-addition-proof: a future column is automatically protected with no edit here,
                -- closing the "enumerate every column" maintenance hazard.
                IF NEW.ip_inet IS NOT NULL
                   OR NEW.user_agent IS NOT NULL
                   OR NEW.details IS NOT NULL
                   OR (to_jsonb(NEW) - 'ip_inet' - 'user_agent' - 'details')
                        IS DISTINCT FROM (to_jsonb(OLD) - 'ip_inet' - 'user_agent' - 'details')
                THEN
                    RAISE EXCEPTION 'auth_event is append-only: only GDPR redaction (NULL ip_inet/user_agent/details) is permitted';
                END IF;
                RETURN NEW;
            END;
            $auth_immut$ LANGUAGE plpgsql;

            CREATE TRIGGER trg_auth_event_block_mutation
                BEFORE UPDATE OR DELETE ON auth_event
                FOR EACH ROW EXECUTE FUNCTION auth_event_block_mutation();
        ]]></sql>
        <rollback>
            <sql splitStatements="false"><![CDATA[
                DROP TRIGGER IF EXISTS trg_auth_event_block_mutation ON auth_event;
                DROP FUNCTION IF EXISTS auth_event_block_mutation();
                GRANT UPDATE, DELETE, TRUNCATE ON auth_event TO CURRENT_USER;
            ]]></sql>
        </rollback>
    </changeSet>

    <!--
        One-in-flight-export-per-account cap as a DB invariant. AccountExportService pre-checks for a
        PENDING/PROCESSING row and returns 409, but that check-then-insert is a TOCTOU: two concurrent
        POSTs under READ COMMITTED both see "none in flight" and both insert. This partial unique index
        is the authoritative guard — the loser's INSERT violates it, the service maps the
        DataIntegrityViolationException to the same 409. Stops unbounded async bundle assemblies (each
        persisting a BYTEA blob) — a DoS / storage-amplification vector.
    -->
    <changeSet author="FelixTJDietrich" id="1780291041748-14-account-export-one-in-flight">
        <preConditions onFail="MARK_RAN" onFailMessage="account_export in-flight unique index already present">
            <sqlCheck expectedResult="0">
                SELECT count(*) FROM pg_class WHERE relname = 'uq_account_export_in_flight'
            </sqlCheck>
        </preConditions>
        <sql splitStatements="false"><![CDATA[
            CREATE UNIQUE INDEX uq_account_export_in_flight
                ON account_export (account_id)
                WHERE status IN ('PENDING', 'PROCESSING');
        ]]></sql>
        <rollback>
            <sql splitStatements="false"><![CDATA[
                DROP INDEX IF EXISTS uq_account_export_in_flight;
            ]]></sql>
        </rollback>
    </changeSet>

    <!--
        Instance-scoped OAuth2 login providers (ADR 0017). Replaces the env-only login defaults and the
        per-workspace OIDC Connections with a single runtime-manageable table: env seeds the defaults on
        first boot, then an instance admin can add more (e.g. a self-hosted GitLab) without a redeploy.
        registration_id is the OAuth callback id (stable, unique). client_secret is sealed at rest by
        EncryptedStringConverter (AES-256-GCM), stored as the base64 TEXT it emits.
    -->
    <changeSet author="FelixTJDietrich" id="1780291041748-15-login-provider">
        <preConditions onFail="MARK_RAN" onFailMessage="login_provider table already present">
            <not>
                <tableExists tableName="login_provider"/>
            </not>
        </preConditions>
        <createTable tableName="login_provider">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="registration_id" type="VARCHAR(64)">
                <constraints nullable="false" unique="true" uniqueConstraintName="uq_login_provider_registration_id"/>
            </column>
            <column name="type" type="VARCHAR(10)">
                <constraints nullable="false"/>
            </column>
            <column name="display_name" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="base_url" type="VARCHAR(512)">
                <constraints nullable="false"/>
            </column>
            <column name="client_id" type="VARCHAR(512)">
                <constraints nullable="false"/>
            </column>
            <column name="client_secret" type="TEXT">
                <constraints nullable="false"/>
            </column>
            <column name="scopes" type="VARCHAR(512)">
                <constraints nullable="false"/>
            </column>
            <column name="enabled" type="BOOLEAN">
                <constraints nullable="false"/>
            </column>
            <column name="seeded_from_env" type="BOOLEAN">
                <constraints nullable="false"/>
            </column>
            <column name="created_at" type="TIMESTAMP WITH TIME ZONE" defaultValueComputed="now()">
                <constraints nullable="false"/>
            </column>
            <column name="updated_at" type="TIMESTAMP WITH TIME ZONE" defaultValueComputed="now()">
                <constraints nullable="false"/>
            </column>
        </createTable>
        <sql splitStatements="false"><![CDATA[
            ALTER TABLE login_provider ADD CONSTRAINT ck_login_provider_type CHECK (type IN ('GITHUB', 'GITLAB'));
        ]]></sql>
        <rollback>
            <dropTable tableName="login_provider"/>
        </rollback>
    </changeSet>

    <changeSet author="FelixTJDietrich" id="1780291041748-16-login-provider-instance-unique">
        <preConditions onFail="MARK_RAN">
            <sqlCheck expectedResult="0">SELECT COUNT(*) FROM pg_constraint WHERE conname = 'uq_login_provider_type_base_url'</sqlCheck>
        </preConditions>
        <comment>One login OAuth app per SCM instance: (type, base_url) must be unique.</comment>
        <addUniqueConstraint
            tableName="login_provider"
            columnNames="type, base_url"
            constraintName="uq_login_provider_type_base_url"/>
        <rollback>
            <dropUniqueConstraint tableName="login_provider" constraintName="uq_login_provider_type_base_url"/>
        </rollback>
    </changeSet>

</databaseChangeLog>
