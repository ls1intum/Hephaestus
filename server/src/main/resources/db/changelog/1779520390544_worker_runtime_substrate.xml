<?xml version="1.1" encoding="UTF-8" standalone="no"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <!--
        Worker runtime substrate + WSS control channel + dependent schema changes
        (issues #1098 + #1099, plus the dual-variant cleanup that consolidated mentor /
         practice / agent surfaces under one source of truth).

        Six logical changes consolidated into one branch-scoped changelog with a precise
        timestamp:

          1. agent_job.cancellation_reason — drain audit column.
          2. worker_token_denylist — fleet-wide JWT revocation table.
          3. practice.description backfill into practice.criteria.
          4. Drop practice.description.
          5. practice.criteria NOT NULL.
          6. agent_config.llm_base_url — per-workspace LLM gateway URL.

        Each step is preconditioned (onFail=MARK_RAN) so partial re-applies are idempotent
        and rollouts that span sibling worktrees stay safe.
    -->

    <changeSet author="FelixTJDietrich" id="1779520390544-1">
        <preConditions onFail="MARK_RAN" onFailMessage="agent_job.cancellation_reason already present">
            <not><columnExists tableName="agent_job" columnName="cancellation_reason"/></not>
        </preConditions>
        <comment>Worker drain cancellation audit (ADR 0009).</comment>
        <addColumn tableName="agent_job">
            <column name="cancellation_reason" type="varchar(32)"/>
        </addColumn>
        <rollback>
            <dropColumn tableName="agent_job" columnName="cancellation_reason"/>
        </rollback>
    </changeSet>

    <changeSet author="FelixTJDietrich" id="1779520390544-2">
        <preConditions onFail="MARK_RAN" onFailMessage="worker_token_denylist already present">
            <not><tableExists tableName="worker_token_denylist"/></not>
        </preConditions>
        <comment>Worker JWT revocation list (ADR 0009).</comment>
        <createTable tableName="worker_token_denylist">
            <column name="jti" type="varchar(64)">
                <constraints primaryKey="true" primaryKeyName="pk_worker_token_denylist" nullable="false"/>
            </column>
            <column name="revoked_at" type="timestamp with time zone">
                <constraints nullable="false"/>
            </column>
            <column name="expires_at" type="timestamp with time zone">
                <constraints nullable="false"/>
            </column>
        </createTable>
        <createIndex tableName="worker_token_denylist" indexName="ix_worker_token_denylist_expires_at">
            <column name="expires_at"/>
        </createIndex>
    </changeSet>

    <changeSet author="FelixTJDietrich" id="1779520390544-3">
        <preConditions onFail="MARK_RAN" onFailMessage="practice.description already removed; skipping backfill">
            <columnExists tableName="practice" columnName="description"/>
        </preConditions>
        <comment>Backfill practice.criteria from practice.description where empty.</comment>
        <sql>UPDATE practice SET criteria = description WHERE criteria IS NULL OR criteria = ''</sql>
        <rollback>
            <!-- Forward-only: criteria values that originated as description cannot be distinguished
                 after the fact. Operators who need rollback must restore from backup. -->
        </rollback>
    </changeSet>

    <changeSet author="FelixTJDietrich" id="1779520390544-4">
        <preConditions onFail="MARK_RAN" onFailMessage="practice.description already removed">
            <columnExists tableName="practice" columnName="description"/>
        </preConditions>
        <comment>Drop practice.description; criteria is the single source of truth.</comment>
        <dropColumn tableName="practice" columnName="description"/>
        <rollback>
            <!-- Forward-only: column data is gone. To restore, take a backup before applying. -->
        </rollback>
    </changeSet>

    <changeSet author="FelixTJDietrich" id="1779520390544-5">
        <preConditions onFail="MARK_RAN" onFailMessage="practice.criteria already NOT NULL">
            <columnExists tableName="practice" columnName="criteria"/>
            <not><columnExists tableName="practice" columnName="description"/></not>
        </preConditions>
        <comment>Make practice.criteria NOT NULL now that description is gone and backfill ran.</comment>
        <addNotNullConstraint tableName="practice" columnName="criteria" columnDataType="TEXT"/>
        <rollback>
            <dropNotNullConstraint tableName="practice" columnName="criteria" columnDataType="TEXT"/>
        </rollback>
    </changeSet>

    <changeSet author="FelixTJDietrich" id="1779520390544-6">
        <preConditions onFail="MARK_RAN" onFailMessage="agent_config.llm_base_url already present">
            <not><columnExists tableName="agent_config" columnName="llm_base_url"/></not>
        </preConditions>
        <comment>
            Per-workspace LLM base URL. Needed when the workspace's LLM endpoint does not
            speak the OpenAI Responses API (e.g. TUM GPU's chat/completions-only gateway).
            Routes via the hephaestus Pi provider over chat/completions.
        </comment>
        <addColumn tableName="agent_config">
            <column name="llm_base_url" type="VARCHAR(2048)"/>
        </addColumn>
        <rollback>
            <dropColumn tableName="agent_config" columnName="llm_base_url"/>
        </rollback>
    </changeSet>

</databaseChangeLog>
