<?xml version="1.1" encoding="UTF-8" standalone="no"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <!--
        #1198 Wave 3 — observability for the credential-blob v1 → v2 migration.

        Wave 3 moved AES-GCM AAD from a static string to a per-row context bound to
        (workspace_id, kind, instance_key, column). All NEW writes are v2; legacy
        rows decrypt with the static v1 AAD and migrate lazily on next save.

        This changeset adds a small tracking column so operators can answer
        "how many rows are still on v1?" without decrypting blobs:

        - `credentials_format_version` mirrors blob[0] (0x01 = v1, 0x02 = v2).
        - Partial index makes the "any v1 left?" query an index-only scan.
        - Liquibase backfill of the new column reads the first byte of the existing
          blob (no decryption needed) — safe to run with the DB online.

        Grafana / runbook: when the partial-index row count hits zero AND has stayed
        there for one week, the v1 branch in CredentialBundleConverter can be deleted
        in a follow-up release.
    -->

    <changeSet author="hephaestus-1198" id="1779700900000-1">
        <preConditions onFail="MARK_RAN">
            <not>
                <columnExists tableName="connection" columnName="credentials_format_version"/>
            </not>
        </preConditions>
        <addColumn tableName="connection">
            <column name="credentials_format_version" type="SMALLINT">
                <constraints nullable="true"/>
            </column>
        </addColumn>
    </changeSet>

    <changeSet author="hephaestus-1198" id="1779700900000-2">
        <sql>
            -- Backfill from the first byte of the existing ciphertext. NULL stays NULL
            -- (no credentials persisted). BYTEA's [1:1] is a single-byte substring.
            UPDATE connection
               SET credentials_format_version = get_byte(credentials_encrypted, 0)
             WHERE credentials_encrypted IS NOT NULL
               AND credentials_format_version IS NULL;
        </sql>
    </changeSet>

    <changeSet author="hephaestus-1198" id="1779700900000-3">
        <preConditions onFail="MARK_RAN">
            <not>
                <indexExists indexName="ix_connection_credentials_v1"/>
            </not>
        </preConditions>
        <sql>
            CREATE INDEX ix_connection_credentials_v1
                ON connection (id)
             WHERE credentials_format_version = 1;
        </sql>
    </changeSet>

</databaseChangeLog>
