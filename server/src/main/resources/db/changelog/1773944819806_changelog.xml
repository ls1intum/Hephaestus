<?xml version="1.1" encoding="UTF-8" standalone="no"?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
    http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <!--
        Add ai_review_enabled preference to user_preferences.

        Opt-out model (default TRUE): users receive AI-generated practice review
        comments immediately at GA. Independent from notificationsEnabled — email
        and PR comments are different channels.

        Consumed by the delivery gate (future) before posting comments.
        Findings are always stored regardless of this preference.
    -->
    <changeSet author="issue-865" id="1773944819806-1">
        <addColumn tableName="user_preferences">
            <column name="ai_review_enabled" type="BOOLEAN" defaultValueBoolean="true">
                <constraints nullable="false"/>
            </column>
        </addColumn>
    </changeSet>

</databaseChangeLog>
