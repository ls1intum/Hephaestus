<?xml version="1.1" encoding="UTF-8" standalone="no"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd"
>
    <!--
      ADR 0022: presence/assessment split + actor-free model. One consolidated changelog for the whole
      branch. Data-preserving renames (not drop+create) so the append-only research record survives.

      Mapping summary:
        practice_finding -> observation        finding_reaction -> reaction
        feedback_finding -> feedback_observation
        observation: idempotency_key->occurrence_key, observation->presence (OBSERVED->PRESENT,
          NOT_OBSERVED->ABSENT) + new assessment (GOOD/BAD derived from practice.kind), detected_at->observed_at,
          finding_fingerprint->recurrence_key, subject_user_id->about_user_id, DROP developer_id + observer,
          severity now nullable.
        reaction: finding_id -> feedback_id (re-anchored to Feedback), developer_id->reactor_user_id,
          finding_fingerprint->recurrence_key.
        feedback_observation: finding_id->observation_id, evidence_role->role.
        feedback: surface->channel, unit_ordinal->position, rendered_body->body, provenance->source,
          supersedes_id->replaces_id, feedback_thread_key->thread_key, DROP idempotency_key, model_id,
          composer_version, synthesis_prompt_version.
        feedback_placement: slot->placement_type, external_ref->posted_comment_ref, DROP anchor_old_path,
          anchor_quote, anchor_start_side, pinned_commit_sha, posted_state, thread_external_ref, resolved,
          resolved_at, resolved_external_ref.
        practice: artifact_type->applies_to, DROP kind + subject_role.
    -->

    <!-- ============================ practice ============================ -->
    <changeSet id="1782375132775-1" author="felix">
        <preConditions onFail="MARK_RAN">
            <columnExists tableName="practice" columnName="artifact_type"/>
        </preConditions>
        <renameColumn tableName="practice" oldColumnName="artifact_type" newColumnName="applies_to"
                      columnDataType="VARCHAR(32)"/>
        <rollback>
            <renameColumn tableName="practice" oldColumnName="applies_to" newColumnName="artifact_type"
                          columnDataType="VARCHAR(32)"/>
        </rollback>
    </changeSet>

