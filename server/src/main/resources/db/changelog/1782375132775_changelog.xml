    <!-- observation -> presence, with the OBSERVED->PRESENT / NOT_OBSERVED->ABSENT value migration. -->
    <changeSet id="1782375132775-7" author="felix">
        <preConditions onFail="MARK_RAN">
            <columnExists tableName="observation" columnName="observation"/>
        </preConditions>
        <dropDefaultValue tableName="observation" columnName="observation"/>
        <sql>ALTER TABLE observation DROP CONSTRAINT IF EXISTS chk_practice_finding_observation</sql>
        <renameColumn tableName="observation" oldColumnName="observation" newColumnName="presence"
                      columnDataType="VARCHAR(16)"/>
        <update tableName="observation">
            <column name="presence" value="PRESENT"/>
            <where>presence = 'OBSERVED'</where>
        </update>
        <update tableName="observation">
            <column name="presence" value="ABSENT"/>
            <where>presence = 'NOT_OBSERVED'</where>
        </update>
        <rollback>
            <update tableName="observation">
                <column name="presence" value="OBSERVED"/>
                <where>presence = 'PRESENT'</where>
            </update>
            <update tableName="observation">
                <column name="presence" value="NOT_OBSERVED"/>
                <where>presence = 'ABSENT'</where>
            </update>
            <renameColumn tableName="observation" oldColumnName="presence" newColumnName="observation"
                          columnDataType="VARCHAR(16)"/>
        </rollback>
    </changeSet>

    <!-- New assessment column, backfilled from old practice.kind x presence per ADR 0022. -->
    <changeSet id="1782375132775-8" author="felix">
        <preConditions onFail="MARK_RAN">
            <not><columnExists tableName="observation" columnName="assessment"/></not>
            <columnExists tableName="practice" columnName="kind"/>
        </preConditions>
        <addColumn tableName="observation">
            <column name="assessment" type="VARCHAR(8)"/>
        </addColumn>
        <!-- DESIRABLE(good) practice + PRESENT => GOOD; + ABSENT => BAD. -->
        <sql>
            UPDATE observation o SET assessment = 'GOOD'
            FROM practice p WHERE o.practice_id = p.id AND o.presence = 'PRESENT'
              AND p.kind = 'DESIRABLE';
        </sql>
        <sql>
            UPDATE observation o SET assessment = 'BAD'
            FROM practice p WHERE o.practice_id = p.id AND o.presence = 'ABSENT'
              AND p.kind = 'DESIRABLE';
        </sql>
        <!-- UNDESIRABLE(bad) practice + PRESENT => BAD; + ABSENT => GOOD. -->
        <sql>
            UPDATE observation o SET assessment = 'BAD'
            FROM practice p WHERE o.practice_id = p.id AND o.presence = 'PRESENT'
              AND p.kind = 'UNDESIRABLE';
        </sql>
        <sql>
            UPDATE observation o SET assessment = 'GOOD'
            FROM practice p WHERE o.practice_id = p.id AND o.presence = 'ABSENT'
              AND p.kind = 'UNDESIRABLE';
        </sql>
        <!-- NOT_APPLICABLE has no valence. -->
        <rollback>
            <dropColumn tableName="observation" columnName="assessment"/>
        </rollback>
    </changeSet>

    <!-- severity becomes nullable (a band only for a BAD observation). -->
