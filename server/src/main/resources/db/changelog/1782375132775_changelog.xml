      finding->feedback remap, so existing rows are cleared before the NOT NULL feedback_id is added.
    -->
    <changeSet id="1782375132775-28" author="felix">
        <preConditions onFail="MARK_RAN">
            <columnExists tableName="reaction" columnName="finding_id"/>
        </preConditions>
        <delete tableName="reaction"/>
        <sql>ALTER TABLE reaction DROP CONSTRAINT IF EXISTS fk_finding_reaction_finding</sql>
        <sql>ALTER TABLE reaction DROP CONSTRAINT IF EXISTS fk_finding_reaction_developer</sql>
        <dropColumn tableName="reaction" columnName="finding_id"/>
        <addColumn tableName="reaction">
            <column name="feedback_id" type="UUID">
                <constraints nullable="false"/>
            </column>
        </addColumn>
        <addForeignKeyConstraint baseTableName="reaction" baseColumnNames="feedback_id"
                                 constraintName="fk_reaction_feedback"
                                 referencedTableName="feedback" referencedColumnNames="id" onDelete="CASCADE"/>
        <rollback>
            <dropForeignKeyConstraint baseTableName="reaction" constraintName="fk_reaction_feedback"/>
            <dropColumn tableName="reaction" columnName="feedback_id"/>
            <addColumn tableName="reaction">
                <column name="finding_id" type="UUID">
                    <constraints nullable="false"/>
                </column>
            </addColumn>
        </rollback>
    </changeSet>

    <!-- Reaction indexes to the new column names. -->
    <changeSet id="1782375132775-29" author="felix">
        <preConditions onFail="MARK_RAN">
            <indexExists indexName="idx_finding_reaction_correlation"/>
        </preConditions>
        <sql>ALTER INDEX idx_finding_reaction_correlation RENAME TO idx_reaction_correlation</sql>
        <!-- idx_finding_reaction_finding_developer was auto-dropped with the finding_id column in -28. -->
        <sql>DROP INDEX IF EXISTS idx_finding_reaction_finding_developer</sql>
        <dropIndex tableName="reaction" indexName="idx_finding_reaction_developer_created"/>
        <createIndex tableName="reaction" indexName="idx_reaction_reactor_created">
            <column name="reactor_user_id"/>
            <column name="created_at" descending="true"/>
        </createIndex>
        <createIndex tableName="reaction" indexName="idx_reaction_feedback_reactor">
            <column name="feedback_id"/>
            <column name="reactor_user_id"/>
            <column name="created_at" descending="true"/>
        </createIndex>
        <rollback>
            <sql>ALTER INDEX idx_reaction_correlation RENAME TO idx_finding_reaction_correlation</sql>
            <dropIndex tableName="reaction" indexName="idx_reaction_reactor_created"/>
            <dropIndex tableName="reaction" indexName="idx_reaction_feedback_reactor"/>
            <createIndex tableName="reaction" indexName="idx_finding_reaction_developer_created">
                <column name="developer_id"/>
                <column name="created_at" descending="true"/>
            </createIndex>
            <createIndex tableName="reaction" indexName="idx_finding_reaction_finding_developer">
                <column name="finding_id"/>
                <column name="developer_id"/>
                <column name="created_at" descending="true"/>
            </createIndex>
        </rollback>
    </changeSet>

    <!-- ============================ practice: drop kind ============================ -->
    <changeSet id="1782375132775-30" author="felix">
        <preConditions onFail="MARK_RAN">
