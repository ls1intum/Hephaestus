<?xml version="1.1" encoding="UTF-8" standalone="no"?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
    http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <!--
        Add composite partial index on agent_job for re-analysis comment dedup.

        The findPreviousDeliveryCommentId query filters on:
          workspace_id = ? AND job_type = 'PULL_REQUEST_REVIEW'
          AND delivery_comment_id IS NOT NULL AND delivery_status = 'DELIVERED'
          AND metadata->>'pull_request_id' = ?
          ORDER BY completed_at DESC NULLS LAST

        This composite B-tree covers the full predicate with a partial filter on
        the invariant conditions (delivery_status, job_type, delivery_comment_id),
        keeping the index small while preventing a sequential scan.
    -->
    <changeSet author="practice-delivery" id="1774049866764-1">
        <sql>
            CREATE INDEX idx_agent_job_delivery_dedup
            ON agent_job (workspace_id, (metadata->>'pull_request_id'), completed_at DESC)
            WHERE delivery_status = 'DELIVERED'
              AND job_type = 'PULL_REQUEST_REVIEW'
              AND delivery_comment_id IS NOT NULL;
        </sql>
        <rollback>
            DROP INDEX IF EXISTS idx_agent_job_delivery_dedup;
        </rollback>
    </changeSet>

</databaseChangeLog>
