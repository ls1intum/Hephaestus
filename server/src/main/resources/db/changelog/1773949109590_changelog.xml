<?xml version="1.1" encoding="UTF-8" standalone="no"?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
    http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <!--
        Add delivery tracking columns to agent_job.

        delivery_status tracks whether results were posted to the git provider
        (separate from job execution status which models container lifecycle).

        delivery_comment_id stores the provider-specific comment/note identifier
        (GraphQL Node ID) for future updates.

        Both columns are nullable — null means no delivery was attempted
        (e.g., job types that don't post comments).
    -->
    <changeSet author="agent-feedback" id="1773949109590-1">
        <addColumn tableName="agent_job">
            <column name="delivery_status" type="VARCHAR(20)"/>
            <column name="delivery_comment_id" type="VARCHAR(255)"/>
        </addColumn>
    </changeSet>

    <!-- CHECK constraint to validate delivery_status enum values -->
    <changeSet author="agent-feedback" id="1773949109590-2">
        <sql>
            ALTER TABLE agent_job
            ADD CONSTRAINT chk_agent_job_delivery_status
            CHECK (delivery_status IS NULL OR delivery_status IN ('PENDING', 'DELIVERED', 'FAILED'));
        </sql>
        <rollback>
            ALTER TABLE agent_job DROP CONSTRAINT IF EXISTS chk_agent_job_delivery_status;
        </rollback>
    </changeSet>

</databaseChangeLog>
