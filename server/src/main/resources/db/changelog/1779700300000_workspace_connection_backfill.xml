<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <!--
        #1198 Unified Integration Framework — workspace → connection backfill.

        Phase 1 (wired into master.xml):
          Custom Java change that lifts the legacy per-workspace integration columns
          (installation_id, personal_access_token, git_provider_mode, gitlab_group_id,
           gitlab_webhook_id, server_url, slack_token, slack_signing_secret,
           leaderboard_notification_team, leaderboard_notification_channel_id,
           installation_linked_at, account_login) into one or two connection rows
           per workspace. The legacy columns are LEFT IN PLACE so existing readers
           continue to work — the JPA model + every caller still reads the legacy
           paths. See WorkspaceConnectionBackfillChange for the per-mode shape.

        Phase 2 (context="connection-cutover", NOT applied by default):
          Drops the twelve legacy columns. Activated by re-running Liquibase with
          the contexts argument set to "connection-cutover", AFTER every caller
          of getInstallationId, getProviderType, getPersonalAccessToken,
          getGitlabGroupId, getGitlabWebhookId, getServerUrl, getSlackToken,
          getSlackSigningSecret, getLeaderboardNotificationTeam,
          getLeaderboardNotificationChannelId, getInstallationLinkedAt,
          getAccountLogin has been migrated to read from the Connection registry.
          The corresponding setters must also be removed from Workspace.java
          before drop, otherwise JPA boot will fail (Hibernate maps to missing
          columns).
    -->

    <changeSet author="hephaestus-1198" id="1779700300000-1-backfill">
        <preConditions onFail="MARK_RAN" onFailMessage="connection table missing; framework changeset not yet applied">
            <tableExists tableName="connection"/>
        </preConditions>
        <comment>
            Backfill connection rows from legacy workspace columns. Idempotent: each
            insert is guarded by a per-(workspace_id, kind) existence check so re-running
            after a crash leaves the DB in a consistent state. App-mode installations
            store NO credential blob (tokens are minted on demand by GithubTokenRefresher).
            PAT-mode (GitHub PAT, GitLab PAT, Slack bot token) rewrap from the legacy
            EncryptedStringConverter format (Base64-wrapped ENC: prefix) into the new
            CredentialBundleConverter format (raw bytea, BearerToken bundle).
        </comment>
        <customChange class="de.tum.cit.aet.hephaestus.integration.registry.migration.WorkspaceConnectionBackfillChange"/>
        <rollback>
            <!--
                Rollback is "delete every connection row inserted by this change".
                We can't tell which rows were inserted by the change vs by runtime
                ConnectionService.transition() after the backfill ran, so the safest
                rollback is documented in the runbook:
                  DELETE FROM connection_audit WHERE connection_id IN
                    (SELECT id FROM connection WHERE state = 'ACTIVE'
                     AND id NOT IN (SELECT connection_id FROM connection_audit));
                  DELETE FROM connection WHERE state = 'ACTIVE'
                     AND id NOT IN (SELECT connection_id FROM connection_audit);
                The empty rollback below is intentional — we record this in the
                runbook, not in mechanical SQL.
            -->
        </rollback>
    </changeSet>

    <!--
        ────────────────────────────────────────────────────────────────────────
        DROP changesets — guarded by context="connection-cutover".

        Liquibase only runs changesets whose contexts match the runtime context.
        With no contexts argument (default boot), these are SKIPPED. To apply,
        run `liquibase update` with contexts set to "connection-cutover" AFTER
        the caller refactor is complete and verified in staging.
        ────────────────────────────────────────────────────────────────────────
    -->

    <changeSet author="hephaestus-1198" id="1779700300000-2-drop-installation-id"
               context="connection-cutover">
        <preConditions onFail="MARK_RAN" onFailMessage="workspace.installation_id already dropped">
            <columnExists tableName="workspace" columnName="installation_id"/>
        </preConditions>
        <dropColumn tableName="workspace" columnName="installation_id"/>
        <rollback>
            <addColumn tableName="workspace">
                <column name="installation_id" type="bigint"/>
            </addColumn>
        </rollback>
    </changeSet>

