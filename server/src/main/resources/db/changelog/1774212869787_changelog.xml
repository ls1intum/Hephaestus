<?xml version="1.1" encoding="UTF-8" standalone="no"?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
    http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <!--
        Add container_logs column to agent_job.

        Stores the full stdout/stderr captured from the Docker container
        after a job completes (or fails). Nullable — null means logs were
        not captured or the job hasn't finished yet.
    -->
    <changeSet author="agent-sandbox" id="1774212869787-1">
        <addColumn tableName="agent_job">
            <column name="container_logs" type="TEXT"/>
        </addColumn>
    </changeSet>

</databaseChangeLog>
