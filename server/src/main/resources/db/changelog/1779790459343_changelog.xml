    <changeSet author="hephaestus-1198" id="1779790459343-21b" runOnChange="false">
        <preConditions onFail="MARK_RAN" onFailMessage="no workspace rows to backfill from (fresh DB)">
            <sqlCheck expectedResult="t">
                SELECT EXISTS (SELECT 1 FROM workspace)
            </sqlCheck>
        </preConditions>
        <comment>
            Lift legacy Workspace integration columns into Connection rows BEFORE the
            section-9 column drops. See WorkspaceConnectionBackfillChange javadoc for
            per-mode mapping. Re-runnable: skips rows already inserted by an earlier run.
        </comment>
        <customChange class="de.tum.cit.aet.hephaestus.integration.core.connection.migration.WorkspaceConnectionBackfillChange"/>
        <rollback>
            <!-- Data-only customChange. Schema rollback is owned by section 1
                 (Connection table) and section 9 (legacy column re-add). -->
        </rollback>
    </changeSet>


    <changeSet author="hephaestus-1198" id="1779790459343-21c" runOnChange="false">
        <preConditions onFail="HALT" onFailMessage="ABORTED: workspace rows exist but no connection rows were backfilled before the section-9 column drops. Section 8 (WorkspaceConnectionBackfillChange) must succeed before legacy columns are dropped. Verify hephaestus.security.encryption-key / HEPHAESTUS_SECURITY_ENCRYPTION_KEY is set, inspect the migration logs, then re-run.">
            <or>
                <!-- Safe state #1: no workspace rows (fresh DB / CI). -->
                <sqlCheck expectedResult="f">SELECT EXISTS (SELECT 1 FROM workspace)</sqlCheck>
                <!-- Safe state #2: connection table populated. -->
                <sqlCheck expectedResult="t">SELECT EXISTS (SELECT 1 FROM connection)</sqlCheck>
                <!-- Safe state #3: legacy columns already gone (re-run on cutover DB). -->
                <not><columnExists tableName="workspace" columnName="installation_id"/></not>
                <!-- Safe state #4: no workspace carries a backfillable git_provider_mode, so the
                     empty connection table is correct (nothing to migrate), not a backfill failure.
                     The customChange skips NULL-mode rows, which would otherwise trip this guard.
                     columnExists is ordered first so the <and> short-circuits on the cutover re-run
                     where git_provider_mode is already dropped (covered by safe state #3). -->
                <and>
                    <columnExists tableName="workspace" columnName="git_provider_mode"/>
                    <sqlCheck expectedResult="f">SELECT EXISTS (SELECT 1 FROM workspace WHERE git_provider_mode IS NOT NULL)</sqlCheck>
                </and>
            </or>
        </preConditions>
        <comment>
            Cross-section data-loss guard. No DML; the precondition does the work.
            HALT semantics mean a failing assertion aborts the migration so the
            section-9 drops never run on a workspace-populated DB with empty
            connection table.
        </comment>
        <sql>SELECT 1</sql>
        <rollback>
            <!-- Guard has no schema side-effects; rollback is a no-op. -->
            <sql>SELECT 1</sql>
        </rollback>
    </changeSet>


