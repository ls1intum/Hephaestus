    <changeSet author="hephaestus-1198" id="1779790459343-34">
        <preConditions onFail="MARK_RAN" onFailMessage="uq_user_keycloak_subject already present">
            <not><indexExists indexName="uq_user_keycloak_subject"/></not>
        </preConditions>
        <comment>
            Partial unique index over (keycloak_subject) WHERE keycloak_subject IS NOT NULL.
            Synced rows without a Keycloak login (bots, organizations, observed-only
            contributors) carry NULL — the partial predicate keeps them outside the
            uniqueness contract while still guaranteeing one row per real authenticated
            person.
        </comment>
        <sql>
            CREATE UNIQUE INDEX uq_user_keycloak_subject
                ON "user" (keycloak_subject)
                WHERE keycloak_subject IS NOT NULL;
        </sql>
        <rollback>
            <sql>DROP INDEX IF EXISTS uq_user_keycloak_subject;</sql>
        </rollback>
    </changeSet>

