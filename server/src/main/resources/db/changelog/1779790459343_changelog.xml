<?xml version="1.1" encoding="UTF-8" standalone="no"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <!--
        #1198 Unified Integration Framework — single branch-scoped changelog.

        Sections:
          1.  connection + connection_audit (+ format-version + partial uniques).
          2.  feedback_post.
          3.  agent_job.{integration_kind, subject_class} + composite index.
          4.  (removed: slack_channel + slack_message — write-dead persistence layer deleted).
          5.  shedlock.
          7.  oauth_state_nonce (single-use OAuth state replay guard).
          8.  WorkspaceConnectionBackfillChange (Java customChange) — idempotent
              backfill of legacy Workspace columns into connection rows.
          8b. HALT guard — prevents section-9 drops on a populated workspace
              table with empty connection table.
          9.  Drop of eleven superseded Workspace columns; account_login stays.
          10. user.keycloak_subject + partial unique (ADR 0016 Stage A).

        Section 8 needs hephaestus.security.encryption-key (system property) or
        HEPHAESTUS_SECURITY_ENCRYPTION_KEY (env var) — the same 32-char key the app uses.
        Missing key + an encrypted PAT in scope → fail-fast, no silent drop.

        Every changeset uses onFail="MARK_RAN" preconditions so re-apply against
        a partially-migrated DB stays forward-only safe.
    -->


    <changeSet author="hephaestus-1198" id="1779790459343-1">
        <preConditions onFail="MARK_RAN" onFailMessage="connection table already present">
            <not><tableExists tableName="connection"/></not>
        </preConditions>
        <comment>Connection aggregate — multi-instance natural key (workspace_id, kind, instance_key).</comment>
        <createTable tableName="connection">
            <column name="id" type="bigserial">
                <constraints primaryKey="true" primaryKeyName="pk_connection" nullable="false"/>
            </column>
            <column name="workspace_id" type="bigint">
                <constraints nullable="false" referencedTableName="workspace" referencedColumnNames="id"
                             foreignKeyName="fk_connection_workspace"/>
            </column>
            <column name="kind" type="varchar(48)">
                <constraints nullable="false"/>
            </column>
            <!-- Nullable from the start — pre-bind OAuth slots carry NULL until the
                 vendor returns the instance handle. NULL-collision protection lives
                 on the partial unique index uq_connection_pending below. -->
            <column name="instance_key" type="varchar(128)"/>
            <column name="display_name" type="varchar(256)"/>
            <column name="state" type="varchar(32)" defaultValue="PENDING">
                <constraints nullable="false"/>
            </column>
            <column name="state_reason" type="varchar(512)"/>
            <column name="config" type="jsonb" defaultValueComputed="'{}'::jsonb">
                <constraints nullable="false"/>
            </column>
            <column name="credentials_encrypted" type="bytea"/>
            <column name="credentials_alg" type="varchar(64)"/>
            <column name="created_at" type="timestamp with time zone" defaultValueComputed="NOW()">
                <constraints nullable="false"/>
            </column>
            <column name="updated_at" type="timestamp with time zone" defaultValueComputed="NOW()">
                <constraints nullable="false"/>
            </column>
            <column name="version" type="bigint" defaultValueNumeric="0">
                <constraints nullable="false"/>
            </column>
        </createTable>
        <addUniqueConstraint tableName="connection"
                             columnNames="workspace_id, kind, instance_key"
                             constraintName="uq_connection"/>
        <sql>
            ALTER TABLE connection ADD CONSTRAINT ck_connection_kind
                CHECK (kind IN ('GITHUB','GITLAB','SLACK'));
            ALTER TABLE connection ADD CONSTRAINT ck_connection_state
                CHECK (state IN ('PENDING','ACTIVE','SUSPENDED','UNINSTALLED'));
        </sql>
        <!-- Unfiltered (workspace_id, kind) lookup index. -->
        <createIndex tableName="connection" indexName="ix_connection_workspace_kind">
            <column name="workspace_id"/>
            <column name="kind"/>
        </createIndex>
        <rollback>
            <dropTable tableName="connection"/>
        </rollback>
    </changeSet>

    <changeSet author="hephaestus-1198" id="1779790459343-2">
        <preConditions onFail="MARK_RAN" onFailMessage="uq_connection_pending partial index already present">
            <not><indexExists indexName="uq_connection_pending"/></not>
        </preConditions>
        <comment>
            Partial unique over (workspace_id, kind) WHERE instance_key IS NULL — closes
            the NULL-collision gap left by the base uq_connection (PostgreSQL treats
            NULL as distinct in standard unique constraints, so a workspace could
            otherwise install the same vendor twice in the pre-bind state).
        </comment>
        <sql>
            CREATE UNIQUE INDEX uq_connection_pending
                ON connection (workspace_id, kind)
                WHERE instance_key IS NULL;
        </sql>
        <rollback>
            <sql>DROP INDEX IF EXISTS uq_connection_pending;</sql>
        </rollback>
    </changeSet>

    <changeSet author="hephaestus-1198" id="1779790459343-2b">
        <preConditions onFail="MARK_RAN" onFailMessage="uq_connection_one_active_scm_per_workspace already present">
            <not><indexExists indexName="uq_connection_one_active_scm_per_workspace"/></not>
        </preConditions>
        <comment>
            Partial unique over (workspace_id) WHERE state = 'ACTIVE' AND kind IN
            ('GITHUB','GITLAB') — DB-level enforcement of the "one ACTIVE SCM
            provider per workspace" invariant. Belt to the @PrePersist suspenders
            on ConnectionService.findActiveProviderKind: history rows in SUSPENDED
            / UNINSTALLED state are unaffected, only one live SCM row may exist
            per workspace at a time.
        </comment>
        <sql>
            CREATE UNIQUE INDEX uq_connection_one_active_scm_per_workspace
                ON connection (workspace_id)
                WHERE state = 'ACTIVE' AND kind IN ('GITHUB','GITLAB');
        </sql>
        <rollback>
            <sql>DROP INDEX IF EXISTS uq_connection_one_active_scm_per_workspace;</sql>
        </rollback>
    </changeSet>

    <changeSet author="hephaestus-1198" id="1779790459343-3">
        <preConditions onFail="MARK_RAN" onFailMessage="connection_audit already present">
            <not><tableExists tableName="connection_audit"/></not>
        </preConditions>
        <comment>Connection audit — append-only with correlation-id idempotency on webhook replay.</comment>
        <createTable tableName="connection_audit">
            <column name="id" type="bigserial">
                <constraints primaryKey="true" primaryKeyName="pk_connection_audit" nullable="false"/>
            </column>
            <column name="connection_id" type="bigint">
                <constraints nullable="false" referencedTableName="connection" referencedColumnNames="id"
                             foreignKeyName="fk_connection_audit_connection"/>
            </column>
            <column name="event_type" type="varchar(48)">
                <constraints nullable="false"/>
            </column>
            <column name="from_state" type="varchar(32)"/>
            <column name="to_state" type="varchar(32)"/>
            <column name="actor_kind" type="varchar(32)">
                <constraints nullable="false"/>
            </column>
            <column name="actor_ref" type="varchar(256)"/>
            <column name="correlation_id" type="varchar(64)"/>
            <column name="detail" type="jsonb"/>
            <column name="occurred_at" type="timestamp with time zone" defaultValueComputed="NOW()">
                <constraints nullable="false"/>
            </column>
        </createTable>
        <!--
            uq_connection_audit_idempotency: webhook-replay idempotency contract.
            NULLS NOT DISTINCT (Postgres 15+) closes the replay-with-NULL gap left
            by the standard UNIQUE contract (server-side admin actions and install
            events arrive without a correlation_id, and the default treats every
            NULL as distinct). Implemented as a raw CREATE UNIQUE INDEX rather than
            addUniqueConstraint because Liquibase has no first-class attribute for
            NULLS NOT DISTINCT on a UNIQUE constraint.
        -->
        <sql>
            CREATE UNIQUE INDEX uq_connection_audit_idempotency
                ON connection_audit (connection_id, event_type, correlation_id)
                NULLS NOT DISTINCT;
        </sql>
        <createIndex tableName="connection_audit" indexName="ix_connection_audit_lookup">
            <column name="connection_id"/>
            <column name="occurred_at" descending="true"/>
        </createIndex>
        <rollback>
            <sql>DROP INDEX IF EXISTS uq_connection_audit_idempotency;</sql>
            <dropTable tableName="connection_audit"/>
        </rollback>
    </changeSet>


