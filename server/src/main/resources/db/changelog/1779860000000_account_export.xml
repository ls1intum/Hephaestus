<?xml version="1.1" encoding="UTF-8" standalone="no"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <!--
        account_export — GDPR Art. 20 ("right to data portability") self-service export.
        One row per "download my data" request (entity:
        de.tum.cit.aet.hephaestus.core.auth.export.AccountExport).

        Account-scoped (NOT workspace-scoped): an export spans everything a principal owns across
        workspaces. Registered in WorkspaceScopedTables.GLOBAL_TABLES + the arch-test
        GLOBAL_ENTITIES allowlist alongside the other core.auth identity tables.

        Lifecycle: PENDING → PROCESSING → READY → EXPIRED (or → FAILED). The JSON bundle is stored
        inline in `payload` (BYTEA) — there is no object store. A scheduled sweep
        (ExportRetentionSweeper) flips READY rows past `expires_at` to EXPIRED and nulls payload
        so the exported PII isn't retained beyond the 48h download window.

        The payload never contains tokens, credential blobs, JWT signing keys, or other users'
        data — see ExportBundle (the disclosure contract).
    -->
    <changeSet author="FelixTJDietrich" id="1779860000000-1-account-export">
        <preConditions onFail="MARK_RAN" onFailMessage="account_export already present">
            <not><tableExists tableName="account_export"/></not>
        </preConditions>
        <createTable tableName="account_export">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="account_id" type="BIGINT">
                <constraints nullable="false"
                             foreignKeyName="fk_account_export_account"
                             referencedTableName="account"
                             referencedColumnNames="id"
                             deleteCascade="true"/>
            </column>
            <column name="status" type="VARCHAR(16)" defaultValue="PENDING">
                <constraints nullable="false"/>
            </column>
            <column name="requested_at" type="TIMESTAMP WITH TIME ZONE" defaultValueComputed="now()">
                <constraints nullable="false"/>
            </column>
            <column name="completed_at" type="TIMESTAMP WITH TIME ZONE"/>
            <column name="expires_at" type="TIMESTAMP WITH TIME ZONE"/>
            <column name="failure_reason" type="VARCHAR(128)"/>
            <column name="payload" type="BYTEA"/>
        </createTable>
        <sql><![CDATA[
            ALTER TABLE account_export ADD CONSTRAINT ck_account_export_status
                CHECK (status IN ('PENDING', 'PROCESSING', 'READY', 'FAILED', 'EXPIRED'));
            -- Hot path: "my exports" listing + the ownership-scoped (id, account_id) lookup.
            CREATE INDEX ix_account_export_account ON account_export (account_id);
            -- Backs the retention sweep: READY rows past expiry.
            CREATE INDEX ix_account_export_ready_expiry
                ON account_export (expires_at)
                WHERE status = 'READY';
        ]]></sql>
    </changeSet>

</databaseChangeLog>
