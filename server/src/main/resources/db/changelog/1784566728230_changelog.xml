    <!-- 17. Clamp-down undercharges (#1368 migration-correctness fix): llm_usage_event.cost_usd is
         NUMERIC(12,6) (1784534949268-1), which tops out at 999999.999999 — LlmUsageRecorder's numeric
         guard silently clamps a genuinely larger computed cost down to that ceiling, undercharging
         against a workspace's own budget cap (which can be set arbitrarily high) the moment a real
         charge exceeds $1M. Widen to NUMERIC(18,6): a NUMERIC precision widen is metadata-only in PG
         (no table rewrite, momentary ACCESS EXCLUSIVE lock only). -->
    <changeSet id="1784566728230-17" author="hephaestus">
        <preConditions onFail="MARK_RAN" onFailMessage="llm_usage_event.cost_usd already widened to NUMERIC(18,6)">
            <sqlCheck expectedResult="0">
                SELECT count(*) FROM information_schema.columns
                WHERE table_name = 'llm_usage_event' AND column_name = 'cost_usd' AND numeric_precision = 18
            </sqlCheck>
        </preConditions>
        <comment>Widen llm_usage_event.cost_usd from NUMERIC(12,6) to NUMERIC(18,6) (#1368)</comment>
        <modifyDataType tableName="llm_usage_event" columnName="cost_usd" newDataType="NUMERIC(18,6)"/>
        <!-- Comment-only rollback, not a real narrowing ALTER: once a value that only fits in the wider
             18-digit precision has been written, narrowing back to NUMERIC(12,6) would overflow-error on
             that row — a data-preserving downgrade does not exist. Rolling back past this changeset means
             accepting the wider column stays in place. -->
        <rollback/>
    </changeSet>

