    <!-- 15. Duplicate upstream ids poison billing (#1368 migration-correctness fix): LlmUsageRecorder
         (agent/usage/LlmUsageRecorder#firstInstanceMatch) matches a call's frozen catalog binding by
         (connection_id, upstream_model_id) alone, since upstream_model_id carries no uniqueness
         constraint on its own — two catalog entries CAN legitimately point at the same upstream id
         today (different slugs/capabilities), and the recorder just picks the first enabled match. That
         is exactly the hazard: an admin who registers a second entry for the same (connection,
         upstream id) pair — e.g. one FREE, one PRICED, or a re-registration with a stale slug — gets a
         nondeterministic pricing outcome; a FREE sibling can silently shadow a PRICED one. One catalog
         entry per (connection, upstream id) closes that. -->
    <changeSet id="1784566728230-15" author="hephaestus">
        <preConditions onFail="MARK_RAN" onFailMessage="ux_llm_model_connection_upstream already exists">
            <not><indexExists indexName="ux_llm_model_connection_upstream"/></not>
        </preConditions>
        <comment>Unique (connection_id, upstream_model_id) on llm_model — no shadowing duplicate (#1368)</comment>
        <createIndex tableName="llm_model" indexName="ux_llm_model_connection_upstream" unique="true">
            <column name="connection_id"/>
            <column name="upstream_model_id"/>
        </createIndex>
        <rollback>
            <dropIndex tableName="llm_model" indexName="ux_llm_model_connection_upstream"/>
        </rollback>
    </changeSet>

