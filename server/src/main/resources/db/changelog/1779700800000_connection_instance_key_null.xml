<?xml version="1.1" encoding="UTF-8" standalone="no"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <!--
        #1198 follow-up: close the (workspace_id, kind) NULL-collision in connection.

        The base uq_connection is (workspace_id, kind, instance_key). In PostgreSQL,
        NULL is distinct in unique constraints, so two rows for the same workspace +
        kind with instance_key IS NULL satisfy the constraint and a workspace can
        install GitHub twice before the vendor binds the instance_key.

        Fix: a partial unique index over (workspace_id, kind) restricted to rows where
        instance_key IS NULL. Vendor binding still flips instance_key to a real value,
        at which point the base uq_connection takes over.
    -->

    <changeSet author="hephaestus-1198" id="1779700800000-1">
        <preConditions onFail="MARK_RAN">
            <not>
                <indexExists indexName="uq_connection_pending"/>
            </not>
        </preConditions>
        <sql>
            CREATE UNIQUE INDEX uq_connection_pending
                ON connection (workspace_id, kind)
                WHERE instance_key IS NULL;
        </sql>
    </changeSet>

</databaseChangeLog>
