<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        https://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <!--
        Flag GitLab group/project access token identities as BOT. Their logins
        follow the deterministic form group_&lt;id&gt;_bot_&lt;hash&gt; /
        project_&lt;id&gt;_bot_&lt;hash&gt;. Classifying them centrally lets
        TeamInfoDTO, LeaguePointsRecalculationService, and findAllByTeamIds
        filter service identities out of leaderboard and roster views.
    -->
    <changeSet id="1776632834575-1" author="hephaestus">
        <sql>
            UPDATE "user"
            SET type = 'BOT'
            WHERE type = 'USER'
              AND login ~ '^(group|project)_[0-9]+_bot_[0-9a-f]+$';
        </sql>
    </changeSet>

    <!--
        Clean slate for GitLab team memberships so the next sync repopulates
        them from DIRECT-only group members on the right teams.

        Background: GetGroupMembers previously asked GitLab for
        relations: [DIRECT, INHERITED]. Because GitLab propagates group members
        down the subgroup tree, every tutor subteam received the full root-group
        staff cohort (~20 users) in addition to its own students. The sync query
        now fetches DIRECT members only and the root group itself is synced as
        a parent Team, so staff members live on the root where they belong.

        Purging all rows lets the next team sync rebuild from the corrected
        query without carrying residue from the old shape. Phase C's
        removeStaleTeamMemberships eventually reconverges too, but only on
        subgroups the sync actually touches that cycle — wiping here avoids a
        visible "30-member tutor team" window after deploy.
    -->
    <changeSet id="1776632834575-2" author="hephaestus">
        <sql>
            DELETE FROM team_membership
            WHERE team_id IN (
                SELECT t.id
                FROM team t
                JOIN git_provider gp ON gp.id = t.provider_id
                WHERE gp.type = 'GITLAB'
            );
        </sql>
    </changeSet>

</databaseChangeLog>
