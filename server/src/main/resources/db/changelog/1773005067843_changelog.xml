<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-3.8.xsd">

    <!-- ==================== Repair Corrupted User Display Names ==================== -->
    <!--
    Webhook events from GitHub/GitLab often arrive without the user's display name.
    The old code fell back to the login when name was missing, and the SQL upsert
    unconditionally overwrote the name column. This caused real names to be replaced
    by logins for many users.

    The code fix (this same PR) changes:
    1. Processors no longer fall back to login when name is null
    2. The upsert SQL now uses COALESCE(EXCLUDED.name, "user".name) to preserve
       existing names

    This migration repairs already-corrupted rows by setting name = NULL where
    name equals login for human users. The next GitHub/GitLab sync cycle will
    re-populate these from the API (which includes the real name).
    -->

    <changeSet author="fix-display-names" id="1773005067843-repair-user-names">
        <comment>Null out user names that were incorrectly set to the login by webhooks,
            so the next sync cycle populates them with real display names from the API.</comment>
        <sql>
            UPDATE "user"
            SET name = NULL
            WHERE name = login
              AND type = 'USER'
        </sql>
        <rollback>
            <sql>
                -- Rollback: restore name = login for users with NULL names
                -- (best-effort; the real names will be fetched by sync anyway)
                UPDATE "user"
                SET name = login
                WHERE name IS NULL
                  AND type = 'USER'
            </sql>
        </rollback>
    </changeSet>

</databaseChangeLog>
