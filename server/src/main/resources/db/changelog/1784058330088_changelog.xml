<?xml version="1.1" encoding="UTF-8" standalone="no"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <!-- Shared sync execution records and connection activity for all integration kinds. -->

    <changeSet author="FelixTJDietrich" id="1784058330088-1">
        <preConditions onFail="MARK_RAN" onFailMessage="sync_job table already present">
            <not><tableExists tableName="sync_job"/></not>
        </preConditions>
        <comment>Shared sync-job execution record across every integration kind.</comment>
        <createTable tableName="sync_job">
            <column name="id" type="bigserial">
                <constraints primaryKey="true" primaryKeyName="pk_sync_job" nullable="false"/>
            </column>
            <column name="workspace_id" type="bigint">
                <constraints nullable="false" referencedTableName="workspace" referencedColumnNames="id"
                             foreignKeyName="fk_sync_job_workspace"/>
            </column>
            <column name="connection_id" type="bigint">
                <constraints nullable="false" referencedTableName="connection" referencedColumnNames="id"
                             foreignKeyName="fk_sync_job_connection"/>
            </column>
            <column name="kind" type="varchar(48)">
                <constraints nullable="false"/>
            </column>
            <column name="type" type="varchar(32)">
                <constraints nullable="false"/>
            </column>
            <!-- Not named "trigger" — sidesteps relying on every dialect/tool treating it as non-reserved. -->
            <column name="trigger_source" type="varchar(32)">
                <constraints nullable="false"/>
            </column>
            <column name="status" type="varchar(32)" defaultValue="PENDING">
                <constraints nullable="false"/>
            </column>
            <column name="cancel_requested" type="boolean" defaultValueBoolean="false">
                <constraints nullable="false"/>
            </column>
            <column name="started_at" type="timestamp with time zone"/>
            <column name="finished_at" type="timestamp with time zone"/>
            <column name="created_at" type="timestamp with time zone" defaultValueComputed="NOW()">
                <constraints nullable="false"/>
            </column>
            <column name="heartbeat_at" type="timestamp with time zone"/>
            <column name="items_processed" type="integer"/>
            <column name="items_total" type="integer"/>
            <column name="progress" type="jsonb"/>
            <column name="error_summary" type="TEXT"/>
            <column name="triggered_by_user_id" type="bigint"/>
        </createTable>
        <sql>
            ALTER TABLE sync_job ADD CONSTRAINT ck_sync_job_type
                CHECK (type IN ('INITIAL','RECONCILIATION','BACKFILL'));
            ALTER TABLE sync_job ADD CONSTRAINT ck_sync_job_trigger_source
                CHECK (trigger_source IN ('SCHEDULED','MANUAL','LIFECYCLE','SYSTEM'));
            ALTER TABLE sync_job ADD CONSTRAINT ck_sync_job_status
                CHECK (status IN ('PENDING','RUNNING','SUCCEEDED','SUCCEEDED_WITH_WARNINGS','FAILED','CANCELLED'));
        </sql>
        <rollback>
            <dropTable tableName="sync_job"/>
        </rollback>
    </changeSet>

    <changeSet author="FelixTJDietrich" id="1784058330088-2">
        <preConditions onFail="MARK_RAN" onFailMessage="ix_sync_job_connection_created already present">
            <not><indexExists indexName="ix_sync_job_connection_created"/></not>
        </preConditions>
        <comment>Job-history pagination: newest-first per connection.</comment>
        <sql>CREATE INDEX ix_sync_job_connection_created ON sync_job (connection_id, created_at DESC)</sql>
        <rollback>
            <dropIndex tableName="sync_job" indexName="ix_sync_job_connection_created"/>
        </rollback>
    </changeSet>

    <changeSet author="FelixTJDietrich" id="1784058330088-3">
        <preConditions onFail="MARK_RAN" onFailMessage="ux_sync_job_active partial index already present">
            <not><indexExists indexName="ux_sync_job_active"/></not>
        </preConditions>
        <comment>
            One-active-job-per-connection guard: race-proof backstop for the service-level check.
            A DataIntegrityViolationException from this index is translated to the same idempotent-
            absorb response as the service-level guard (SyncJobService.beginJob).
        </comment>
        <sql>CREATE UNIQUE INDEX ux_sync_job_active ON sync_job (connection_id) WHERE status IN ('PENDING', 'RUNNING')</sql>
        <rollback>
            <dropIndex tableName="sync_job" indexName="ux_sync_job_active"/>
        </rollback>
    </changeSet>

    <changeSet author="FelixTJDietrich" id="1784058330088-4">
        <preConditions onFail="MARK_RAN" onFailMessage="connection_activity table already present">
            <not><tableExists tableName="connection_activity"/></not>
        </preConditions>
        <comment>
            Webhook-liveness ("last event processed") watermark, one row per connection — no
            counters, no history. Written by ConnectionActivityRecorder from the NATS consumer's
            post-dispatch hook, throttled to at most one write per connection per 15s. Read side
            feeds SyncStatusService (core-owned data, never populated by per-vendor providers).
        </comment>
        <createTable tableName="connection_activity">
            <column name="connection_id" type="bigint">
                <constraints primaryKey="true" primaryKeyName="pk_connection_activity" nullable="false"
                             foreignKeyName="fk_connection_activity_connection"
                             referencedTableName="connection" referencedColumnNames="id"
                             deleteCascade="true"/>
            </column>
            <column name="workspace_id" type="bigint">
                <constraints nullable="false" referencedTableName="workspace" referencedColumnNames="id"
                             foreignKeyName="fk_connection_activity_workspace"/>
            </column>
            <column name="last_event_at" type="timestamp with time zone"/>
            <column name="last_event_type" type="varchar(128)"/>
        </createTable>
        <rollback>
            <dropTable tableName="connection_activity"/>
        </rollback>
    </changeSet>

    <changeSet author="FelixTJDietrich" id="1784058330088-5">
        <preConditions onFail="MARK_RAN" onFailMessage="sync-job connection ownership constraint already present">
            <not><foreignKeyConstraintExists foreignKeyName="fk_sync_job_connection_workspace"/></not>
        </preConditions>
        <comment>Ensure a sync job's connection belongs to the same workspace.</comment>
        <sql>
            ALTER TABLE connection ADD CONSTRAINT ux_connection_id_workspace UNIQUE (id, workspace_id);
            ALTER TABLE sync_job ADD CONSTRAINT fk_sync_job_connection_workspace
                FOREIGN KEY (connection_id, workspace_id) REFERENCES connection (id, workspace_id);
        </sql>
        <rollback>
            <sql>
                ALTER TABLE sync_job DROP CONSTRAINT fk_sync_job_connection_workspace;
                ALTER TABLE connection DROP CONSTRAINT ux_connection_id_workspace;
            </sql>
        </rollback>
    </changeSet>

</databaseChangeLog>
