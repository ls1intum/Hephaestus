<?xml version="1.1" encoding="UTF-8" standalone="no"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <!--
        #1198 — Persist the Keycloak subject claim on SCM `User`.

        Pairs with the deletion of the unused integration.identity layer
        (`HephaestusUser` + `IntegrationIdentity` + `JpaUserDirectory`). The
        SCM User row is now the authoritative person record; `keycloak_subject`
        is the stable join key against the IdP and replaces the indirection
        that the deleted layer was supposed to provide.

        Today's authorization path still resolves by `login` (see
        `WorkspaceContextFilter` + `SecurityUtils.getCurrentUserLogin`). This
        changeset only seeds the column so a follow-up PR can flip the lookup
        to `keycloak_subject` without a backfill window. See ADR 0016.

        Index strategy: partial unique on (keycloak_subject) WHERE NOT NULL.
        Synced rows (bots, organizations, contributors observed only via
        webhooks) keep coexisting with NULL subjects — only authenticated
        users ever populate the column, so the partial index is the correct
        uniqueness contract.

        Note: the `"user"` table name stays double-quoted because USER is a
        SQL reserved word in PostgreSQL.
    -->

    <changeSet author="hephaestus-1198" id="1779862439263-1">
        <preConditions onFail="MARK_RAN" onFailMessage="user.keycloak_subject already present">
            <not><columnExists tableName="user" columnName="keycloak_subject"/></not>
        </preConditions>
        <comment>Stable Keycloak subject claim — nullable until the first authenticated upsert populates it.</comment>
        <sql>
            ALTER TABLE "user" ADD COLUMN keycloak_subject VARCHAR(128);
        </sql>
        <rollback>
            <sql>ALTER TABLE "user" DROP COLUMN IF EXISTS keycloak_subject;</sql>
        </rollback>
    </changeSet>

    <changeSet author="hephaestus-1198" id="1779862439263-2">
        <preConditions onFail="MARK_RAN" onFailMessage="uq_user_keycloak_subject already present">
            <not><indexExists indexName="uq_user_keycloak_subject"/></not>
        </preConditions>
        <comment>
            Partial unique index over (keycloak_subject) WHERE keycloak_subject IS NOT NULL.
            Synced rows without a Keycloak login (bots, organizations, observed-only
            contributors) carry NULL — the partial predicate keeps them outside the
            uniqueness contract while still guaranteeing one row per real authenticated
            person.
        </comment>
        <sql>
            CREATE UNIQUE INDEX uq_user_keycloak_subject
                ON "user" (keycloak_subject)
                WHERE keycloak_subject IS NOT NULL;
        </sql>
        <rollback>
            <sql>DROP INDEX IF EXISTS uq_user_keycloak_subject;</sql>
        </rollback>
    </changeSet>

</databaseChangeLog>
