<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-3.8.xsd">

    <!-- Changesets in ./changelog/ are timestamp-prefixed and applied in lexical order.
         New migrations: drop a file named <unix-millis-timestamp>_changelog.xml into
         ./changelog/ — no master.xml edit needed.
         See docs/contributor/database-migration.mdx. -->
    <includeAll path="./changelog/" relativeToChangelogFile="true"/>

</databaseChangeLog>
