<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        https://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <!--
        Pi-only consolidation: normalise legacy CLAUDE_CODE/OPENCODE rows to PI, then drop
        agent_type. Both changeSets gate on column existence so re-runs no-op.
    -->
    <changeSet id="1778439253787-1" author="hephaestus">
        <preConditions onFail="MARK_RAN" onFailMessage="agent_type column already removed; nothing to normalise">
            <and>
                <columnExists tableName="agent_config" columnName="agent_type"/>
                <sqlCheck expectedResult="0">
                    SELECT count(*) FROM agent_config
                     WHERE agent_type NOT IN ('CLAUDE_CODE', 'OPENCODE', 'PI')
                </sqlCheck>
            </and>
        </preConditions>
        <comment>Normalise legacy AgentType values to PI before column drop (rolling-deploy safety)</comment>
        <update tableName="agent_config">
            <column name="agent_type" value="PI"/>
            <where>agent_type IN ('CLAUDE_CODE', 'OPENCODE')</where>
        </update>
    </changeSet>

    <changeSet id="1778439253787-2" author="hephaestus">
        <preConditions onFail="MARK_RAN" onFailMessage="agent_type column already removed">
            <columnExists tableName="agent_config" columnName="agent_type"/>
        </preConditions>
        <comment>Drop agent_type column — Pi-only consolidation</comment>
        <dropColumn tableName="agent_config" columnName="agent_type"/>
        <rollback>
            <!-- Schema-shape rollback; original CLAUDE_CODE/OPENCODE values are not restored. -->
            <addColumn tableName="agent_config">
                <column name="agent_type" type="VARCHAR(32)" defaultValue="PI">
                    <constraints nullable="false"/>
                </column>
            </addColumn>
        </rollback>
    </changeSet>

</databaseChangeLog>
