<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-3.8.xsd">

    <!--
    Drop the notifications_enabled column from user_preferences.
    The only consumer (MailNotificationSender / Postfix email) was removed.
    No code reads or writes this column anymore.
    -->

    <changeSet author="legacy-cleanup" id="1774528639746-1">
        <preConditions onFail="MARK_RAN">
            <columnExists tableName="user_preferences" columnName="notifications_enabled"/>
        </preConditions>
        <comment>Drop unused notifications_enabled column (mail infrastructure removed)</comment>
        <dropColumn tableName="user_preferences" columnName="notifications_enabled"/>
    </changeSet>

</databaseChangeLog>
