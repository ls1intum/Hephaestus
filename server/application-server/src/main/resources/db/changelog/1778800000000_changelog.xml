<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.27.xsd">

    <!--
        Drop the legacy chat_message_part table. The backfill changeset in
        1778756946278_changelog.xml has already denormalised every row into chat_message.parts
        JSONB; the intelligence-service that was the only writer to this table is deleted in
        this same PR. Precondition guards against rolling out drop on a database where backfill
        somehow missed a row.

        Rollback recreates the table with its original schema from 1754979350893_changelog.xml
        (column types, nullability, FK). Indexes are NOT recreated — they were derivative.
    -->
    <changeSet id="mentor-1071-drop-chat-message-part" author="hephaestus">
        <preConditions onFail="HALT" onFailMessage="chat_message_part is not empty — backfill incomplete or post-deploy writes occurred">
            <sqlCheck expectedResult="0">SELECT COUNT(*) FROM chat_message_part</sqlCheck>
        </preConditions>
        <comment>Drop legacy chat_message_part table (replaced by chat_message.parts JSONB)</comment>
        <dropTable tableName="chat_message_part"/>
        <rollback>
            <createTable tableName="chat_message_part">
                <column name="message_id" type="UUID">
                    <constraints nullable="false" primaryKey="true" primaryKeyName="chat_message_partPK"/>
                </column>
                <column name="order_index" type="INTEGER">
                    <constraints nullable="false" primaryKey="true" primaryKeyName="chat_message_partPK"/>
                </column>
                <column name="content" type="JSONB"/>
                <column name="original_type" type="VARCHAR(64)"/>
                <column name="type" type="VARCHAR(32)">
                    <constraints nullable="false"/>
                </column>
            </createTable>
            <addForeignKeyConstraint
                baseTableName="chat_message_part"
                baseColumnNames="message_id"
                constraintName="fk_chat_message_part_message"
                referencedTableName="chat_message"
                referencedColumnNames="id"
                onDelete="CASCADE"/>
        </rollback>
    </changeSet>

</databaseChangeLog>
