<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        https://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <!--
        Backfill chat_message.parts from chat_message_part rows. Idempotent: only touches rows
        where parts is NULL (or the default empty array). The WHERE clause targets messages that
        have any chat_message_part row; messages without parts stay '[]'.

        Part shape reconstruction:
          - `type` is COALESCE(original_type, lower(replace(type, '_', '-'))) so that TEXT →
            'text', STEP_START → 'step-start'. Tool/data parts always have original_type set
            (e.g. 'tool-fetch_context', 'data-finding'), so the fallback only kicks in for
            simple types.
          - `content` JSONB (which already holds the part body sans the type field) is merged.
          - Parts are ordered by chat_message_part.order_index ASC within each message.

        Rollback is a no-op because the column itself is dropped by the previous changeset's
        rollback; clearing the values without dropping the column would leave a half-rolled-back
        state.
    -->
    <changeSet id="1779000000002-1" author="hephaestus">
        <preConditions onFail="MARK_RAN" onFailMessage="chat_message.parts already populated">
            <and>
                <columnExists tableName="chat_message" columnName="parts"/>
                <sqlCheck expectedResult="1">
                    SELECT CASE WHEN EXISTS (
                        SELECT 1 FROM chat_message m
                        WHERE (m.parts IS NULL OR m.parts = '[]'::jsonb)
                          AND EXISTS (SELECT 1 FROM chat_message_part p WHERE p.message_id = m.id)
                    ) THEN 1 ELSE 0 END
                </sqlCheck>
            </and>
        </preConditions>
        <comment>Backfill chat_message.parts from chat_message_part rows (idempotent)</comment>
        <sql splitStatements="false">
            UPDATE chat_message m
               SET parts = COALESCE(sub.parts_array, '[]'::jsonb)
              FROM (
                SELECT
                    p.message_id,
                    jsonb_agg(
                        COALESCE(p.content, '{}'::jsonb)
                            || jsonb_build_object(
                                'type',
                                COALESCE(
                                    p.original_type,
                                    REPLACE(LOWER(p.type), '_', '-')
                                )
                            )
                        ORDER BY p.order_index
                    ) AS parts_array
                  FROM chat_message_part p
                 GROUP BY p.message_id
              ) sub
             WHERE m.id = sub.message_id
               AND (m.parts IS NULL OR m.parts = '[]'::jsonb);
        </sql>
        <rollback>
            <!-- No-op: the parts column drop in 1779000000001-1's rollback restores the prior state. -->
        </rollback>
    </changeSet>

</databaseChangeLog>
