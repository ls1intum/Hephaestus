<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-3.8.xsd">

    <!-- ==================== Agent orchestration foundation tables ==================== -->
    <!--
    Creates two tables for the coding agent orchestration system:
    - agent_config: one per workspace, stores agent type, model, encrypted API key, limits
    - agent_job: execution records with UUID PK, JSONB metadata/output, job_token auth
    -->

    <!-- Step 1: Create agent_config table (multiple per workspace, distinguished by name) -->
    <changeSet author="agent-orchestration" id="1773354889621-1">
        <createTable tableName="agent_config">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints nullable="false" primaryKey="true" primaryKeyName="agent_config_pkey"/>
            </column>
            <column name="workspace_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="name" type="VARCHAR(100)">
                <constraints nullable="false"/>
            </column>
            <column name="enabled" type="BOOLEAN" defaultValueBoolean="false">
                <constraints nullable="false"/>
            </column>
            <column name="agent_type" type="VARCHAR(32)">
                <constraints nullable="false"/>
            </column>
            <column name="model_name" type="VARCHAR(128)"/>
            <column name="llm_api_key" type="TEXT"/>
            <column name="llm_provider" type="VARCHAR(32)">
                <constraints nullable="false"/>
            </column>
            <column name="timeout_seconds" type="INTEGER" defaultValueNumeric="600">
                <constraints nullable="false"/>
            </column>
            <column name="max_concurrent_jobs" type="INTEGER" defaultValueNumeric="3">
                <constraints nullable="false"/>
            </column>
            <column name="allow_internet" type="BOOLEAN" defaultValueBoolean="false">
                <constraints nullable="false"/>
            </column>
            <column name="created_at" type="TIMESTAMP(6) WITH TIME ZONE">
                <constraints nullable="false"/>
            </column>
            <column name="updated_at" type="TIMESTAMP(6) WITH TIME ZONE"/>
        </createTable>
    </changeSet>

    <!-- Step 2: Unique constraint — one config per (workspace, name) -->
    <changeSet author="agent-orchestration" id="1773354889621-2">
        <addUniqueConstraint columnNames="workspace_id, name"
            constraintName="uk_agent_config_workspace_name" tableName="agent_config"/>
    </changeSet>

    <!-- Step 3: FK agent_config.workspace_id → workspace.id -->
    <changeSet author="agent-orchestration" id="1773354889621-3">
        <addForeignKeyConstraint baseColumnNames="workspace_id" baseTableName="agent_config"
            constraintName="fk_agent_config_workspace" referencedColumnNames="id"
            referencedTableName="workspace" validate="true"/>
    </changeSet>

    <!-- Step 4: Create agent_job table -->
    <changeSet author="agent-orchestration" id="1773354889621-4">
        <createTable tableName="agent_job">
            <column name="id" type="UUID">
                <constraints nullable="false" primaryKey="true" primaryKeyName="agent_job_pkey"/>
            </column>
            <column name="workspace_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="config_id" type="BIGINT"/>
            <column name="job_type" type="VARCHAR(50)">
                <constraints nullable="false"/>
            </column>
            <column name="status" type="VARCHAR(20)" defaultValue="QUEUED">
                <constraints nullable="false"/>
            </column>
            <column name="metadata" type="JSONB"/>
            <column name="output" type="JSONB"/>
            <column name="config_snapshot" type="JSONB">
                <constraints nullable="false"/>
            </column>
            <column name="job_token" type="TEXT">
                <constraints nullable="false"/>
            </column>
            <column name="idempotency_key" type="VARCHAR(255)"/>
            <column name="container_id" type="VARCHAR(64)"/>
            <column name="exit_code" type="INTEGER"/>
            <column name="error_message" type="TEXT"/>
            <column name="retry_count" type="INTEGER" defaultValueNumeric="0">
                <constraints nullable="false"/>
            </column>
            <column name="created_at" type="TIMESTAMP(6) WITH TIME ZONE">
                <constraints nullable="false"/>
            </column>
            <column name="started_at" type="TIMESTAMP(6) WITH TIME ZONE"/>
            <column name="completed_at" type="TIMESTAMP(6) WITH TIME ZONE"/>
        </createTable>
    </changeSet>

    <!-- Step 5: FK agent_job.workspace_id → workspace.id -->
    <changeSet author="agent-orchestration" id="1773354889621-5">
        <addForeignKeyConstraint baseColumnNames="workspace_id" baseTableName="agent_job"
            constraintName="fk_agent_job_workspace" referencedColumnNames="id"
            referencedTableName="workspace" validate="true"/>
    </changeSet>

    <!-- Step 6: FK agent_job.config_id → agent_config.id (SET NULL on delete) -->
    <changeSet author="agent-orchestration" id="1773354889621-6">
        <addForeignKeyConstraint baseColumnNames="config_id" baseTableName="agent_job"
            constraintName="fk_agent_job_config" referencedColumnNames="id"
            referencedTableName="agent_config" onDelete="SET NULL" validate="true"/>
    </changeSet>

    <!-- Step 7: Index on (workspace_id, status) for filtered job queries -->
    <changeSet author="agent-orchestration" id="1773354889621-7">
        <createIndex indexName="idx_agent_job_workspace_status" tableName="agent_job">
            <column name="workspace_id"/>
            <column name="status"/>
        </createIndex>
    </changeSet>

    <!-- Step 8: Partial index on running jobs for timeout monitoring -->
    <changeSet author="agent-orchestration" id="1773354889621-8">
        <sql>
            CREATE INDEX idx_agent_job_status_started
                ON agent_job(status, started_at)
                WHERE status = 'RUNNING';
        </sql>
    </changeSet>

    <!-- Step 9: Unique index on job_token (encrypted, used for LLM proxy auth) -->
    <changeSet author="agent-orchestration" id="1773354889621-9">
        <addUniqueConstraint columnNames="job_token"
            constraintName="uk_agent_job_token" tableName="agent_job"/>
    </changeSet>

    <!-- Step 10: Partial unique index for idempotency on active jobs -->
    <changeSet author="agent-orchestration" id="1773354889621-10">
        <sql>
            CREATE UNIQUE INDEX uk_agent_job_idempotency
                ON agent_job(workspace_id, idempotency_key)
                WHERE status IN ('QUEUED', 'RUNNING') AND idempotency_key IS NOT NULL;
        </sql>
    </changeSet>

</databaseChangeLog>
