<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        https://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <!--
        Restore the merge_commit_sha column on issue (pull-request row) so GitLab
        sync can persist MergeRequest.mergeCommitSha.

        The column was dropped in 1768089179000_changelog because GitHub's webhook
        payload omits it for merged PRs (GraphQL sync only supplies it on fresh
        fetches). GitLab exposes it consistently via GraphQL MergeRequest.mergeCommitSha
        and we need it as the anchor for the fallback commit→MR linker (PR #1021,
        Gap 1 — 41% NULL on merged MRs drives 17.6% commit_pull_request coverage).
    -->
    <changeSet id="1776400000000-1" author="hephaestus">
        <preConditions onFail="MARK_RAN">
            <not>
                <columnExists tableName="issue" columnName="merge_commit_sha"/>
            </not>
        </preConditions>
        <addColumn tableName="issue">
            <column name="merge_commit_sha" type="VARCHAR(40)"/>
        </addColumn>
    </changeSet>

</databaseChangeLog>
