<?xml version="1.1" encoding="UTF-8" standalone="no"?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
    http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <!--
        Drop the FK constraint on practice_finding.agent_job_id → agent_job.id.

        The PracticeFinding entity was changed from @ManyToOne AgentJob to a raw UUID
        column to break a module cycle between the 'agent' and 'practices' packages
        (enforced by ArchUnit). The FK is no longer declared in JPA, so Hibernate's
        reference schema does not include it — causing Liquibase drift detection to
        flag it.

        Referential integrity impact is minimal: AgentJob records are immutable
        (never deleted), the column is still NOT NULL with an index, and the insert
        path validates the job exists before persisting findings.
    -->
    <changeSet author="practice-detection" id="1773913964834-1">
        <dropForeignKeyConstraint baseTableName="practice_finding"
            constraintName="fk_practice_finding_agent_job"/>
    </changeSet>

</databaseChangeLog>
