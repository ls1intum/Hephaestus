<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
    http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-3.8.xsd">

    <!-- ============================================================ -->
    <!-- LLM usage tracking: move from per-call llm_call table to     -->
    <!-- job-level columns on agent_job.                              -->
    <!-- ============================================================ -->

    <!-- 1. Add job-level LLM usage columns to agent_job -->
    <changeSet id="1774785360089-1" author="hephaestus">
        <preConditions onFail="MARK_RAN">
            <not><columnExists tableName="agent_job" columnName="llm_model"/></not>
        </preConditions>
        <addColumn tableName="agent_job">
            <column name="llm_model" type="VARCHAR(100)"/>
            <column name="llm_total_calls" type="INTEGER"/>
            <column name="llm_total_input_tokens" type="INTEGER"/>
            <column name="llm_total_output_tokens" type="INTEGER"/>
            <column name="llm_total_reasoning_tokens" type="INTEGER"/>
            <column name="llm_cache_read_tokens" type="INTEGER"/>
            <column name="llm_cache_write_tokens" type="INTEGER"/>
            <column name="llm_cost_usd" type="DOUBLE PRECISION"/>
        </addColumn>
    </changeSet>

    <!-- 2. Drop per-call llm_call table (usage now tracked at job level) -->
    <changeSet id="1774785360089-2" author="hephaestus">
        <preConditions onFail="MARK_RAN">
            <tableExists tableName="llm_call"/>
        </preConditions>
        <dropTable tableName="llm_call"/>
    </changeSet>

    <!-- 3. Drop legacy duration column (job has started_at / completed_at) -->
    <changeSet id="1774785360089-3" author="hephaestus">
        <preConditions onFail="MARK_RAN">
            <columnExists tableName="agent_job" columnName="llm_total_duration_ms"/>
        </preConditions>
        <dropColumn tableName="agent_job" columnName="llm_total_duration_ms"/>
    </changeSet>

    <!-- 4. Add model version tracking to agent_config and agent_job -->
    <changeSet id="1774785360089-4" author="hephaestus">
        <preConditions onFail="MARK_RAN">
            <and>
                <not><columnExists tableName="agent_config" columnName="model_version"/></not>
                <not><columnExists tableName="agent_job" columnName="llm_model_version"/></not>
            </and>
        </preConditions>
        <addColumn tableName="agent_config">
            <column name="model_version" type="VARCHAR(50)"/>
        </addColumn>
        <addColumn tableName="agent_job">
            <column name="llm_model_version" type="VARCHAR(50)"/>
        </addColumn>
    </changeSet>

    <!-- ============================================================ -->
    <!-- Domain model cleanup: rename columns, tighten constraints,   -->
    <!-- remove cognitive apprenticeship and edit-in-place artifacts.  -->
    <!-- ============================================================ -->

    <!-- 5. Rename practice.detection_prompt → practice.criteria -->
    <changeSet id="1774785360089-5" author="hephaestus">
        <preConditions onFail="MARK_RAN">
            <columnExists tableName="practice" columnName="detection_prompt"/>
        </preConditions>
        <comment>Rename detection_prompt to criteria to match domain model</comment>
        <renameColumn tableName="practice"
                      oldColumnName="detection_prompt"
                      newColumnName="criteria"
                      columnDataType="TEXT"/>
    </changeSet>

    <!-- 6. Remove NEEDS_REVIEW verdict, keep POSITIVE/NEGATIVE/NOT_APPLICABLE -->
    <changeSet id="1774785360089-6" author="hephaestus">
        <comment>Delete NEEDS_REVIEW findings and tighten verdict constraint</comment>
        <delete tableName="practice_finding">
            <where>verdict = 'NEEDS_REVIEW'</where>
        </delete>
        <sql>
            ALTER TABLE practice_finding DROP CONSTRAINT IF EXISTS chk_practice_finding_verdict;
            ALTER TABLE practice_finding ADD CONSTRAINT chk_practice_finding_verdict
                CHECK (verdict IN ('POSITIVE', 'NEGATIVE', 'NOT_APPLICABLE'));
        </sql>
    </changeSet>

    <!-- 7. Drop guidance_method column (cognitive apprenticeship removed) -->
    <changeSet id="1774785360089-7" author="hephaestus">
        <comment>Drop guidance_method column and its CHECK constraint</comment>
        <sql>
            ALTER TABLE practice_finding DROP CONSTRAINT IF EXISTS chk_practice_finding_guidance_method;
            ALTER TABLE practice_finding DROP COLUMN IF EXISTS guidance_method;
        </sql>
    </changeSet>

    <!-- 8. Drop delivery dedup index (edit-in-place logic removed) -->
    <changeSet id="1774785360089-8" author="hephaestus">
        <comment>Drop delivery dedup index — no longer needed</comment>
        <sql>
            DROP INDEX IF EXISTS idx_agent_job_delivery_dedup;
        </sql>
    </changeSet>

</databaseChangeLog>
