<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.27.xsd">

    <changeSet id="mentor-add-session-jsonl-blob" author="hephaestus">
        <preConditions onFail="MARK_RAN" onFailMessage="session_jsonl column already exists">
            <not><columnExists tableName="chat_thread" columnName="session_jsonl"/></not>
        </preConditions>
        <comment>Verbatim Pi SDK session JSONL bytes for byte-identical cold-restart.</comment>
        <sql>ALTER TABLE chat_thread ADD COLUMN session_jsonl BYTEA NULL;</sql>
        <rollback>
            <sql>ALTER TABLE chat_thread DROP COLUMN IF EXISTS session_jsonl;</sql>
        </rollback>
    </changeSet>

</databaseChangeLog>
