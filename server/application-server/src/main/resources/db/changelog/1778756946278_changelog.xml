<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        https://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <!--
        Pi mentor (#1071) — single consolidated schema migration.
        Author timestamp: 2026-05-14 11:09:06 UTC (epoch-ms 1778756946278).

        Single file = single reviewable unit for the whole mentor schema delta. Split into
        per-concern <changeSet>s so each retains atomic rollback; the in-flight unique index
        runs CONCURRENTLY (mandatory outside a transaction).

        Changeset order matters: drop of chat_message_part MUST sit last so the backfill +
        cascade-FK + shape checks have all run against the live table first.

        1.  chat_message.parts JSONB column
        2.  backfill from chat_message_part (idempotent)
        3.  parts shape: NOT NULL + array CHECK
        4.  metadata shape: CHECK (NULL or JSON object)
        5.  one in-flight assistant message per thread (durable concurrency guard)
        6.  model_pricing table + idempotent seed
        7.  chat_message.version (optimistic lock)
        8.  drop vestigial chat_thread.selected_leaf_message_id
        9.  chat_message_vote.message_id FK ON DELETE CASCADE
        10. chat_message.thread_id / parent_message_id / chat_message_part.message_id ON DELETE CASCADE
        11. metadata status enum CHECK
        12. chat_message.status column (promoted from metadata)
        13. chat_thread.session_jsonl BYTEA (verbatim Pi session for cold-restart)
        14. drop chat_message_part (last — backfill is canonical, table now inert)
        15. drop legacy `document` table (intelligence-service Pi-context store; obsolete after
            the Pi mentor moves context loading into application-server providers)

        The per-workspace `workspace.mentor_enabled` toggle is NOT in this file — it lives in
        its own changelog (`1778760000000_workspace_mentor_enabled.xml`) because it touches the
        `workspace` table, not `chat_message_*`. Single-concern per file.
    -->

    <!-- 1. JSONB column for AI-SDK UIMessage parts. Default '[]' so reads stay non-null
         between schema apply and backfill; chat_message_part itself is dropped in the
         1778800000000 changelog. -->
    <changeSet id="mentor-1071-add-parts-column" author="hephaestus">
        <preConditions onFail="MARK_RAN" onFailMessage="chat_message.parts already exists">
            <not><columnExists tableName="chat_message" columnName="parts"/></not>
        </preConditions>
        <comment>Add chat_message.parts JSONB column for AI SDK UIMessage parts</comment>
        <addColumn tableName="chat_message">
            <column name="parts" type="JSONB" defaultValueComputed="'[]'::jsonb"/>
        </addColumn>
        <rollback>
            <dropColumn tableName="chat_message" columnName="parts"/>
        </rollback>
    </changeSet>

    <!-- 2. Reconstruct parts JSONB from the normalised chat_message_part rows. Idempotent: only
         touches messages whose parts is still '[]' AND that have any chat_message_part row.
         Part shape reconstruction merges the per-row `content` JSONB with a synthetic `type`
         field (original_type wins; else lower(replace(type,'_','-'))). Ordered by order_index. -->
    <changeSet id="mentor-1071-backfill-parts" author="hephaestus">
        <preConditions onFail="MARK_RAN" onFailMessage="chat_message.parts already populated">
            <sqlCheck expectedResult="1">
                SELECT CASE WHEN EXISTS (
                    SELECT 1 FROM chat_message m
                    WHERE (m.parts IS NULL OR m.parts = '[]'::jsonb)
                      AND EXISTS (SELECT 1 FROM chat_message_part p WHERE p.message_id = m.id)
                ) THEN 1 ELSE 0 END
            </sqlCheck>
        </preConditions>
        <comment>Backfill chat_message.parts from chat_message_part rows</comment>
        <sql splitStatements="false">
            UPDATE chat_message m
               SET parts = COALESCE(sub.parts_array, '[]'::jsonb)
              FROM (
                SELECT
                    p.message_id,
                    jsonb_agg(
                        COALESCE(p.content, '{}'::jsonb)
                            || jsonb_build_object(
                                'type',
                                COALESCE(p.original_type, REPLACE(LOWER(p.type), '_', '-'))
                            )
                        ORDER BY p.order_index
                    ) AS parts_array
                  FROM chat_message_part p
                 GROUP BY p.message_id
              ) sub
             WHERE m.id = sub.message_id
               AND (m.parts IS NULL OR m.parts = '[]'::jsonb);
        </sql>
        <rollback>
            <!-- No-op: the parts column drop in changeset 1's rollback restores prior state. -->
        </rollback>
    </changeSet>

    <!-- 3. Lock parts to a valid AI-SDK shape: array, never null. The backfill (changeset 2)
         catches every chat_message_part row; defensive UPDATE here covers any race the
         backfill missed before NOT NULL closes the door. -->
    <changeSet id="mentor-1071-enforce-parts-shape" author="hephaestus">
        <preConditions onFail="MARK_RAN" onFailMessage="chat_message.parts is already NOT NULL">
            <sqlCheck expectedResult="1">
                SELECT CASE WHEN is_nullable = 'YES' THEN 1 ELSE 0 END
                  FROM information_schema.columns
                 WHERE table_schema = current_schema()
                   AND table_name = 'chat_message'
                   AND column_name = 'parts'
            </sqlCheck>
        </preConditions>
        <comment>Enforce chat_message.parts NOT NULL + JSON-array CHECK</comment>
        <sql splitStatements="false">
            UPDATE chat_message SET parts = '[]'::jsonb WHERE parts IS NULL;
            ALTER TABLE chat_message ALTER COLUMN parts SET NOT NULL;
            ALTER TABLE chat_message
                ADD CONSTRAINT chk_chat_message_parts_shape
                CHECK (jsonb_typeof(parts) = 'array');
        </sql>
        <rollback>
            <sql>
                ALTER TABLE chat_message DROP CONSTRAINT IF EXISTS chk_chat_message_parts_shape;
                ALTER TABLE chat_message ALTER COLUMN parts DROP NOT NULL;
            </sql>
        </rollback>
    </changeSet>

    <!-- 4. Constrain metadata to a JSON object (or NULL). MentorChatService writes
         {status, model, costUsd, ...}; junk shapes (scalars, arrays) would break the read path. -->
    <changeSet id="mentor-1071-enforce-metadata-shape" author="hephaestus">
        <preConditions onFail="MARK_RAN" onFailMessage="metadata shape constraint already exists">
            <!-- pg_constraint is the canonical source; information_schema.constraint_column_usage
                 behaviour for CHECK constraints has shifted between Postgres 14/15/16. -->
            <not>
                <sqlCheck expectedResult="1">
                    SELECT CASE WHEN EXISTS (
                        SELECT 1 FROM pg_constraint c
                          JOIN pg_namespace n ON n.oid = c.connamespace
                         WHERE c.conname = 'chk_chat_message_metadata_shape'
                           AND n.nspname = current_schema()
                    ) THEN 1 ELSE 0 END
                </sqlCheck>
            </not>
        </preConditions>
        <comment>Constrain chat_message.metadata to JSON object shape (or NULL)</comment>
        <sql splitStatements="false">
            ALTER TABLE chat_message
                ADD CONSTRAINT chk_chat_message_metadata_shape
                CHECK (metadata IS NULL OR jsonb_typeof(metadata) = 'object');
        </sql>
        <rollback>
            <sql>ALTER TABLE chat_message DROP CONSTRAINT IF EXISTS chk_chat_message_metadata_shape;</sql>
        </rollback>
    </changeSet>

    <!-- 5. At most one in-flight assistant message per thread — durable concurrency guard
         against double-submit races that survive replica boundaries until #1077 lands sticky
         sessions. CREATE INDEX CONCURRENTLY because chat_message is a hot table; mandatory
         runInTransaction="false" since CONCURRENTLY refuses to run in a transaction. -->
    <changeSet id="mentor-1071-in-flight-unique-index" author="hephaestus" runInTransaction="false">
        <preConditions onFail="MARK_RAN" onFailMessage="in-flight unique index already exists">
            <not><indexExists indexName="ux_chat_message_in_flight"/></not>
        </preConditions>
        <comment>One in-flight assistant message per thread (durable concurrency guard)</comment>
        <sql splitStatements="false">
            CREATE UNIQUE INDEX CONCURRENTLY ux_chat_message_in_flight
                ON chat_message (thread_id)
                WHERE (metadata ->> 'status') = 'in_flight';
        </sql>
        <rollback>
            <!-- Mirror the forward path: DROP INDEX CONCURRENTLY so rollback on a hot prod DB
                 doesn't acquire ACCESS EXCLUSIVE behind every reader. The rollback inherits the
                 parent changeSet's runInTransaction="false", per Liquibase 4.x docs. -->
            <sql>DROP INDEX CONCURRENTLY IF EXISTS ux_chat_message_in_flight;</sql>
        </rollback>
    </changeSet>

    <!-- 6. Model pricing lookup + idempotent seed. LiteLLM does NOT return per-request cost
         on streaming (litellm#12689); we multiply Pi `agent_end` token usage by per-1k prices
         stored here. ON CONFLICT DO NOTHING keeps the seed safe if an operator hand-patched a
         row before this changeset ran (e.g. to fix a price typo). -->
    <changeSet id="mentor-1071-model-pricing" author="hephaestus">
        <preConditions onFail="MARK_RAN" onFailMessage="model_pricing table already exists">
            <not><tableExists tableName="model_pricing"/></not>
        </preConditions>
        <comment>Create model_pricing for mentor cost computation + seed common vendor prices</comment>
        <createTable tableName="model_pricing">
            <column name="model_id" type="VARCHAR(128)">
                <constraints primaryKey="true" primaryKeyName="pk_model_pricing"/>
            </column>
            <column name="per_1k_input_usd" type="DECIMAL(12,6)">
                <constraints nullable="false"/>
            </column>
            <column name="per_1k_output_usd" type="DECIMAL(12,6)">
                <constraints nullable="false"/>
            </column>
            <column name="per_1k_cache_read_usd" type="DECIMAL(12,6)" defaultValueNumeric="0"/>
            <column name="per_1k_cache_write_usd" type="DECIMAL(12,6)" defaultValueNumeric="0"/>
            <column name="valid_from" type="TIMESTAMP WITH TIME ZONE" defaultValueComputed="now()">
                <constraints nullable="false"/>
            </column>
            <column name="valid_to" type="TIMESTAMP WITH TIME ZONE"/>
        </createTable>
        <sql splitStatements="false">
            INSERT INTO model_pricing (model_id, per_1k_input_usd, per_1k_output_usd, per_1k_cache_read_usd, per_1k_cache_write_usd)
            VALUES
                ('gpt-4o-mini',       0.000150, 0.000600, 0.000075, 0.000000),
                ('gpt-4o',            0.002500, 0.010000, 0.001250, 0.000000),
                ('claude-3-5-sonnet', 0.003000, 0.015000, 0.000300, 0.003750),
                ('claude-3-5-haiku',  0.000800, 0.004000, 0.000080, 0.001000),
                ('claude-opus-4',     0.015000, 0.075000, 0.001500, 0.018750)
            ON CONFLICT (model_id) DO NOTHING;
        </sql>
        <rollback>
            <dropTable tableName="model_pricing"/>
        </rollback>
    </changeSet>

    <!-- 7. Optimistic-lock column. Replaces the read-before-write `isStillInFlight` TOCTOU
         check on finalise/interrupt with Hibernate's @Version handling: a concurrent reaper
         flip bumps the version, the late writer's stale snapshot fails the version predicate,
         and persistence's caller logs + skips so the reaper's verdict survives. The reaper
         SQL bumps the version explicitly because @Modifying queries bypass Hibernate's
         automatic increment. -->
    <changeSet id="mentor-1071-add-version-column" author="hephaestus">
        <preConditions onFail="MARK_RAN" onFailMessage="chat_message.version already exists">
            <not><columnExists tableName="chat_message" columnName="version"/></not>
        </preConditions>
        <comment>Add chat_message.version BIGINT NOT NULL DEFAULT 0 for Hibernate @Version optimistic locking</comment>
        <addColumn tableName="chat_message">
            <column name="version" type="BIGINT" defaultValueNumeric="0">
                <constraints nullable="false"/>
            </column>
        </addColumn>
        <rollback>
            <dropColumn tableName="chat_message" columnName="version"/>
        </rollback>
    </changeSet>

    <!-- 8. Drop the dead chat_thread.selected_leaf_message_id column. The pre-Pi
         intelligence-service tracked the "currently displayed leaf" in a branching
         conversation tree by storing the leaf id directly. With the intelligence-service
         module removed in this PR the writer is gone; only the reader survived (always null).
         The Pi mentor issue spec (#1071) explicitly says the leaf is "resolved from the tree"
         — computed, not stored. Shipping the column + FK + unique constraint + wire field
         through 4 layers when nobody writes to it is dead weight; the webapp's generated
         client never consumes the field. Drop the column and tighten the wire. Future
         branching support (if ever) computes the leaf from chat_message's tree structure. -->
    <changeSet id="mentor-1071-drop-selected-leaf-message-fk" author="hephaestus">
        <preConditions onFail="MARK_RAN" onFailMessage="FK already dropped">
            <foreignKeyConstraintExists foreignKeyName="FK34beodgwi0g7kn66svlk4hlfr"/>
        </preConditions>
        <comment>Drop FK FK34beodgwi0g7kn66svlk4hlfr (chat_thread.selected_leaf_message_id → chat_message.id)</comment>
        <dropForeignKeyConstraint baseTableName="chat_thread" constraintName="FK34beodgwi0g7kn66svlk4hlfr"/>
        <rollback>
            <addForeignKeyConstraint baseColumnNames="selected_leaf_message_id" baseTableName="chat_thread"
                                     constraintName="FK34beodgwi0g7kn66svlk4hlfr"
                                     referencedColumnNames="id" referencedTableName="chat_message"/>
        </rollback>
    </changeSet>

    <changeSet id="mentor-1071-drop-selected-leaf-message-unique" author="hephaestus">
        <preConditions onFail="MARK_RAN" onFailMessage="Unique constraint already dropped">
            <uniqueConstraintExists tableName="chat_thread" constraintName="UC_CHAT_THREADSELECTED_LEAF_MESSAGE_ID_COL"/>
        </preConditions>
        <comment>Drop unique constraint on chat_thread.selected_leaf_message_id</comment>
        <dropUniqueConstraint tableName="chat_thread"
                              constraintName="UC_CHAT_THREADSELECTED_LEAF_MESSAGE_ID_COL"/>
        <rollback>
            <addUniqueConstraint tableName="chat_thread" columnNames="selected_leaf_message_id"
                                 constraintName="UC_CHAT_THREADSELECTED_LEAF_MESSAGE_ID_COL"/>
        </rollback>
    </changeSet>

    <changeSet id="mentor-1071-drop-selected-leaf-message-column" author="hephaestus">
        <preConditions onFail="MARK_RAN" onFailMessage="Column already dropped">
            <columnExists tableName="chat_thread" columnName="selected_leaf_message_id"/>
        </preConditions>
        <comment>Drop chat_thread.selected_leaf_message_id (vestigial intelligence-service field)</comment>
        <dropColumn tableName="chat_thread" columnName="selected_leaf_message_id"/>
        <rollback>
            <addColumn tableName="chat_thread">
                <column name="selected_leaf_message_id" type="UUID"/>
            </addColumn>
        </rollback>
    </changeSet>

    <!-- 11. Add the missing FK from chat_message_vote → chat_message with ON DELETE CASCADE.
         The original mentor-framework-v2 migration (1754979350893) created the vote table with
         message_id as PRIMARY KEY but NO FK — so deletes against chat_message silently orphaned
         vote rows, and ChatThreadController.deleteThread's "cascades to messages, votes, parts"
         claim was a lie. JPA-side cascade walks the tree per row (N round-trips); a DB-level
         ON DELETE CASCADE is one statement and survives bulk SQL deletes (reaper sweeps, GDPR
         scrubs). Both correctness and performance win. -->
    <changeSet id="mentor-1071-chat-message-vote-fk" author="hephaestus">
        <preConditions onFail="MARK_RAN" onFailMessage="chat_message_vote FK already exists">
            <not><foreignKeyConstraintExists foreignKeyName="fk_chat_message_vote_message"/></not>
        </preConditions>
        <comment>Add FK chat_message_vote.message_id → chat_message.id ON DELETE CASCADE</comment>
        <addForeignKeyConstraint baseColumnNames="message_id" baseTableName="chat_message_vote"
                                 constraintName="fk_chat_message_vote_message"
                                 referencedColumnNames="id" referencedTableName="chat_message"
                                 onDelete="CASCADE"/>
        <rollback>
            <dropForeignKeyConstraint baseTableName="chat_message_vote"
                                      constraintName="fk_chat_message_vote_message"/>
        </rollback>
    </changeSet>

    <!-- 12. Add ON DELETE CASCADE to the three legacy mentor FKs. The pattern was already used
         on fk_chat_thread_workspace (in 1764514002516); the original mentor framework migration
         missed it for thread_id, parent_message_id, and chat_message_part.message_id. Without
         it, any direct-SQL delete against chat_thread or chat_message (reaper sweeps, GDPR
         scrubs, ops scripts) fails with FK violation. Pattern: drop the old FK, re-add with
         ON DELETE CASCADE. Rollback restores the old FK without cascade. -->
    <changeSet id="mentor-1071-cascade-chat-message-thread" author="hephaestus">
        <preConditions onFail="MARK_RAN" onFailMessage="chat_message.thread_id FK already cascades">
            <foreignKeyConstraintExists foreignKeyName="FK8s34d909gxc4xrlvml8gag9kh"/>
        </preConditions>
        <comment>Replace chat_message.thread_id FK with ON DELETE CASCADE variant</comment>
        <dropForeignKeyConstraint baseTableName="chat_message" constraintName="FK8s34d909gxc4xrlvml8gag9kh"/>
        <addForeignKeyConstraint baseColumnNames="thread_id" baseTableName="chat_message"
                                 constraintName="FK8s34d909gxc4xrlvml8gag9kh"
                                 referencedColumnNames="id" referencedTableName="chat_thread"
                                 onDelete="CASCADE"/>
        <rollback>
            <dropForeignKeyConstraint baseTableName="chat_message" constraintName="FK8s34d909gxc4xrlvml8gag9kh"/>
            <addForeignKeyConstraint baseColumnNames="thread_id" baseTableName="chat_message"
                                     constraintName="FK8s34d909gxc4xrlvml8gag9kh"
                                     referencedColumnNames="id" referencedTableName="chat_thread"/>
        </rollback>
    </changeSet>

    <changeSet id="mentor-1071-cascade-chat-message-parent" author="hephaestus">
        <preConditions onFail="MARK_RAN" onFailMessage="chat_message.parent_message_id FK already cascades">
            <foreignKeyConstraintExists foreignKeyName="FKd0fewjs0l68rq2bww9h8o4cmb"/>
        </preConditions>
        <comment>Replace chat_message.parent_message_id self-FK with ON DELETE CASCADE variant</comment>
        <dropForeignKeyConstraint baseTableName="chat_message" constraintName="FKd0fewjs0l68rq2bww9h8o4cmb"/>
        <addForeignKeyConstraint baseColumnNames="parent_message_id" baseTableName="chat_message"
                                 constraintName="FKd0fewjs0l68rq2bww9h8o4cmb"
                                 referencedColumnNames="id" referencedTableName="chat_message"
                                 onDelete="CASCADE"/>
        <rollback>
            <dropForeignKeyConstraint baseTableName="chat_message" constraintName="FKd0fewjs0l68rq2bww9h8o4cmb"/>
            <addForeignKeyConstraint baseColumnNames="parent_message_id" baseTableName="chat_message"
                                     constraintName="FKd0fewjs0l68rq2bww9h8o4cmb"
                                     referencedColumnNames="id" referencedTableName="chat_message"/>
        </rollback>
    </changeSet>

    <changeSet id="mentor-1071-cascade-chat-message-part-message" author="hephaestus">
        <preConditions onFail="MARK_RAN" onFailMessage="chat_message_part.message_id FK already cascades">
            <foreignKeyConstraintExists foreignKeyName="FKkfle3niou3f9r63mc3u8vi1na"/>
        </preConditions>
        <comment>Replace chat_message_part.message_id FK with ON DELETE CASCADE variant</comment>
        <dropForeignKeyConstraint baseTableName="chat_message_part" constraintName="FKkfle3niou3f9r63mc3u8vi1na"/>
        <addForeignKeyConstraint baseColumnNames="message_id" baseTableName="chat_message_part"
                                 constraintName="FKkfle3niou3f9r63mc3u8vi1na"
                                 referencedColumnNames="id" referencedTableName="chat_message"
                                 onDelete="CASCADE"/>
        <rollback>
            <dropForeignKeyConstraint baseTableName="chat_message_part" constraintName="FKkfle3niou3f9r63mc3u8vi1na"/>
            <addForeignKeyConstraint baseColumnNames="message_id" baseTableName="chat_message_part"
                                     constraintName="FKkfle3niou3f9r63mc3u8vi1na"
                                     referencedColumnNames="id" referencedTableName="chat_message"/>
        </rollback>
    </changeSet>

    <!-- 13. Tighten the metadata CHECK to enforce the status enum. The earlier shape constraint
         (changeSet 4 above) only pinned object-or-null; a future writer that forgets `status`
         or typos it (`"in_flite"`) wouldn't be caught at write-time, and the partial unique
         index + reaper SQL silently disagree on what's in-flight. -->
    <changeSet id="mentor-1071-tighten-metadata-status-check" author="hephaestus">
        <preConditions onFail="MARK_RAN" onFailMessage="metadata status enum check already applied">
            <sqlCheck expectedResult="t">
                SELECT NOT EXISTS (
                    SELECT 1 FROM information_schema.check_constraints
                    WHERE constraint_schema = current_schema()
                      AND constraint_name = 'chk_chat_message_metadata_status'
                )
            </sqlCheck>
        </preConditions>
        <comment>Tighten metadata CHECK: if status key is present it must be one of (in_flight, completed, interrupted)</comment>
        <!-- jsonb_exists(metadata, 'status') instead of the `?` operator: Liquibase's SQL
             pre-processor parses `?` as a JDBC placeholder and fails with "syntax error at
             or near '$1'". jsonb_exists is the function-form equivalent that survives
             unmodified through the JDBC layer. -->
        <sql>
            ALTER TABLE chat_message ADD CONSTRAINT chk_chat_message_metadata_status
            CHECK (
                metadata IS NULL
                OR NOT jsonb_exists(metadata, 'status')
                OR (metadata->>'status') IN ('in_flight', 'completed', 'interrupted')
            );
        </sql>
        <rollback>
            <sql>ALTER TABLE chat_message DROP CONSTRAINT IF EXISTS chk_chat_message_metadata_status;</sql>
        </rollback>
    </changeSet>

    <!-- 14. Promote `metadata.status` JSONB sub-key to a real `chat_message.status` column.
         Status is the only correctness-critical metadata field (drives the partial unique
         index + the reaper's stuck-row sweep); the JSONB encoding made every read pay a
         function-call cost and the partial index opaque to query planners. Other metadata
         fields (cost, usage, model) are billing/observability and stay in the JSONB bag.

         Strategy (zero-downtime):
           a. Add nullable column + idempotent backfill from existing JSONB rows.
           b. Promote NOT NULL + enum CHECK once backfill completes.
           c. Recreate the partial unique index against the new column (CONCURRENTLY).
           d. Drop the metadata-status CHECK + the legacy (metadata->>'status')-keyed index. -->
    <changeSet id="mentor-1071-add-status-column" author="hephaestus">
        <preConditions onFail="MARK_RAN" onFailMessage="status column already exists">
            <not><columnExists tableName="chat_message" columnName="status"/></not>
        </preConditions>
        <comment>Add nullable status column (backfilled in the next changeset)</comment>
        <sql>
            ALTER TABLE chat_message ADD COLUMN status VARCHAR(16) NULL;
        </sql>
        <rollback>
            <sql>ALTER TABLE chat_message DROP COLUMN IF EXISTS status;</sql>
        </rollback>
    </changeSet>

    <changeSet id="mentor-1071-backfill-status" author="hephaestus">
        <comment>Backfill chat_message.status from metadata.status; idempotent.</comment>
        <sql>
            UPDATE chat_message
               SET status = metadata->>'status'
             WHERE status IS NULL
               AND metadata IS NOT NULL
               AND (metadata->>'status') IN ('in_flight', 'completed', 'interrupted');
            -- User rows never had a status in metadata; default them to 'completed' (immutable
            -- once written, never in_flight).
            UPDATE chat_message
               SET status = 'completed'
             WHERE status IS NULL
               AND role = 'USER';
            -- Any remaining null assistant rows are pre-status-tracking; treat as completed so
            -- the NOT NULL promotion below succeeds without manual intervention.
            UPDATE chat_message
               SET status = 'completed'
             WHERE status IS NULL;
        </sql>
        <rollback>
            <comment>No-op: backfill is data movement; rollback drops the column.</comment>
            <empty/>
        </rollback>
    </changeSet>

    <changeSet id="mentor-1071-status-not-null-and-check" author="hephaestus">
        <preConditions onFail="MARK_RAN" onFailMessage="status NOT NULL + check already applied">
            <sqlCheck expectedResult="t">
                SELECT NOT EXISTS (SELECT 1 FROM information_schema.constraint_column_usage
                                   WHERE table_schema = current_schema()
                                     AND table_name = 'chat_message'
                                     AND constraint_name = 'chk_chat_message_status')
            </sqlCheck>
        </preConditions>
        <comment>Enforce NOT NULL + enum CHECK on the status column.</comment>
        <sql>
            ALTER TABLE chat_message
                ALTER COLUMN status SET NOT NULL,
                ADD CONSTRAINT chk_chat_message_status
                    CHECK (status IN ('in_flight', 'completed', 'interrupted'));
        </sql>
        <rollback>
            <sql>
                ALTER TABLE chat_message
                    DROP CONSTRAINT IF EXISTS chk_chat_message_status,
                    ALTER COLUMN status DROP NOT NULL;
            </sql>
        </rollback>
    </changeSet>

    <changeSet id="mentor-1071-replace-in-flight-index" author="hephaestus" runInTransaction="false">
        <preConditions onFail="MARK_RAN" onFailMessage="new in-flight index already exists">
            <not><indexExists indexName="ux_chat_message_in_flight_v2"/></not>
        </preConditions>
        <comment>Create column-keyed partial unique index; drop legacy JSONB-keyed one.</comment>
        <sql>
            CREATE UNIQUE INDEX CONCURRENTLY IF NOT EXISTS ux_chat_message_in_flight_v2
                ON chat_message (thread_id)
             WHERE status = 'in_flight';
            DROP INDEX CONCURRENTLY IF EXISTS ux_chat_message_in_flight;
        </sql>
        <rollback>
            <sql>
                CREATE UNIQUE INDEX CONCURRENTLY IF NOT EXISTS ux_chat_message_in_flight
                    ON chat_message (thread_id)
                 WHERE (metadata ->> 'status') = 'in_flight';
                DROP INDEX CONCURRENTLY IF EXISTS ux_chat_message_in_flight_v2;
            </sql>
        </rollback>
    </changeSet>

    <changeSet id="mentor-1071-drop-metadata-status-check" author="hephaestus">
        <comment>chk_chat_message_metadata_status is now redundant: status lives in its own
            column with its own CHECK. Drop it so writers don't need to mirror it in JSONB.
            The metadata bag itself stays (cost, usage, model, finishReason, durationMs).</comment>
        <sql>
            ALTER TABLE chat_message DROP CONSTRAINT IF EXISTS chk_chat_message_metadata_status;
        </sql>
        <rollback>
            <sql>
                ALTER TABLE chat_message ADD CONSTRAINT chk_chat_message_metadata_status
                CHECK (
                    metadata IS NULL
                    OR NOT jsonb_exists(metadata, 'status')
                    OR (metadata->>'status') IN ('in_flight', 'completed', 'interrupted')
                );
            </sql>
        </rollback>
    </changeSet>

    <!-- Verbatim Pi SDK session JSONL bytes for byte-identical cold-restart. -->
    <changeSet id="mentor-1071-add-session-jsonl-blob" author="hephaestus">
        <preConditions onFail="MARK_RAN" onFailMessage="session_jsonl column already exists">
            <not><columnExists tableName="chat_thread" columnName="session_jsonl"/></not>
        </preConditions>
        <comment>Add chat_thread.session_jsonl BYTEA for Pi prompt-cache continuity across cold restarts</comment>
        <sql>ALTER TABLE chat_thread ADD COLUMN session_jsonl BYTEA NULL;</sql>
        <rollback>
            <sql>ALTER TABLE chat_thread DROP COLUMN IF EXISTS session_jsonl;</sql>
        </rollback>
    </changeSet>

    <!-- Final step: drop chat_message_part. Backfill (changeSet 2) already denormalised every
         row into chat_message.parts JSONB; intelligence-service (the only writer) is deleted
         in this same PR. HALT precondition refuses to drop if any row survives. MUST be the
         last chat_message_part-touching changeset in this file — runs AFTER the cascade-FK
         migration above. -->
    <changeSet id="mentor-1071-drop-chat-message-part" author="hephaestus">
        <preConditions onFail="MARK_RAN" onFailMessage="chat_message_part already dropped">
            <tableExists tableName="chat_message_part"/>
        </preConditions>
        <comment>Drop legacy chat_message_part table (replaced by chat_message.parts JSONB)</comment>
        <!-- Inline HALT-on-non-empty guard. A single <preConditions> block can't express
             "skip if table gone" AND "halt if non-empty" cleanly; embedding the row-count
             check in PL/pgSQL keeps the safety net intact. splitStatements=false because
             Liquibase's default splitter doesn't understand $$ blocks. -->
        <sql splitStatements="false">
            DO $$
            DECLARE remaining BIGINT;
            BEGIN
                SELECT COUNT(*) INTO remaining FROM chat_message_part;
                IF remaining &gt; 0 THEN
                    RAISE EXCEPTION 'chat_message_part has % rows — backfill incomplete or post-deploy writes occurred', remaining;
                END IF;
            END $$;
        </sql>
        <dropTable tableName="chat_message_part"/>
        <rollback>
            <createTable tableName="chat_message_part">
                <column name="message_id" type="UUID">
                    <constraints nullable="false" primaryKey="true" primaryKeyName="chat_message_partPK"/>
                </column>
                <column name="order_index" type="INTEGER">
                    <constraints nullable="false" primaryKey="true" primaryKeyName="chat_message_partPK"/>
                </column>
                <column name="content" type="JSONB"/>
                <column name="original_type" type="VARCHAR(64)"/>
                <column name="type" type="VARCHAR(32)">
                    <constraints nullable="false"/>
                </column>
            </createTable>
            <addForeignKeyConstraint
                baseTableName="chat_message_part"
                baseColumnNames="message_id"
                constraintName="fk_chat_message_part_message"
                referencedTableName="chat_message"
                referencedColumnNames="id"
                onDelete="CASCADE"/>
        </rollback>
    </changeSet>

    <!-- 15. Drop the legacy `document` table. Created by the intelligence-service mentor
         framework (changelog 1754979350893) to persist Pi-context fragments. Obsolete now
         that intelligence-service is deleted and the Pi mentor loads context through the
         JPA-side providers in `agent/context/providers/mentor/`. The FK on `user_id` and the
         indices die with the table; precondition keeps the changeset idempotent in case it
         was already dropped by a hand-run cleanup on staging. -->
    <changeSet id="mentor-1071-drop-document" author="hephaestus">
        <preConditions onFail="MARK_RAN" onFailMessage="document table already dropped">
            <tableExists tableName="document"/>
        </preConditions>
        <comment>Drop legacy intelligence-service `document` table (FKs and indices cascade)</comment>
        <dropTable tableName="document" cascadeConstraints="true"/>
        <rollback>
            <createTable tableName="document">
                <column name="id" type="UUID">
                    <constraints nullable="false" primaryKey="true" primaryKeyName="documentPK"/>
                </column>
                <column name="version_number" type="INTEGER">
                    <constraints nullable="false" primaryKey="true" primaryKeyName="documentPK"/>
                </column>
                <column name="content" type="TEXT"/>
                <column name="created_at" type="TIMESTAMP(6) WITH TIME ZONE">
                    <constraints nullable="false"/>
                </column>
                <column name="kind" type="VARCHAR(255)">
                    <constraints nullable="false"/>
                </column>
                <column name="title" type="VARCHAR(255)">
                    <constraints nullable="false"/>
                </column>
                <column name="user_id" type="BIGINT">
                    <constraints nullable="false"/>
                </column>
                <column name="workspace_id" type="BIGINT">
                    <constraints nullable="false"/>
                </column>
            </createTable>
        </rollback>
    </changeSet>


</databaseChangeLog>
