<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-3.8.xsd">

    <!-- ==================== Add slug column to team for GitLab subgroup support ==================== -->
    <!--
    The team entity needs a slug column to distinguish between display name and unique identifier.
    For GitHub: slug = team slug (e.g., "backend-core")
    For GitLab: slug = relative path from root group (e.g., "group1/alpha")
    The unique constraint moves from (provider_id, organization, name) to (provider_id, organization, slug).
    -->

    <!-- Step 1: Add nullable slug column -->
    <changeSet author="gitlab-team-support" id="1773100000000-1">
        <addColumn tableName="team">
            <column name="slug" type="VARCHAR(512)"/>
        </addColumn>
    </changeSet>

    <!-- Step 2: Backfill slug = name for existing teams (GitHub teams where name ≈ slug) -->
    <changeSet author="gitlab-team-support" id="1773100000000-2">
        <sql>
            UPDATE team SET slug = name WHERE slug IS NULL;
        </sql>
    </changeSet>

    <!-- Step 3: Make slug NOT NULL -->
    <changeSet author="gitlab-team-support" id="1773100000000-3">
        <addNotNullConstraint tableName="team" columnName="slug" columnDataType="VARCHAR(512)"/>
    </changeSet>

    <!-- Step 4: Drop old unique constraint on (provider_id, organization, name) -->
    <changeSet author="gitlab-team-support" id="1773100000000-4">
        <preConditions onFail="MARK_RAN">
            <indexExists indexName="uk_team_provider_organization_name"/>
        </preConditions>
        <dropUniqueConstraint tableName="team" constraintName="uk_team_provider_organization_name"/>
    </changeSet>

    <!-- Step 5: Add new unique constraint on (provider_id, organization, slug) -->
    <changeSet author="gitlab-team-support" id="1773100000000-5">
        <addUniqueConstraint tableName="team" columnNames="provider_id, organization, slug"
                             constraintName="uk_team_provider_organization_slug"/>
    </changeSet>

</databaseChangeLog>
