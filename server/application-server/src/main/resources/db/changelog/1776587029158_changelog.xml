<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        https://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <!--
        PR #1021 — consolidated migration for the gitlab-sync + profile-review
        hardening work. Folds four per-feature changelogs
        (1776300000000, 1776400000000, 1776500000000, 1776600000000)
        into a single precisely-timestamped changelog so the branch ships one
        migration in total.
    -->

    <!-- Gap 4a.1 — backfill git_commit.author_id via direct email match (provider-scoped). -->
    <changeSet id="1776587029158-1" author="hephaestus">
        <sql>
            UPDATE git_commit c
            SET author_id = u.id
            FROM repository r, "user" u
            WHERE c.author_id IS NULL
              AND c.author_email IS NOT NULL
              AND c.repository_id = r.id
              AND u.provider_id = r.provider_id
              AND LOWER(u.email) = LOWER(c.author_email);
        </sql>
    </changeSet>

    <!-- Gap 4a.2 — backfill git_commit.committer_id via direct email match (provider-scoped). -->
    <changeSet id="1776587029158-2" author="hephaestus">
        <sql>
            UPDATE git_commit c
            SET committer_id = u.id
            FROM repository r, "user" u
            WHERE c.committer_id IS NULL
              AND c.committer_email IS NOT NULL
              AND c.repository_id = r.id
              AND u.provider_id = r.provider_id
              AND LOWER(u.email) = LOWER(c.committer_email);
        </sql>
    </changeSet>

    <!--
        Gap 4a.3 — backfill git_commit.author_id via email local-part as login
        (TUM/LRZ convention, e.g. ge27coy@mytum.de -> login ge27coy). Only applies
        when the local-part is a single login-shaped token (no dot, no plus) and
        the email is NOT a GitLab bot noreply. Provider-scoped.
    -->
    <changeSet id="1776587029158-3" author="hephaestus">
        <sql>
            UPDATE git_commit c
            SET author_id = u.id
            FROM repository r, "user" u
            WHERE c.author_id IS NULL
              AND c.author_email IS NOT NULL
              AND c.repository_id = r.id
              AND u.provider_id = r.provider_id
              AND split_part(c.author_email, '@', 1) ~ '^[A-Za-z0-9_-]+$'
              AND c.author_email !~* '^(group|project)_[0-9]+_bot[_a-z0-9-]*@noreply\..+$'
              AND LOWER(u.login) = LOWER(split_part(c.author_email, '@', 1));
        </sql>
    </changeSet>

    <!-- Gap 4a.4 — backfill git_commit.committer_id via email local-part as login (provider-scoped). -->
    <changeSet id="1776587029158-4" author="hephaestus">
        <sql>
            UPDATE git_commit c
            SET committer_id = u.id
            FROM repository r, "user" u
            WHERE c.committer_id IS NULL
              AND c.committer_email IS NOT NULL
              AND c.repository_id = r.id
              AND u.provider_id = r.provider_id
              AND split_part(c.committer_email, '@', 1) ~ '^[A-Za-z0-9_-]+$'
              AND c.committer_email !~* '^(group|project)_[0-9]+_bot[_a-z0-9-]*@noreply\..+$'
              AND LOWER(u.login) = LOWER(split_part(c.committer_email, '@', 1));
        </sql>
    </changeSet>

    <!--
        Gap 1 — restore issue.merge_commit_sha so GitLab sync can persist
        MergeRequest.mergeCommitSha. GitHub webhooks omit it; GitLab GraphQL
        supplies it consistently and we use it as the anchor for the fallback
        commit-MR linker (addresses 17.6% commit_pull_request coverage from
        41% NULL merge_commit_sha on merged MRs).
    -->
    <changeSet id="1776587029158-5" author="hephaestus">
        <preConditions onFail="MARK_RAN">
            <not>
                <columnExists tableName="issue" columnName="merge_commit_sha"/>
            </not>
        </preConditions>
        <addColumn tableName="issue">
            <column name="merge_commit_sha" type="VARCHAR(40)"/>
        </addColumn>
    </changeSet>

    <!--
        Gap 2 — anchor GitLab review threads on their diffRefs headSha / baseSha.
        Without commit_sha / original_commit_sha, inline-feedback scoring and the
        agent diff-note poster have no commit anchor. GitHub-source rows remain
        backward-compatible (NULL until the GitHub sync is extended).
    -->
    <changeSet id="1776587029158-6" author="hephaestus">
        <preConditions onFail="MARK_RAN">
            <not>
                <columnExists tableName="pull_request_review_thread" columnName="commit_sha"/>
            </not>
        </preConditions>
        <addColumn tableName="pull_request_review_thread">
            <column name="commit_sha" type="VARCHAR(64)"/>
            <column name="original_commit_sha" type="VARCHAR(64)"/>
        </addColumn>
    </changeSet>

    <!--
        Gap 4b — German DIN 5007-2 name folding as a first-class SQL function.
        GitLab commit emails carry DIN 5007-2 transliterations of umlauts in the
        local-part (jannis.hoeferlin@tum.de) while User.name stores the original
        UTF-8 form (Jannis Höferlin). Off-the-shelf accent folding (unaccent,
        ICU und-u-ks-level1) strips diacritics (ö->o); we need expansion (ö->oe).
        Centralised as an IMMUTABLE SQL function and backed by a functional index.
        Hibernate calls it via a registered FunctionContributor.
    -->
    <changeSet id="1776587029158-7" author="hephaestus" runOnChange="true">
        <sql splitStatements="false" endDelimiter=";">
            CREATE OR REPLACE FUNCTION de_fold_name(input text)
            RETURNS text
            LANGUAGE sql
            IMMUTABLE
            STRICT
            PARALLEL SAFE
            AS $$
                SELECT REPLACE(
                           REPLACE(
                               REPLACE(
                                   REPLACE(LOWER(input), 'ö', 'oe'),
                                   'ä', 'ae'
                               ),
                               'ü', 'ue'
                           ),
                           'ß', 'ss'
                       )
            $$;
        </sql>
    </changeSet>

    <changeSet id="1776587029158-8" author="hephaestus">
        <preConditions onFail="MARK_RAN">
            <not>
                <indexExists indexName="idx_user_de_fold_name"/>
            </not>
        </preConditions>
        <sql splitStatements="false">
            CREATE INDEX idx_user_de_fold_name ON "user" (de_fold_name(name))
            WHERE type = 'USER'
        </sql>
        <rollback>
            <sql>DROP INDEX IF EXISTS idx_user_de_fold_name</sql>
        </rollback>
    </changeSet>

</databaseChangeLog>
