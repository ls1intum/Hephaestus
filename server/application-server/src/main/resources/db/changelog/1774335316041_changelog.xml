<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-3.8.xsd">

    <!-- ==================== Finding feedback table ==================== -->
    <!--
    Append-only feedback from contributors on AI-generated practice findings.
    Supports three actions: APPLIED, DISPUTED, NOT_APPLICABLE.
    No UNIQUE constraint on (finding_id, contributor_id) — multiple feedback
    events per finding are valid (contributor changes mind over time).
    The latest row per (finding_id, contributor_id) is the "current" state.
    -->

    <!-- Step 1: Create finding_feedback table -->
    <changeSet author="finding-feedback" id="1774335316041-1">
        <createTable tableName="finding_feedback">
            <column name="id" type="UUID">
                <constraints nullable="false" primaryKey="true" primaryKeyName="finding_feedback_pkey"/>
            </column>
            <column name="finding_id" type="UUID">
                <constraints nullable="false"/>
            </column>
            <column name="contributor_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="action" type="VARCHAR(16)">
                <constraints nullable="false"/>
            </column>
            <column name="explanation" type="TEXT"/>
            <column name="created_at" type="TIMESTAMP(6) WITH TIME ZONE">
                <constraints nullable="false"/>
            </column>
        </createTable>
    </changeSet>

    <!-- Step 2: FK finding_id → practice_finding(id) ON DELETE CASCADE -->
    <changeSet author="finding-feedback" id="1774335316041-2">
        <addForeignKeyConstraint baseColumnNames="finding_id" baseTableName="finding_feedback"
            constraintName="fk_finding_feedback_finding" referencedColumnNames="id"
            referencedTableName="practice_finding" onDelete="CASCADE" validate="true"/>
    </changeSet>

    <!-- Step 3: FK contributor_id → user(id) (RESTRICT — no cascade) -->
    <changeSet author="finding-feedback" id="1774335316041-3">
        <addForeignKeyConstraint baseColumnNames="contributor_id" baseTableName="finding_feedback"
            constraintName="fk_finding_feedback_contributor" referencedColumnNames="id"
            referencedTableName="user" validate="true"/>
    </changeSet>

    <!-- Step 4: CHECK constraint on action values -->
    <changeSet author="finding-feedback" id="1774335316041-4">
        <sql>
            ALTER TABLE finding_feedback
            ADD CONSTRAINT chk_finding_feedback_action
            CHECK (action IN ('APPLIED', 'DISPUTED', 'NOT_APPLICABLE'));
        </sql>
        <rollback>
            ALTER TABLE finding_feedback DROP CONSTRAINT IF EXISTS chk_finding_feedback_action;
        </rollback>
    </changeSet>

    <!-- Step 5: CHECK constraint: DISPUTED requires non-empty explanation -->
    <changeSet author="finding-feedback" id="1774335316041-5">
        <sql>
            ALTER TABLE finding_feedback
            ADD CONSTRAINT chk_finding_feedback_disputed_explanation
            CHECK (action != 'DISPUTED' OR (explanation IS NOT NULL AND length(trim(explanation)) > 0));
        </sql>
        <rollback>
            ALTER TABLE finding_feedback DROP CONSTRAINT IF EXISTS chk_finding_feedback_disputed_explanation;
        </rollback>
    </changeSet>

    <!-- Step 6: Index on (contributor_id, created_at DESC) for engagement queries -->
    <changeSet author="finding-feedback" id="1774335316041-6">
        <sql>
            CREATE INDEX idx_finding_feedback_contributor_created
            ON finding_feedback (contributor_id, created_at DESC);
        </sql>
        <rollback>
            DROP INDEX IF EXISTS idx_finding_feedback_contributor_created;
        </rollback>
    </changeSet>

    <!-- Step 7: Composite index for DISTINCT ON performance -->
    <changeSet author="finding-feedback" id="1774335316041-7">
        <sql>
            CREATE INDEX idx_finding_feedback_finding_contributor
            ON finding_feedback (finding_id, contributor_id, created_at DESC);
        </sql>
        <rollback>
            DROP INDEX IF EXISTS idx_finding_feedback_finding_contributor;
        </rollback>
    </changeSet>

</databaseChangeLog>
