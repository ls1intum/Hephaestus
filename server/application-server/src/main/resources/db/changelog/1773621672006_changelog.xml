<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-3.8.xsd">

    <!-- Add credential_mode column to agent_config for proxy/direct auth support -->
    <changeSet author="agent-adapters" id="1773621672006-1">
        <addColumn tableName="agent_config">
            <column name="credential_mode" type="VARCHAR(16)" defaultValue="PROXY">
                <constraints nullable="false"/>
            </column>
        </addColumn>
    </changeSet>

</databaseChangeLog>
