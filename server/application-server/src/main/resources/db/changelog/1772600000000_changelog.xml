<?xml version="1.1" encoding="UTF-8" standalone="no"?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
                   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                   http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <!-- ========================================================================
         GitLab Webhook Auto-Registration (Issue #721)
         ========================================================================

         Adds columns to workspace table for storing GitLab group-level webhook
         registration state. These enable automatic webhook lifecycle management:
         - Registration during workspace activation
         - Deregistration during workspace purge

         gitlab_group_id  – Stable numeric group ID (survives group renames).
                            Used for REST API calls: POST/DELETE /groups/:id/hooks
         gitlab_webhook_id – Webhook ID returned by GitLab on successful registration.
                             Used for deregistration and idempotency checks.
    -->

    <changeSet id="1772600000000-1" author="hephaestus">
        <addColumn tableName="workspace">
            <column name="gitlab_group_id" type="BIGINT">
                <constraints nullable="true"/>
            </column>
            <column name="gitlab_webhook_id" type="BIGINT">
                <constraints nullable="true"/>
            </column>
        </addColumn>
    </changeSet>

</databaseChangeLog>
