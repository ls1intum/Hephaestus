<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        https://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <!--
        PiMentorAgent #1071: denormalise chat_message_part rows into a JSONB array column on
        chat_message. The runner writes AI SDK UIMessage parts directly; reads stay backward-
        compatible until #1074 drops chat_message_part.
    -->
    <changeSet id="1779000000001-1" author="hephaestus">
        <preConditions onFail="MARK_RAN" onFailMessage="chat_message.parts already exists">
            <not><columnExists tableName="chat_message" columnName="parts"/></not>
        </preConditions>
        <comment>Add chat_message.parts JSONB column for AI SDK UIMessage parts (denormalised)</comment>
        <addColumn tableName="chat_message">
            <column name="parts" type="JSONB" defaultValueComputed="'[]'::jsonb"/>
        </addColumn>
        <rollback>
            <dropColumn tableName="chat_message" columnName="parts"/>
        </rollback>
    </changeSet>

</databaseChangeLog>
