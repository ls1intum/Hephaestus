<?xml version="1.1" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <!-- ==================== Workspace feature flags ==================== -->
    <!--
    Add 4 workspace-scoped boolean feature flags to control which features
    are enabled per workspace. All default to FALSE for new workspaces;
    admins enable features manually via the admin UI.

    Data migration backfills existing non-GitLab workspaces with
    leaderboard_enabled=true and achievements_enabled=true to preserve
    current behavior on deploy.
    -->

    <!-- Add all 4 feature flag columns in a single atomic changeset -->
    <changeSet author="workspace-features" id="1774472313956-1">
        <addColumn tableName="workspace">
            <column name="practices_enabled" type="BOOLEAN" defaultValueBoolean="false">
                <constraints nullable="false"/>
            </column>
            <column name="achievements_enabled" type="BOOLEAN" defaultValueBoolean="false">
                <constraints nullable="false"/>
            </column>
            <column name="leaderboard_enabled" type="BOOLEAN" defaultValueBoolean="false">
                <constraints nullable="false"/>
            </column>
            <column name="progression_enabled" type="BOOLEAN" defaultValueBoolean="false">
                <constraints nullable="false"/>
            </column>
        </addColumn>
    </changeSet>

    <!--
    Backfill existing non-GitLab workspaces to preserve current behavior.
    Uses positive match on known GitHub modes; NULL git_provider_mode also
    gets backfilled (pre-mode workspaces are GitHub).
    Rollback is a no-op: rolling back changeset -1 drops the columns entirely.
    -->
    <changeSet author="workspace-features" id="1774472313956-2">
        <sql>
            UPDATE workspace
            SET leaderboard_enabled = true, achievements_enabled = true
            WHERE git_provider_mode IS NULL
               OR git_provider_mode IN ('PAT_ORG', 'GITHUB_APP_INSTALLATION');
        </sql>
        <rollback>
            <!-- No-op: columns are dropped by rolling back changeset -1 -->
        </rollback>
    </changeSet>

</databaseChangeLog>
