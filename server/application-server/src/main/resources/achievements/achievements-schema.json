{
	"$schema": "http://json-schema.org/draft-07/schema#",
	"title": "Achievements Configuration",
	"type": "object",
	"properties": {
		"achievements": {
			"type": "array",
			"items": {
				"$ref": "#/definitions/achievement"
			}
		}
	},
	"required": ["achievements"],
	"definitions": {
		"achievement": {
			"type": "object",
			"properties": {
				"id": {
					"type": "string",
					"description": "Unique identifier for the achievement"
				},
				"parent": {
					"type": "string",
					"description": "ID of the previous achievement in the progression chain"
				},
				"rarity": {
					"description": "Visual rarity for UI styling",
					"enum": ["common", "uncommon", "rare", "epic", "legendary", "mythic"]
				},
				"isHidden": {
					"type": "boolean",
					"description": "If true, achievement is hidden until unlocked"
				},
				"category": {
					"description": "Grouping category for UI and logic",
					"enum": ["pull_requests", "commits", "communication", "issues", "milestones"]
				},
				"triggerEvents": {
					"type": "array",
					"items": {
						"enum": [
							"PULL_REQUEST_OPENED",
							"PULL_REQUEST_MERGED",
							"PULL_REQUEST_CLOSED",
							"PULL_REQUEST_REOPENED",
							"PULL_REQUEST_READY",
							"PULL_REQUEST_DRAFTED",
							"PULL_REQUEST_SYNCHRONIZED",
							"PULL_REQUEST_LABELED",
							"PULL_REQUEST_UNLABELED",
							"COMMIT_CREATED",
							"REVIEW_APPROVED",
							"REVIEW_CHANGES_REQUESTED",
							"REVIEW_COMMENTED",
							"REVIEW_UNKNOWN",
							"REVIEW_DISMISSED",
							"REVIEW_EDITED",
							"COMMENT_CREATED",
							"COMMENT_UPDATED",
							"COMMENT_DELETED",
							"REVIEW_COMMENT_CREATED",
							"REVIEW_COMMENT_EDITED",
							"REVIEW_COMMENT_DELETED",
							"REVIEW_THREAD_RESOLVED",
							"REVIEW_THREAD_UNRESOLVED",
							"ISSUE_CREATED",
							"ISSUE_CLOSED",
							"ISSUE_REOPENED",
							"ISSUE_DELETED",
							"ISSUE_LABELED",
							"ISSUE_UNLABELED",
							"ISSUE_TYPED",
							"ISSUE_UNTYPED"
						]
					}
				},
				"evaluatorClass": {
					"type": "string",
					"description": "Implementation class for the evaluator. Can be a fully qualified class name or a short name (assumed to be in de.tum.in.www1.hephaestus.achievement.evaluator).",
					"enum": [
						"StandardCountEvaluator",
						"ReviewCountEvaluator",
						"DummyEvaluator",
						"de.tum.in.www1.hephaestus.achievement.evaluator.StandardCountEvaluator",
						"de.tum.in.www1.hephaestus.achievement.evaluator.ReviewCountEvaluator",
						"de.tum.in.www1.hephaestus.achievement.evaluator.DummyEvaluator"
					]
				},
				"requirements": {
					"type": "object",
					"properties": {
						"type": {
							"enum": ["LinearAchievementProgress", "BinaryAchievementProgress"]
						},
						"target": {
							"type": "integer",
							"minimum": 0,
							"description": "Target count for LinearAchievementProgress"
						},
						"current": {
							"type": "integer",
							"minimum": 0,
							"description": "Current count (usually 0 in config)"
						},
						"unlocked": {
							"type": "boolean",
							"description": "Unlock state (usually false in config)"
						}
					},
					"required": ["type"]
				}
			},
			"required": ["id", "rarity", "isHidden", "category", "evaluatorClass", "requirements"]
		}
	}
}
