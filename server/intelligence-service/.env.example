NODE_ENV=development
PORT=8000
LOG_LEVEL=debug
DATABASE_URL=postgresql://root:root@localhost:${POSTGRES_PORT:-5432}/hephaestus

# Verbose logging - logs full request/response bodies to file (for debugging)
# WARNING: This can log sensitive data. Use only for debugging.
VERBOSE_LOGGING=false
VERBOSE_LOG_FILE=logs/verbose.log

MODEL_NAME="openai:gpt-4o-mini"

# For Non-Azure OpenAI
OPENAI_API_KEY=<openai-api-key>

# For Azure OpenAI
AZURE_RESOURCE_NAME=<resource-name>
AZURE_API_KEY=<azure-api-key>
