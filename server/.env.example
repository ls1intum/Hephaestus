# Copy this file to .env and fill in the secrets before starting the stack locally or in production.
#
# IMPORTANT: After copying, run `docker compose down -v` to clear any stale local state,
# then `docker compose up` to apply your new configuration.

# =============================================================================
# PORT OVERRIDES (optional)
# =============================================================================
# Override host-side ports to avoid collisions with other services on your machine.
# Internal container ports remain unchanged; only the localhost binding moves.
#
# Default port assignments:
#
#   Service                 Default   Variable                  Notes
#   ─────────────────────── ───────── ───────────────────────── ──────────────────────────────
#   PostgreSQL              5432      POSTGRES_PORT             Docker host mapping
#   Application server      8080      SERVER_PORT               Spring Boot server.port
#   Webapp (Vite)           4200      WEBAPP_PORT               Set in shell, not here (see below)
#
# IMPORTANT: WEBAPP_PORT is read by Vite at dev-server startup. Set it in your
# shell environment or webapp/.env, NOT here. If you change it, also set
# APPLICATION_HOST_URL so the server's CORS origin matches:
#
#   APPLICATION_HOST_URL=http://localhost:5200
#   WEBAPP_PORT=5200 npm -w webapp run dev
#
#POSTGRES_PORT=5432
#SERVER_PORT=8080
#APPLICATION_HOST_URL=http://localhost:4200

# =============================================================================
# AUTHENTICATION (Hephaestus-native — no Keycloak; ADR 0017)
# =============================================================================
# GitHub OAuth App (https://github.com/settings/developers), callback:
#   http://localhost:38080/login/oauth2/code/github
GITHUB_OAUTH_CLIENT_ID=replace-with-github-client-id
GITHUB_OAUTH_CLIENT_SECRET=replace-with-github-client-secret

# gitlab.lrz.de OAuth application (https://gitlab.lrz.de/-/user_settings/applications),
# redirect URI http://localhost:38080/login/oauth2/code/gitlab-lrz, scopes openid profile email read_user.
# Leave blank to disable the GitLab login button locally.
GITLAB_LRZ_OAUTH_CLIENT_ID=
GITLAB_LRZ_OAUTH_CLIENT_SECRET=

# Base64-encoded 32-byte AES-256 key sealing the short-lived OAuth state cookies.
# Blank in local dev → an ephemeral per-boot key is generated (in-flight logins don't
# survive a restart). MUST be set in production. Generate: openssl rand -base64 32
#HEPHAESTUS_AUTH_STATE_COOKIE_KEY=
# Public issuer origin (prod only; defaults to http://localhost:38080 in dev).
#HEPHAESTUS_AUTH_ISSUER=https://hephaestus.aet.cit.tum.de

# GITHUB_PAT for GitHub API authentication (as alternative for env variable)
#GITHUB_PAT=replace-with-github-pat
# =============================================================================
# MENTOR (Pi chat agent) RUNTIME (advanced — usually leave defaults)
# =============================================================================
# Per-workspace enable lives in the admin UI (workspace.mentor_enabled).
# Mentor beans load when SANDBOX_ENABLED=true (they need InteractiveSandboxService).

# Pi runner stdio framing tunables (read by pi-mentor-runner.mjs at startup).
# Production defaults match the in-container layout and never need overriding.
# Tests and CI smoke runs set these to a writable tmpdir.
#MENTOR_RUNNER_SESSIONS_DIR=/workspace/.sessions
#MENTOR_RUNNER_CWD=/workspace
#MENTOR_RUNNER_SYSTEM_PROMPT_PATH=/workspace/agent/mentor/system.md

# Per-turn budget for Pi-side watchdog (ms). Defaults to 120s; combined with a
# 30s grace this caps a worst-case Pi LLM call before the runner force-rebinds
# the session. The Java orchestrator's prompt-ack deadline (165s) outlasts this
# so the runner — not the client — owns turn cancellation.
#MENTOR_TURN_BUDGET_MS=120000

# DEBUG-ONLY: swap the Pi SDK for a deterministic stub. Every prompt returns
# `stub: <text>`. NEVER set this in production — the runner logs a loud WARN
# on startup when it sees `=1`, but there is no environment-level refusal.
#MENTOR_RUNNER_PROTOCOL_ONLY=
#MENTOR_RUNNER_STUB_DELAY_MS=
