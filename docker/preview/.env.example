# =============================================================================
# PREVIEW DEPLOYMENT ENVIRONMENT VARIABLES (Coolify)
# =============================================================================
#
# Configure these in Coolify's Environment Variables section.
# Variables marked with :?Required will show a red border if not set.
#
# Coolify Auto-Generated Variables (don't set these):
#   - SERVICE_FQDN_WEBAPP: Domain assigned to webapp service
#   - SERVICE_FQDN_APPLICATION_SERVER: Domain for API (if assigned)
#   - COOLIFY_BRANCH: Git branch name
#   - COOLIFY_CONTAINER_NAME: Container name with UUID
#
# =============================================================================

# -----------------------------------------------------------------------------
# SHARED INFRASTRUCTURE (compose.shared-infra.yaml)
# -----------------------------------------------------------------------------

# Base domain for preview environment (e.g., preview.hephaestus.cit.tum.de)
# PR deployments will be subdomains: pr-123.preview.hephaestus.cit.tum.de
PREVIEW_DOMAIN=

# Docker image tag for shared services (webhook-server)
IMAGE_TAG=latest

# Webhook secret for GitHub and GitLab webhooks (prefer SHA-256; e.g., `openssl rand -hex 32`)
WEBHOOK_SECRET=

# Auth (Hephaestus-native — no Keycloak; ADR 0017)
# Base64 32-byte AES key for OAuth state cookies. Generate: openssl rand -base64 32
HEPHAESTUS_AUTH_STATE_COOKIE_KEY=
# Exactly 32 chars — AES key for credential encryption (used by every pod, incl. the webhook receiver).
HEPHAESTUS_SECURITY_ENCRYPTION_KEY=
# GitHub OAuth App. Named GH_OAUTH_* (not GITHUB_OAUTH_*) to match compose.app.yaml, which maps
# these onto the GITHUB_OAUTH_* the server reads — GitHub Actions reserves the GITHUB_ prefix.
# The API is served at the root of its own host in previews (no /api base path), so the callback is
# https://<appserver-fqdn>/login/oauth2/code/github.
GH_OAUTH_CLIENT_ID=
GH_OAUTH_CLIENT_SECRET=
# GitLab OAuth app (optional; gitlab.com or self-hosted); callback .../login/oauth2/code/gitlab
GITLAB_OAUTH_CLIENT_ID=
GITLAB_OAUTH_CLIENT_SECRET=
GITLAB_OAUTH_BASE_URL=https://gitlab.com
GITLAB_OAUTH_DISPLAY_NAME=GitLab

# Outline documentation integration. The flag gates every Outline bean (matchIfMissing=false) and is
# needed by BOTH Coolify applications: the app stack (admin surface, sync, agent context) and the
# shared-infra webhook-server (which otherwise answers 501 to every /webhooks/outline delivery, and
# Outline auto-disables the subscription after 25 failures). Outline's webhook secret is
# per-subscription and stored encrypted on the connection row — there is no signing-secret env var.
HEPHAESTUS_INTEGRATION_OUTLINE_ENABLED=false
# Link-only login provider (never a sign-in button). BASE_URL is REQUIRED whenever CLIENT_ID is set —
# Outline is self-hosted, so there is no default origin, and a blank/invalid value makes the seed skip
# with only a WARN. Callback: https://<appserver-fqdn>/login/oauth2/code/outline, scope `read`.
OUTLINE_OAUTH_BASE_URL=
OUTLINE_OAUTH_DISPLAY_NAME=Outline
OUTLINE_OAUTH_CLIENT_ID=
OUTLINE_OAUTH_CLIENT_SECRET=

# -----------------------------------------------------------------------------
# APPLICATION STACK (compose.app.yaml)
# -----------------------------------------------------------------------------

# PostgreSQL password for per-PR database
POSTGRES_PASSWORD=hephaestus-preview

# GitHub App credentials
GH_APP_ID=
GH_APP_PRIVATE_KEY=
GH_AUTH_TOKEN=
# Install URL shown in the workspace creation wizard
GH_APP_INSTALLATION_URL=

# -----------------------------------------------------------------------------
# OPTIONAL
# -----------------------------------------------------------------------------

# NATS settings
NATS_ENABLED=true

# Monitoring (relaxed defaults for previews)
MONITORING_TIMEFRAME=14
MONITORING_RUN_ON_STARTUP=false
MONITORING_SYNC_CRON=0 0 2 * * *

# Observability
SENTRY_DSN=

# UI debugging
TANSTACK_DEVTOOLS_ENABLED=true

# Preview remains intentionally limited.
# GitLab login, GitLab workspace creation, sandbox execution, git checkout,
# and practice-review rollout validation are not supported by this preview stack.
# Use the production compose topology on local or staging when validating issue #970.

# HEPHAESTUS_AGENT_IMAGE_REFERENCE=ghcr.io/ls1intum/hephaestus/agent-pi@sha256:<digest>  # preview override only
