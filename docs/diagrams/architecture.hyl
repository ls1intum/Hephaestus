// Hephaestus Architecture — 5 Internal + 7 External Components
// Render at https://hylimo.github.io
componentDiagram {
    vdist = 200
    hdist = 350

    // === Internal Platform ===
    component("Hephaestus") {

        component("WebApp", keywords = list("React 19")) layout {
            pos = apos(50, 50)
        }

        component("ApplicationServer", keywords = list("Spring Boot")) layout {
            pos = rpos(WebApp, hdist + 100, 0)
        }

        component("IntelligenceService", keywords = list("Hono")) layout {
            pos = rpos(WebApp, 0, vdist)
        }

        component("WebhookIngest", keywords = list("Hono")) layout {
            pos = rpos(ApplicationServer, 0, vdist)
        }

        component("DockerSandbox", keywords = list("AI Agents")) layout {
            pos = rpos(IntelligenceService, (hdist + 100) / 2, vdist)
        }

    } layout {
        pos = apos(200, 0)
    }

    // === External Systems ===
    component("CodePlatforms", keywords = list("GitHub, GitLab")) layout {
        pos = rpos(Hephaestus, -200, vdist * 2 + 200)
    }

    component("PostgreSQL", keywords = list("Database")) layout {
        pos = rpos(CodePlatforms, hdist, 0)
    }

    component("NATS", keywords = list("Events")) layout {
        pos = rpos(PostgreSQL, hdist - 50, 0)
    }

    component("Keycloak", keywords = list("Auth")) layout {
        pos = rpos(NATS, hdist - 50, 0)
    }

    component("LLMProvider", keywords = list("AI")) layout {
        pos = rpos(Keycloak, hdist - 50, 0)
    }

    component("Langfuse", keywords = list("Traces")) layout {
        pos = rpos(LLMProvider, hdist - 50, 0)
    }

    component("Slack", keywords = list("Notifications")) layout {
        pos = rpos(Langfuse, hdist - 50, 0)
    }

    // === Internal Interfaces ===

    // WebApp → ApplicationServer (REST)
    appREST = ApplicationServer.provides("REST", 0.5, dist = 50)
    webREST = WebApp.requires("REST", 0.5)
    webREST dependsOn appREST

    // WebApp → IntelligenceService (Mentor)
    intelMentor = IntelligenceService.provides("MentorAPI", 0.75, dist = 50)
    webMentor = WebApp.requires("MentorAPI", 0.75)
    webMentor dependsOn intelMentor

    // ApplicationServer → DockerSandbox (Spawn Agent)
    sandboxAPI = DockerSandbox.provides("AgentAPI", 0.5, dist = 50)
    appAgent = ApplicationServer.requires("Agent", 0.75)
    appAgent dependsOn sandboxAPI

    // WebhookIngest provides Webhooks
    webhookIn = WebhookIngest.provides("Webhooks", 0.75, dist = 50)

    // === External Dependencies ===

    pgDB = PostgreSQL.provides("DB", 0.5, dist = 40)
    natsEvents = NATS.provides("Events", 0.5, dist = 40)
    kcAuth = Keycloak.provides("Auth", 0.5, dist = 40)
    llmAI = LLMProvider.provides("LLM", 0.5, dist = 40)
    lfTraces = Langfuse.provides("Traces", 0.5, dist = 40)

    // ApplicationServer → External
    appDB = ApplicationServer.requires("DB", 0.25)
    appDB dependsOn pgDB
    appEvents = ApplicationServer.requires("Events", 0.25)
    appEvents dependsOn natsEvents
    appAuthReq = ApplicationServer.requires("Auth", 0.25)
    appAuthReq dependsOn kcAuth

    // DockerSandbox → External
    sandboxLLM = DockerSandbox.requires("LLM", 0.25)
    sandboxLLM dependsOn llmAI

    // IntelligenceService → External
    intelLLM = IntelligenceService.requires("LLM", 0.25)
    intelLLM dependsOn llmAI
    intelTraces = IntelligenceService.requires("Traces", 0.25)
    intelTraces dependsOn lfTraces

    // ApplicationServer → Slack
    slackNotify = Slack.provides("Notify", 0.5, dist = 40)
    appSlack = ApplicationServer.requires("Notify", 0.5)
    appSlack dependsOn slackNotify

    // WebhookIngest → NATS
    webhookPub = WebhookIngest.requires("Publish", 0.25)
    webhookPub dependsOn natsEvents

    // CodePlatforms → WebhookIngest
    cpWebhooks = CodePlatforms.requires("push", 0.5)
    cpWebhooks dependsOn webhookIn
}
