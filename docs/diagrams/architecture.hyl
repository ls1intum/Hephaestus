// Hephaestus Architecture
// Render at https://hylimo.github.io
componentDiagram {
    hdist = 350
    vdist = 250

    // ================================================================
    // Managed components
    // ================================================================
    component("WebApp", keywords = list("managed")) layout {
        pos = apos(0, 0)
    }

    component("ApplicationServer", keywords = list("managed")) layout {
        pos = rpos(WebApp, hdist + 100, 0)
    }

    component("IntelligenceService", keywords = list("managed")) layout {
        pos = rpos(WebApp, 0, vdist)
    }

    component("WebhookIngest", keywords = list("managed")) layout {
        pos = rpos(ApplicationServer, 0, vdist)
    }

    component("DockerSandbox", keywords = list("managed")) layout {
        pos = rpos(IntelligenceService, (hdist + 100) / 2, vdist)
    }

    // ================================================================
    // External systems
    // ================================================================
    component("CodePlatforms", keywords = list("external")) layout {
        pos = rpos(WebApp, -50, vdist * 3)
    }

    component("PostgreSQL", keywords = list("external")) layout {
        pos = rpos(CodePlatforms, hdist, 0)
    }

    component("NATS", keywords = list("external")) layout {
        pos = rpos(PostgreSQL, hdist, 0)
    }

    component("Keycloak", keywords = list("external")) layout {
        pos = rpos(NATS, hdist, 0)
    }

    component("LLMProvider", keywords = list("external")) layout {
        pos = rpos(Keycloak, hdist, 0)
    }

    // ================================================================
    // Interfaces (all connected notation)
    // ================================================================

    // WebApp --> ApplicationServer
    ApplicationServer.provides("REST", 0.5, dist = 50)
    WebApp.requires(0.5, REST)

    // ApplicationServer --> IntelligenceService
    IntelligenceService.provides("Mentor", 0.75, dist = 50)
    ApplicationServer.requires(0.75, Mentor)

    // ApplicationServer --> DockerSandbox
    DockerSandbox.provides("Sandbox", 0.5, dist = 50)
    ApplicationServer.requires(0.5, Sandbox)

    // WebhookIngest + ApplicationServer --> CodePlatforms
    CodePlatforms.provides("Git", 0.75, dist = 40)
    WebhookIngest.requires(0.25, Git)
    ApplicationServer.requires(0.25, Git)

    // ApplicationServer + IntelligenceService --> PostgreSQL
    PostgreSQL.provides("DB", 0.75, dist = 40)
    ApplicationServer.requires(0.25, DB)
    IntelligenceService.requires(0.25, DB)

    // ApplicationServer + WebhookIngest --> NATS
    NATS.provides("Events", 0.75, dist = 40)
    ApplicationServer.requires(0.25, Events)
    WebhookIngest.requires(0.25, Events)

    // WebApp + ApplicationServer --> Keycloak
    Keycloak.provides("Auth", 0.75, dist = 40)
    WebApp.requires(0.75, Auth)
    ApplicationServer.requires(0.25, Auth)

    // IntelligenceService + DockerSandbox --> LLMProvider
    LLMProvider.provides("LLM", 0.75, dist = 40)
    IntelligenceService.requires(0.25, LLM)
    DockerSandbox.requires(0.25, LLM)
}
