// Hephaestus Deployment View
// Render at https://hylimo.github.io
//
// This diagram shows the deployable components and their interfaces.
// The conceptual practice-aware loop (events -> detection -> findings ->
// channels) is in `practice-loop.hyl` â€” keep them paired.
componentDiagram {
    w = 250
    hdist = 450
    vdist = 110

    component("Hephaestus") {
        component("Webapp") layout {
            width = w
        }

        component("Application Server") layout {
            width = w
            pos = rpos(Webapp, hdist, 0)
        }

        component("PostgreSQL") layout {
            width = w
            pos = rpos(`Application Server`, 0, vdist * -2)
        }

        component("User Management") layout {
            width = w
            pos = rpos(`Application Server`, hdist * -0.5, vdist * -1)
        }

        component("Agent Sandbox") layout {
            width = w
            pos = rpos(`Application Server`, hdist, 0)
        }

        component("Intelligence Service") layout {
            width = w
            pos = rpos(`Agent Sandbox`, 0, vdist * -1)
        }

        component("Message Broker") layout {
            width = w
            pos = rpos(`Agent Sandbox`, 0, vdist)
        }

        component("Webhook Ingest") layout {
            width = w
            pos = rpos(`Application Server`, 0, vdist)
        }

        component("Git Provider") layout {
            width = w
            pos = rpos(`User Management`, 0, vdist * 3.75)
        }

        component("LLM Provider") layout {
            width = w
            pos = rpos(`Intelligence Service`, hdist, vdist / 2)
        }
    } layout {
        height = 521.35
        pos = apos(0, 1)
        width = 1248
    }

    `LLM Provider`.provides("LLM", 0.5, dist = 70, namePos = [0, 25])
    `Intelligence Service`.requires(0, LLM) with {
        over = start(0).axisAligned(0.75, end(0.5))
    }
    `Agent Sandbox`.requires(0, LLM) with {
        over = start(0).axisAligned(0.75, end(0.5))
    }

    PostgreSQL.provides("Data", 0.205, dist = 50, namePos = [50, -10])
    `Application Server`.requires(0.795, Data)

    `User Management`.provides("Auth", 0.5, dist = 50, namePos = [0, 25])
    `User Management`.provides("User Data", dist = 50, namePos = [0, 25])
    `Webapp`.requires(0.75, Auth) with {
        over = start(0).axisAligned(0, end(0.5))
    }
    `Application Server`.requires(0.75, `User Data`) with {
        over = start(0).axisAligned(0, end(0.5))
    }

    `Application Server`.provides("App Data", 0.5, dist = 100, namePos = [0, 25])
    Webapp.requires(0, `App Data`)

    `Intelligence Service`.provides("Intelligence Data", 0.5, dist = 100, namePos = [0, 25])
    `Application Server`.requires(0.839, `Intelligence Data`) with {
        over = start(0).axisAligned(0, end(0.5))
    }
    `Agent Sandbox`.provides("Sandbox", 0.5, dist = 100, namePos = [0, 25])
    `Application Server`.requires(0.01, `Sandbox`, dist = 108.2) with {
        over = start(0).axisAligned(0, end(0.5))
    }

    `Webhook Ingest`.provides("Activity Events", 0.25, dist = 94.7, namePos = [80, -10])

    `Message Broker`.provides("Message", 0.501, dist = 100, namePos = [50, 13])
    `Webhook Ingest`.requires(0, Message) with {
        over = start(0).axisAligned(0, end(0.5))
    }
    `Application Server`.requires(0.161, Message) with {
        over = start(0).axisAligned(-0.431, end(0.5))
    }

    `Git Provider`.provides("Repository Data", 0.75, dist = 46.3, namePos = [-75, -10])
    `Git Provider`.requires(0, `Activity Events`, dist = 80) with {
        over = start(0).axisAligned(-1, end(0.5))
    }

    `Application Server`.requires(0.33, `Repository Data`, dist = 250) with {
        over = start(0).axisAligned(-0.827, end(0.5))
    }
}
