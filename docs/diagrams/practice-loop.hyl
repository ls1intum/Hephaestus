// Hephaestus Practice-Aware Feedback Loop
// Render at https://hylimo.github.io
//
// The conceptual flow that the deployment view (architecture.hyl) does not
// show: how activity becomes findings and how findings reach people through
// four coupled channels.
//
// Mapping to deployment components:
//   Activity Events        <- Webhook Ingest + Application Server
//   Practice Catalog       <- PostgreSQL (practice table) + Application Server
//   Practice Detection     <- Agent Sandbox (LLM-based detector)
//   Findings + Routing     <- Application Server (PracticeFinding + delivery composer)
//   In-Context Feedback    <- DiffNotePoster on Git Provider PR/MR
//   Reflection Dashboard   <- Webapp pull surface
//   Conversational Mentor  <- Webapp + Intelligence Service
//   Facilitator Dashboard  <- Webapp educator surface
componentDiagram {
    w = 220
    hdist = 360
    vdist = 110

    component("Hephaestus Practice Loop") {

        // === Sources (left column) ===
        component("Activity Events") layout {
            width = w
        }

        component("Practice Catalog") layout {
            width = w
            pos = rpos(`Activity Events`, 0, vdist * 2)
        }

        // === Detection (centre) ===
        component("Practice Detection") layout {
            width = w
            pos = rpos(`Activity Events`, hdist, vdist)
        }

        // === Routing (centre-right) ===
        component("Finding + Routing") layout {
            width = w
            pos = rpos(`Practice Detection`, hdist, 0)
        }

        // === Channels (right column, top to bottom) ===
        component("In-Context Feedback") layout {
            width = w
            pos = rpos(`Finding + Routing`, hdist, vdist * -2)
        }

        component("Reflection Dashboard") layout {
            width = w
            pos = rpos(`Finding + Routing`, hdist, vdist * -0.5)
        }

        component("Conversational Mentor") layout {
            width = w
            pos = rpos(`Finding + Routing`, hdist, vdist)
        }

        component("Facilitator Dashboard") layout {
            width = w
            pos = rpos(`Finding + Routing`, hdist, vdist * 2.5)
        }

        // === Audiences (far right) ===
        component("Contributor") layout {
            width = w
            pos = rpos(`Reflection Dashboard`, hdist, 0)
        }

        component("Facilitator") layout {
            width = w
            pos = rpos(`Facilitator Dashboard`, hdist, 0)
        }
    } layout {
        pos = apos(0, 1)
    }

    // === Detection consumes events and the catalog ===
    `Activity Events`.provides("events", 0.5, dist = 60, namePos = [0, -10])
    `Practice Detection`.requires(0, events) with {
        over = start(0).axisAligned(0, end(0.5))
    }

    `Practice Catalog`.provides("definitions", 0.5, dist = 60, namePos = [0, -10])
    `Practice Detection`.requires(1, definitions) with {
        over = start(0).axisAligned(0, end(0.5))
    }

    // === Detection produces findings ===
    `Practice Detection`.provides("findings", 0.5, dist = 60, namePos = [0, -10])
    `Finding + Routing`.requires(0, findings) with {
        over = start(0).axisAligned(0, end(0.5))
    }

    // === Routing distributes to four channels ===
    `Finding + Routing`.provides("push (task-level)", 0.2, dist = 80, namePos = [40, -10])
    `In-Context Feedback`.requires(0, `push (task-level)`) with {
        over = start(0).axisAligned(0, end(0.5))
    }

    `Finding + Routing`.provides("pull (process-level)", 0.45, dist = 80, namePos = [40, -10])
    `Reflection Dashboard`.requires(0, `pull (process-level)`) with {
        over = start(0).axisAligned(0, end(0.5))
    }

    `Finding + Routing`.provides("dialogic (self-reg.)", 0.65, dist = 80, namePos = [40, -10])
    `Conversational Mentor`.requires(0, `dialogic (self-reg.)`) with {
        over = start(0).axisAligned(0, end(0.5))
    }

    `Finding + Routing`.provides("facilitator (decision support)", 0.85, dist = 80, namePos = [40, -10])
    `Facilitator Dashboard`.requires(0, `facilitator (decision support)`) with {
        over = start(0).axisAligned(0, end(0.5))
    }

    // === Channels reach audiences ===
    `In-Context Feedback`.provides("PR comments", 0.5, dist = 50, namePos = [0, -10])
    Contributor.requires(0, `PR comments`) with {
        over = start(0).axisAligned(0, end(0.5))
    }

    `Reflection Dashboard`.provides("findings view", 0.5, dist = 50, namePos = [0, -10])
    Contributor.requires(0.5, `findings view`) with {
        over = start(0).axisAligned(0, end(0.5))
    }

    `Conversational Mentor`.provides("dialogue", 0.5, dist = 50, namePos = [0, -10])
    Contributor.requires(1, dialogue) with {
        over = start(0).axisAligned(0, end(0.5))
    }

    `Facilitator Dashboard`.provides("contributor overview", 0.5, dist = 50, namePos = [0, -10])
    Facilitator.requires(0, `contributor overview`) with {
        over = start(0).axisAligned(0, end(0.5))
    }

    // === Contestation flows back from contributor to findings ===
    Contributor.provides("contestation", 0.85, dist = 80, namePos = [-100, 13])
    `Finding + Routing`.requires(0.85, contestation) with {
        over = start(0).axisAligned(0, end(0.5))
    }
}
